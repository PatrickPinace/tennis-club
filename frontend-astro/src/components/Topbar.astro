<script>
  import { Switch } from '@headlessui/react';
  import { useState } from 'react';

  export default function Topbar({ classicUrl }) {
    const [enabled, setEnabled] = useState(false);

    return (
      <nav class="topbar">
        <div class="topbar__inner">
          <div class="topbar__theme-switch">
            <Switch
              checked={enabled}
              onChange={setEnabled}
              class={`topbar__switch ${enabled ? 'topbar__switch--enabled' : ''}`}
            >
              {enabled ? 'Jasny' : 'Ciemny'}
            </Switch>
          </div>
        </div>
      </nav>
    );
  }
</script>

