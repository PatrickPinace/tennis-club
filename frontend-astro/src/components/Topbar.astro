---
// Topbar.astro — przepisany z templates/components/_topbar.html
interface Props {
  title?: string;
}
const { title = 'Tennis Club' } = Astro.props;
---

<header class="app-topbar">
  <div class="app-topbar__left">
    <!-- Mobile hamburger -->
    <button
      class="btn-ghost btn-icon"
      id="sidebar-toggle"
      onclick="toggleSidebar()"
      aria-label="Menu"
      style="display:none;"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/>
      </svg>
    </button>
    <span class="topbar-page-title">{title}</span>
  </div>

  <div class="app-topbar__right">
    <!-- Theme toggle -->
    <button
      class="btn-ghost btn-icon"
      id="theme-toggle"
      onclick="toggleTheme()"
      title="Zmień motyw"
      aria-label="Zmień motyw"
    >
      <!-- Moon icon (dark mode active) -->
      <svg id="theme-icon-dark" width="18" height="18" viewBox="0 0 20 20" fill="currentColor" style="display:none;">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
      </svg>
      <!-- Sun icon (light mode active) -->
      <svg id="theme-icon-light" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
      </svg>
    </button>

    <!-- Notification bell (placeholder) -->
    <div style="position:relative;">
      <button class="notif-btn" title="Powiadomienia" aria-label="Powiadomienia">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
        </svg>
      </button>
    </div>

    <!-- User chip (placeholder — docelowo z /api/me/) -->
    <div class="user-chip">
      <div class="user-chip__avatar">U</div>
      <span class="user-chip__name">Użytkownik</span>
    </div>
  </div>
</header>

<style>
  .app-topbar {
    height: var(--topbar-height);
    padding: 0 28px;
    display: flex; align-items: center; justify-content: space-between;
    background: var(--topbar-bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    position: sticky; top: 0; z-index: 50;
  }

  .app-topbar__left,
  .app-topbar__right {
    display: flex; align-items: center; gap: 8px;
  }
  .app-topbar__left { gap: 16px; }

  .topbar-page-title {
    font-size: 1rem; font-weight: 600; color: var(--text); white-space: nowrap;
  }

  .btn-ghost {
    background: transparent; color: var(--text-muted); border: none;
    border-radius: var(--radius-sm); cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .btn-ghost:hover { background: var(--surface-hover); color: var(--text); }
  .btn-icon {
    display: grid; place-items: center;
    min-height: 36px; width: 36px; padding: 0;
  }

  .notif-btn {
    position: relative; width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    display: grid; place-items: center;
    color: var(--text-muted); background: none; border: none; cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .notif-btn:hover { background: var(--surface-hover); color: var(--text); }

  .user-chip {
    display: flex; align-items: center; gap: 10px;
    padding: 5px 10px 5px 5px;
    border-radius: var(--radius-sm); cursor: pointer;
    transition: background 0.15s;
  }
  .user-chip:hover { background: var(--surface-hover); }

  .user-chip__avatar {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--primary-subtle);
    border: 1.5px solid var(--primary);
    color: var(--primary); font-weight: 700; font-size: 0.78rem;
    display: grid; place-items: center;
  }
  .user-chip__name { font-size: 0.82rem; font-weight: 600; color: var(--text); }

  @media (max-width: 1024px) {
    #sidebar-toggle { display: flex !important; }
  }
</style>
