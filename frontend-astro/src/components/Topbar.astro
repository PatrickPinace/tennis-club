---
// Topbar.astro — przepisany wg projektu grafika
// Search bar + CTA "+ Nowa Rezerwacja" + user chip z inicjałami
import { url } from '@/lib/url';

// Link "Wersja klasyczna" → Django.
// W dev: DJANGO_API_URL=http://localhost:8000 → http://localhost:8000/tournaments
// W prod za Caddy: DJANGO_API_URL jest wewnętrzny (http://tennis-web:8000),
//   ale przeglądarka musi dostać zewnętrzny URL, więc używamy ścieżki relatywnej /tournaments
//   (Caddy routuje /tournaments → Django, bo nie pasuje do /astro/*).
// Aby to działało w obu środowiskach, używamy PUBLIC_DJANGO_URL jeśli ustawiony,
// albo DJANGO_API_URL tylko gdy zawiera localhost (dev), w prod fallback to '/tournaments'.
const _djangoApiUrl = process.env.DJANGO_API_URL ?? '';
const classicUrl = _djangoApiUrl.includes('localhost') || _djangoApiUrl.includes('127.0.0.1')
  ? _djangoApiUrl.replace(/\/$/, '') + '/tournaments'
  : '/tournaments';

interface Props {
  greeting?: string;   // "Witaj z powrotem, Marcin!" — opcjonalny heading w treści
  showSearch?: boolean;
  showCta?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
  /** Liczba nieprzečytanych powiadomień z API (null = ukryj odznakę) */
  unreadCount?: number | null;
}
const {
  greeting,
  showSearch = true,
  showCta = true,
  ctaLabel = '+ Nowa Rezerwacja',
  ctaHref = '/courts/reservations',
  unreadCount = null,
} = Astro.props;
---

<header class="topbar">
  <!-- Left: greeting text lub tytuł -->
  <div class="topbar__left">
    <button
      class="topbar__hamburger"
      id="sidebar-toggle"
      onclick="toggleSidebar()"
      aria-label="Menu"
      style="display:none;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    {greeting && (
      <h1 class="topbar__greeting">{greeting}</h1>
    )}
  </div>

  <!-- Right: search + bell + CTA + user -->
  <div class="topbar__right">

    {showSearch && (
      <div class="topbar__search">
        <svg class="topbar__search-icon" width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
        </svg>
        <input
          type="search"
          class="topbar__search-input"
          placeholder="Szukaj rezerwacji, graczy..."
          aria-label="Szukaj"
        />
      </div>
    )}

    <!-- Notifications bell -->
    <div class="topbar__notif-wrap">
      <button
        class="topbar__icon-btn"
        id="notif-btn"
        onclick="toggleNotifPanel(); event.stopPropagation();"
        aria-label="Powiadomienia"
        title="Powiadomienia"
      >
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
        </svg>
        {unreadCount !== null && unreadCount > 0 && (
          <span class="topbar__notif-dot" id="notif-count" aria-label={`${unreadCount} nieprzeczytanych powiadomień`}>
            {unreadCount > 99 ? '99+' : unreadCount}
          </span>
        )}
        {(unreadCount === null || unreadCount === 0) && (
          <span class="topbar__notif-dot" id="notif-count" style="display:none;">0</span>
        )}
      </button>

      <!-- Notifications panel -->
      <div class="topbar__notif-panel" id="notif-panel" style="display:none;" role="dialog" aria-label="Powiadomienia">
        <div class="topbar__notif-arrow" aria-hidden="true"></div>
        <div class="topbar__notif-header">
          <span class="topbar__notif-title">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
              <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
            </svg>
            Powiadomienia
          </span>
          <button onclick="readAllNotif()" class="topbar__notif-mark">Oznacz wszystkie</button>
        </div>
        <div id="notif-list" class="topbar__notif-list">
          <div class="topbar__notif-empty">Brak nowych powiadomień</div>
        </div>
      </div>
    </div>

    {showCta && (
      <a href={ctaHref} class="topbar__cta">
        {ctaLabel}
      </a>
    )}

    <!-- User chip — wypełniany przez JS po sprawdzeniu /api/auth/me/ -->
    <div class="topbar__user-wrap">
      <!-- Stan zalogowany (domyślnie ukryty, JS go pokazuje) -->
      <div class="topbar__user" id="user-chip" style="display:none;" role="button" tabindex="0" aria-label="Menu użytkownika">
        <div class="topbar__user-avatar" aria-hidden="true" id="user-avatar">??</div>
        <div class="topbar__user-info">
          <span class="topbar__user-name" id="user-name">—</span>
          <span class="topbar__user-surname" id="user-surname"></span>
        </div>
        <svg class="topbar__user-caret" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
        <!-- Dropdown menu -->
        <div class="topbar__user-menu" id="user-menu" style="display:none;">
          <a href={url('/tournaments/manage')} class="topbar__user-menu-item topbar__user-menu-link">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
              <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
            </svg>
            Moje turnieje
          </a>
          <a href={url('/profile')} class="topbar__user-menu-item topbar__user-menu-link">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
            </svg>
            Mój profil
          </a>
          <div class="topbar__user-menu-divider"></div>
          <button class="topbar__user-menu-item" id="logout-btn">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 001 1h12a1 1 0 001-1V4a1 1 0 00-1-1H3zm11 4a1 1 0 10-2 0v4a1 1 0 102 0V7zm-3 1a1 1 0 10-2 0v3a1 1 0 102 0V8z" clip-rule="evenodd"/>
            </svg>
            Wyloguj
          </button>
        </div>
      </div>
      <!-- Stan niezalogowany -->
      <a href={url('/login')} class="topbar__login-link" id="login-link">Zaloguj się</a>
    </div>

    <!-- Link do wersji klasycznej (Django) -->
    <a href={classicUrl} class="topbar__classic-link" title="Wróć do wersji klasycznej">
      Wersja klasyczna →
    </a>

    <!-- Theme toggle — dyskretny -->
    <button
      class="topbar__icon-btn topbar__theme-btn"
      onclick="toggleTheme()"
      aria-label="Zmień motyw"
      title="Zmień motyw"
    >
      <svg id="theme-icon-dark" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="display:none;" aria-hidden="true">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
      </svg>
      <svg id="theme-icon-light" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .topbar {
    height: var(--topbar-height);
    padding: 0 28px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    background: var(--topbar-bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky; top: 0; z-index: 50;
  }

  .topbar__left {
    display: flex; align-items: center; gap: 14px;
    min-width: 0; flex-shrink: 1;
  }

  .topbar__greeting {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.025em;
    white-space: nowrap;
    line-height: 1;
  }

  .topbar__hamburger {
    display: none;
    align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 8px;
    color: var(--text-muted);
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
  }
  .topbar__hamburger:hover { background: var(--surface-hover); color: var(--text); }

  /* ── Right group ──────────────────────────────────────────────────────── */
  .topbar__right {
    display: flex; align-items: center; gap: 8px;
    flex-shrink: 0;
  }

  /* ── Search ───────────────────────────────────────────────────────────── */
  .topbar__search {
    position: relative;
    display: flex; align-items: center;
  }

  .topbar__search-icon {
    position: absolute; left: 10px;
    color: var(--text-dim);
    pointer-events: none;
    flex-shrink: 0;
  }

  .topbar__search-input {
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 8px;
    padding: 7px 14px 7px 32px;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    width: 220px;
    transition: border-color 0.15s, box-shadow 0.15s, width 0.2s;
    outline: none;
  }
  .topbar__search-input::placeholder { color: var(--text-dim); }
  .topbar__search-input:hover { border-color: var(--border-light); }
  .topbar__search-input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-subtle);
    width: 260px;
  }

  /* ── Icon buttons (bell, theme) ───────────────────────────────────────── */
  .topbar__icon-btn {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: grid; place-items: center;
    color: var(--text-muted);
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
    position: relative;
    cursor: pointer;
  }
  .topbar__icon-btn:hover { background: var(--surface-hover); color: var(--text); }

  /* ── Notification bell ────────────────────────────────────────────────── */
  .topbar__notif-wrap { position: relative; }

  .topbar__notif-dot {
    position: absolute; top: 3px; right: 3px;
    min-width: 16px; height: 16px;
    background: #ef4444; color: #fff;
    border-radius: 99px; font-size: 0.6rem; font-weight: 700;
    display: grid; place-items: center;
    border: 2px solid var(--bg);
    padding: 0 3px;
  }

  .topbar__notif-panel {
    position: absolute; right: 0; top: calc(100% + 8px);
    width: 340px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 30px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.08);
    z-index: 200;
    overflow: hidden;
    animation: notif-enter 0.15s ease;
  }

  @keyframes notif-enter {
    from { opacity: 0; transform: translateY(-6px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Strzałka wskazująca na dzwoneczek */
  .topbar__notif-arrow {
    position: absolute; top: -6px; right: 14px;
    width: 11px; height: 11px;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
    transform: rotate(45deg);
  }

  .topbar__notif-title {
    display: flex; align-items: center; gap: 7px;
    font-weight: 700; font-size: 0.875rem; color: var(--text);
  }

  .topbar__notif-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 13px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .topbar__notif-mark {
    font-size: 0.75rem; color: var(--primary);
    background: none; border: none; cursor: pointer;
    font-family: var(--font-sans);
    padding: 3px 8px; border-radius: 5px;
    transition: background 0.1s;
  }
  .topbar__notif-mark:hover {
    background: color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .topbar__notif-list {
    max-height: 380px; overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .topbar__notif-list::-webkit-scrollbar { width: 4px; }
  .topbar__notif-list::-webkit-scrollbar-track { background: transparent; }
  .topbar__notif-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  /* Uwaga: .topbar__notif-empty duplikowana w :global poniżej (potrzebne dla JS innerHTML) */
  .topbar__notif-empty {
    padding: 32px 20px;
    text-align: center;
    color: var(--text-muted); font-size: 0.84rem;
    display: flex; align-items: center; justify-content: center;
    min-height: 80px;
  }

  /* ── CTA button ───────────────────────────────────────────────────────── */
  .topbar__cta {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 0 16px; height: 36px;
    background: #22c55e; color: #000;
    border-radius: 8px;
    font-size: 0.875rem; font-weight: 700;
    text-decoration: none; white-space: nowrap;
    transition: background 0.15s, transform 0.1s;
    box-shadow: 0 2px 8px rgba(34,197,94,0.3);
  }
  .topbar__cta:hover { background: #16a34a; transform: translateY(-1px); }
  .topbar__cta:active { transform: translateY(0); }

  /* ── User chip ────────────────────────────────────────────────────────── */
  .topbar__user {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 8px 5px 5px;
    border-radius: 8px; cursor: pointer;
    transition: background 0.12s;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }
  .topbar__user:hover { background: var(--surface-hover); border-color: var(--border-light); }

  .topbar__user-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(34,197,94,0.15);
    border: 1.5px solid #22c55e;
    color: #22c55e; font-weight: 800; font-size: 0.68rem;
    display: grid; place-items: center; flex-shrink: 0;
  }

  .topbar__user-info {
    display: flex; flex-direction: column;
    line-height: 1.15;
  }
  .topbar__user-name   { font-size: 0.78rem; font-weight: 700; color: var(--text); }
  .topbar__user-surname { font-size: 0.72rem; color: var(--text-muted); }

  .topbar__user-caret { color: var(--text-dim); flex-shrink: 0; }

  .topbar__theme-btn { margin-left: 2px; }

  /* ── Classic version link ─────────────────────────────────────────────── */
  .topbar__classic-link {
    font-size: 0.75rem; font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    white-space: nowrap;
    padding: 4px 8px;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
  }
  .topbar__classic-link:hover {
    background: var(--surface-hover);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .topbar__classic-link { display: none; }
  }

  /* ── User wrap (auth state) ────────────────────────────────────────── */
  .topbar__user-wrap { position: relative; }

  .topbar__login-link {
    display: inline-flex; align-items: center;
    padding: 0 14px; height: 36px;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    font-size: 0.875rem; font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .topbar__login-link:hover {
    background: var(--surface-hover);
    color: var(--text);
    border-color: var(--border-light);
  }

  .topbar__user-menu {
    position: absolute; right: 0; top: calc(100% + 6px);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md);
    z-index: 200;
    min-width: 140px;
    overflow: hidden;
  }

  .topbar__user-menu-item {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 10px 14px;
    font-size: 0.875rem; font-weight: 500; color: var(--text);
    background: none; border: none; cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.1s;
    text-align: left;
  }
  .topbar__user-menu-item:hover { background: var(--surface-hover); }

  .topbar__user-menu-link {
    text-decoration: none;
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 10px 14px;
    font-size: 0.875rem; font-weight: 500; color: var(--text);
    transition: background 0.1s;
  }
  .topbar__user-menu-link:hover { background: var(--surface-hover); }

  .topbar__user-menu-divider {
    height: 1px; background: var(--border);
    margin: 2px 0;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .topbar__hamburger { display: flex !important; }
    .topbar__search-input { width: 160px; }
    .topbar__search-input:focus { width: 200px; }
  }

  @media (max-width: 640px) {
    .topbar { padding: 0 16px; }
    .topbar__greeting { font-size: 1.1rem; }
    .topbar__search { display: none; }
    .topbar__user-info { display: none; }
    .topbar__cta { padding: 0 10px; font-size: 0.8rem; }
  }

  /* ── Notification panel items (wstrzykiwane przez JS) ────────── */
  :global(.topbar__notif-item) {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 11px 16px;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
    cursor: default;
  }
  :global(.topbar__notif-item:last-child) { border-bottom: none; }
  :global(.topbar__notif-item:hover) { background: var(--surface-hover); }

  :global(.topbar__notif-dot) {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
    background: transparent;
  }

  :global(.topbar__notif-body) { flex: 1; min-width: 0; }

  :global(.topbar__notif-msg) {
    font-size: 0.82rem; color: var(--text); line-height: 1.45;
    margin: 0 0 3px;
    word-break: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.topbar__notif-time) {
    font-size: 0.7rem; color: var(--text-muted);
    display: block;
  }

  :global(.topbar__notif-item--unread) {
    background: color-mix(in srgb, var(--primary) 5%, transparent);
    border-left: 3px solid var(--primary);
    padding-left: 13px;
    cursor: pointer;
  }
  :global(.topbar__notif-item--unread .topbar__notif-dot) {
    background: var(--primary);
  }
  :global(.topbar__notif-item--unread .topbar__notif-msg) {
    font-weight: 600;
  }
  :global(.topbar__notif-item--unread:hover) {
    background: color-mix(in srgb, var(--primary) 9%, transparent);
  }

  :global(.topbar__notif-footer) {
    padding: 9px 16px;
    border-top: 1px solid var(--border);
    text-align: center;
    background: var(--surface-2);
  }
  :global(.topbar__notif-footer a) {
    font-size: 0.78rem; color: var(--primary);
    text-decoration: none; font-weight: 600;
  }
  :global(.topbar__notif-footer a:hover) { text-decoration: underline; }

  /* Elementy generowane przez JS — wymagają :global bo nie dostają scoped atrybutu */
  :global(.topbar__notif-empty) {
    padding: 32px 20px;
    text-align: center;
    color: var(--text-muted); font-size: 0.84rem;
    display: flex; align-items: center; justify-content: center;
    min-height: 80px;
  }
</style>

<script>
  const _API = (document.querySelector('meta[name="api-base"]') as HTMLMetaElement)?.content
             ?? 'http://localhost:8000';

  // ── Helpers ───────────────────────────────────────────────────────────────
  function getCsrf(): string {
    return document.cookie.match(/csrftoken=([^;]+)/)?.[1] ?? '';
  }

  function fmtTime(iso: string): string {
    try {
      const d = new Date(iso);
      const now = new Date();
      const diff = (now.getTime() - d.getTime()) / 1000;
      if (diff < 60) return 'przed chwilą';
      if (diff < 3600) return `${Math.floor(diff / 60)} min temu`;
      if (diff < 86400) return `${Math.floor(diff / 3600)} godz. temu`;
      return d.toLocaleDateString('pl-PL', { day: '2-digit', month: 'short' });
    } catch { return iso; }
  }

  // ── Notifications panel ───────────────────────────────────────────────────
  let notifPanelOpen = false;
  let notifLoaded = false;

  function toggleNotifPanel() {
    const panel = document.getElementById('notif-panel') as HTMLElement | null;
    if (!panel) return;
    notifPanelOpen = !notifPanelOpen;
    panel.style.display = notifPanelOpen ? 'block' : 'none';
    if (notifPanelOpen && !notifLoaded) {
      loadNotifications();
    }
  }
  // Eksponuj globalnie — wymagane przez onclick="" w HTML
  (window as any).toggleNotifPanel = toggleNotifPanel;

  async function loadNotifications() {
    const list = document.getElementById('notif-list');
    if (!list) return;
    list.innerHTML = '<div class="topbar__notif-empty" style="padding:16px;text-align:center;font-size:0.8rem;color:var(--text-dim);">Ładowanie…</div>';
    try {
      const res = await fetch(`${_API}/api/notifications/`, { credentials: 'include' });
      if (!res.ok) throw new Error();
      const data: Array<{id:number;message:string;created_at:string;is_read:boolean}> = await res.json();
      notifLoaded = true;
      renderNotifList(data);
    } catch {
      list.innerHTML = '<div class="topbar__notif-empty">Nie udało się pobrać powiadomień.</div>';
    }
  }

  function renderNotifList(notifications: Array<{id:number;message:string;created_at:string;is_read:boolean}>) {
    const list = document.getElementById('notif-list');
    if (!list) return;
    const unread = notifications.filter(n => !n.is_read);
    const recent = notifications.slice(0, 10);
    if (!recent.length) {
      list.innerHTML = '<div class="topbar__notif-empty">Brak powiadomień.</div>';
      updateBadge(0);
      return;
    }
    list.innerHTML = recent.map(n => `
      <div class="topbar__notif-item${n.is_read ? '' : ' topbar__notif-item--unread'}"
           data-notif-id="${n.id}">
        <div class="topbar__notif-dot"></div>
        <div class="topbar__notif-body">
          <p class="topbar__notif-msg">${escHtmlNotif(n.message)}</p>
          <time class="topbar__notif-time">${fmtTime(n.created_at)}</time>
        </div>
      </div>`).join('')
      + `<div class="topbar__notif-footer"><a href="${(import.meta.env.BASE_URL ?? '/').replace(/\/$/, '')}/notifications">Zobacz wszystkie powiadomienia →</a></div>`;
    updateBadge(unread.length);
    // Kliknięcie → mark as read
    list.querySelectorAll<HTMLElement>('.topbar__notif-item--unread').forEach(el => {
      el.addEventListener('click', () => markRead(parseInt(el.dataset.notifId!), el));
    });
  }

  function escHtmlNotif(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  async function markRead(id: number, el: HTMLElement) {
    try {
      const res = await fetch(`${_API}/api/notifications/${id}/read/`, {
        method: 'PATCH', credentials: 'include',
        headers: { 'X-CSRFToken': getCsrf(), 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        el.classList.remove('topbar__notif-item--unread');
        el.style.cursor = 'default';
        // Zmniejsz badge
        const badge = document.getElementById('notif-count');
        if (badge) {
          const cur = parseInt(badge.textContent ?? '0', 10);
          updateBadge(Math.max(0, cur - 1));
        }
      }
    } catch { /* cicha degradacja */ }
  }

  async function readAllNotif() {
    try {
      await fetch(`${_API}/api/notifications/read-all/`, {
        method: 'POST', credentials: 'include',
        headers: { 'X-CSRFToken': getCsrf(), 'Content-Type': 'application/json' },
      });
      updateBadge(0);
      notifLoaded = false;
      loadNotifications();
    } catch { /* cicha degradacja */ }
  }
  (window as any).readAllNotif = readAllNotif;

  function updateBadge(count: number) {
    const badge = document.getElementById('notif-count');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : String(count);
      badge.style.display = '';
    } else {
      badge.style.display = 'none';
    }
  }

  async function fetchUnreadCount() {
    try {
      const res = await fetch(`${_API}/api/notifications/`, {
        credentials: 'include', redirect: 'manual',
      });
      if (res.type === 'opaqueredirect' || !res.ok) return;
      const data: Array<{is_read: boolean}> = await res.json();
      const count = data.filter(n => !n.is_read).length;
      updateBadge(count);
    } catch { /* niezalogowany lub błąd — ukryj badge */ }
  }

  // Odśwież badge przy każdym załadowaniu strony
  fetchUnreadCount();

  // Zamknij panel po kliknięciu poza nim
  document.addEventListener('click', (e) => {
    const wrap = document.querySelector('.topbar__notif-wrap');
    if (wrap && !wrap.contains(e.target as Node) && notifPanelOpen) {
      toggleNotifPanel();
    }
  });

  // ── Auth state w topbarze ──────────────────────────────────────────────────
  // Sprawdza /api/auth/me/ i wypełnia user chip lub pokazuje link "Zaloguj się"
  (async function initUserChip() {
    const API = _API;
    const chip      = document.getElementById('user-chip') as HTMLElement | null;
    const loginLink = document.getElementById('login-link') as HTMLElement | null;
    const avatar    = document.getElementById('user-avatar') as HTMLElement | null;
    const nameEl    = document.getElementById('user-name') as HTMLElement | null;
    const surnameEl = document.getElementById('user-surname') as HTMLElement | null;
    const userMenu  = document.getElementById('user-menu') as HTMLElement | null;
    const logoutBtn = document.getElementById('logout-btn') as HTMLElement | null;

    try {
      const res = await fetch(`${API}/api/auth/me/`, {
        credentials: 'include',
        redirect: 'manual',
      });

      if (res.ok) {
        const data = await res.json();
        if (data.authenticated && data.user) {
          const u = data.user;
          const initials = ((u.first_name?.[0] ?? '') + (u.last_name?.[0] ?? '')).toUpperCase()
                          || u.username.slice(0, 2).toUpperCase();

          if (avatar) avatar.textContent = initials;
          if (nameEl) nameEl.textContent = u.first_name || u.username;
          if (surnameEl) surnameEl.textContent = u.last_name || '';

          if (chip) chip.style.display = 'flex';
          if (loginLink) loginLink.style.display = 'none';

          // Dropdown user menu
          if (chip && userMenu) {
            chip.addEventListener('click', (e) => {
              e.stopPropagation();
              userMenu.style.display = userMenu.style.display === 'none' ? 'block' : 'none';
            });
            document.addEventListener('click', () => {
              userMenu.style.display = 'none';
            });
          }

          // Logout
          if (logoutBtn) {
            logoutBtn.addEventListener('click', async () => {
              await fetch(`${API}/api/auth/logout/`, {
                method: 'POST',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: '{}',
              });
              window.location.href = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '') + '/login';
            });
          }
          return;
        }
      }
    } catch {
      // brak połączenia — pokazuj link logowania
    }

    // Niezalogowany
    if (chip) chip.style.display = 'none';
    if (loginLink) loginLink.style.display = 'flex';
  })();
</script>
