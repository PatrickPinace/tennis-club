---
// Topbar.astro — przepisany wg projektu grafika
// Search bar + CTA "+ Nowa Rezerwacja" + user chip z inicjałami
interface Props {
  greeting?: string;   // "Witaj z powrotem, Marcin!" — opcjonalny heading w treści
  showSearch?: boolean;
  showCta?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  greeting,
  showSearch = true,
  showCta = true,
  ctaLabel = '+ Nowa Rezerwacja',
  ctaHref = '/courts/reservations',
} = Astro.props;
---

<header class="topbar">
  <!-- Left: greeting text lub tytuł -->
  <div class="topbar__left">
    <button
      class="topbar__hamburger"
      id="sidebar-toggle"
      onclick="toggleSidebar()"
      aria-label="Menu"
      style="display:none;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    {greeting && (
      <h1 class="topbar__greeting">{greeting}</h1>
    )}
  </div>

  <!-- Right: search + bell + CTA + user -->
  <div class="topbar__right">

    {showSearch && (
      <div class="topbar__search">
        <svg class="topbar__search-icon" width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
        </svg>
        <input
          type="search"
          class="topbar__search-input"
          placeholder="Szukaj rezerwacji, graczy..."
          aria-label="Szukaj"
        />
      </div>
    )}

    <!-- Notifications bell -->
    <div class="topbar__notif-wrap">
      <button
        class="topbar__icon-btn"
        id="notif-btn"
        onclick="toggleNotifPanel(); event.stopPropagation();"
        aria-label="Powiadomienia"
        title="Powiadomienia"
      >
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
        </svg>
        <span class="topbar__notif-dot" id="notif-count" style="display:none;">1</span>
      </button>

      <!-- Notifications panel -->
      <div class="topbar__notif-panel" id="notif-panel" style="display:none;" role="dialog" aria-label="Powiadomienia">
        <div class="topbar__notif-header">
          <span>Powiadomienia</span>
          <button onclick="readAllNotif()" class="topbar__notif-mark">Oznacz wszystkie</button>
        </div>
        <div id="notif-list" class="topbar__notif-list">
          <div class="topbar__notif-empty">Brak nowych powiadomień</div>
        </div>
      </div>
    </div>

    {showCta && (
      <a href={ctaHref} class="topbar__cta">
        {ctaLabel}
      </a>
    )}

    <!-- User chip -->
    <div class="topbar__user" role="button" tabindex="0" aria-label="Menu użytkownika">
      <div class="topbar__user-avatar" aria-hidden="true">MK</div>
      <div class="topbar__user-info">
        <span class="topbar__user-name">Marcin</span>
        <span class="topbar__user-surname">Kowalski</span>
      </div>
      <svg class="topbar__user-caret" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </div>

    <!-- Theme toggle — dyskretny -->
    <button
      class="topbar__icon-btn topbar__theme-btn"
      onclick="toggleTheme()"
      aria-label="Zmień motyw"
      title="Zmień motyw"
    >
      <svg id="theme-icon-dark" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="display:none;" aria-hidden="true">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
      </svg>
      <svg id="theme-icon-light" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .topbar {
    height: var(--topbar-height);
    padding: 0 28px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    background: var(--topbar-bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky; top: 0; z-index: 50;
  }

  .topbar__left {
    display: flex; align-items: center; gap: 14px;
    min-width: 0; flex-shrink: 1;
  }

  .topbar__greeting {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.025em;
    white-space: nowrap;
    line-height: 1;
  }

  .topbar__hamburger {
    display: none;
    align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 8px;
    color: var(--text-muted);
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
  }
  .topbar__hamburger:hover { background: var(--surface-hover); color: var(--text); }

  /* ── Right group ──────────────────────────────────────────────────────── */
  .topbar__right {
    display: flex; align-items: center; gap: 8px;
    flex-shrink: 0;
  }

  /* ── Search ───────────────────────────────────────────────────────────── */
  .topbar__search {
    position: relative;
    display: flex; align-items: center;
  }

  .topbar__search-icon {
    position: absolute; left: 10px;
    color: var(--text-dim);
    pointer-events: none;
    flex-shrink: 0;
  }

  .topbar__search-input {
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 8px;
    padding: 7px 14px 7px 32px;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    width: 220px;
    transition: border-color 0.15s, box-shadow 0.15s, width 0.2s;
    outline: none;
  }
  .topbar__search-input::placeholder { color: var(--text-dim); }
  .topbar__search-input:hover { border-color: var(--border-light); }
  .topbar__search-input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-subtle);
    width: 260px;
  }

  /* ── Icon buttons (bell, theme) ───────────────────────────────────────── */
  .topbar__icon-btn {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: grid; place-items: center;
    color: var(--text-muted);
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
    position: relative;
    cursor: pointer;
  }
  .topbar__icon-btn:hover { background: var(--surface-hover); color: var(--text); }

  /* ── Notification bell ────────────────────────────────────────────────── */
  .topbar__notif-wrap { position: relative; }

  .topbar__notif-dot {
    position: absolute; top: 3px; right: 3px;
    min-width: 16px; height: 16px;
    background: #ef4444; color: #fff;
    border-radius: 99px; font-size: 0.6rem; font-weight: 700;
    display: grid; place-items: center;
    border: 2px solid var(--bg);
    padding: 0 3px;
  }

  .topbar__notif-panel {
    position: absolute; right: 0; top: calc(100% + 8px);
    width: 320px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    z-index: 200;
    overflow: hidden;
  }

  .topbar__notif-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    font-weight: 700; font-size: 0.875rem; color: var(--text);
  }

  .topbar__notif-mark {
    font-size: 0.75rem; color: var(--primary);
    background: none; border: none; cursor: pointer;
    font-family: var(--font-sans);
  }
  .topbar__notif-mark:hover { text-decoration: underline; }

  .topbar__notif-list { max-height: 360px; overflow-y: auto; }

  .topbar__notif-empty {
    padding: 28px; text-align: center;
    color: var(--text-muted); font-size: 0.85rem;
  }

  /* ── CTA button ───────────────────────────────────────────────────────── */
  .topbar__cta {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 0 16px; height: 36px;
    background: #22c55e; color: #000;
    border-radius: 8px;
    font-size: 0.875rem; font-weight: 700;
    text-decoration: none; white-space: nowrap;
    transition: background 0.15s, transform 0.1s;
    box-shadow: 0 2px 8px rgba(34,197,94,0.3);
  }
  .topbar__cta:hover { background: #16a34a; transform: translateY(-1px); }
  .topbar__cta:active { transform: translateY(0); }

  /* ── User chip ────────────────────────────────────────────────────────── */
  .topbar__user {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 8px 5px 5px;
    border-radius: 8px; cursor: pointer;
    transition: background 0.12s;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }
  .topbar__user:hover { background: var(--surface-hover); border-color: var(--border-light); }

  .topbar__user-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(34,197,94,0.15);
    border: 1.5px solid #22c55e;
    color: #22c55e; font-weight: 800; font-size: 0.68rem;
    display: grid; place-items: center; flex-shrink: 0;
  }

  .topbar__user-info {
    display: flex; flex-direction: column;
    line-height: 1.15;
  }
  .topbar__user-name   { font-size: 0.78rem; font-weight: 700; color: var(--text); }
  .topbar__user-surname { font-size: 0.72rem; color: var(--text-muted); }

  .topbar__user-caret { color: var(--text-dim); flex-shrink: 0; }

  .topbar__theme-btn { margin-left: 2px; }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .topbar__hamburger { display: flex !important; }
    .topbar__search-input { width: 160px; }
    .topbar__search-input:focus { width: 200px; }
  }

  @media (max-width: 640px) {
    .topbar { padding: 0 16px; }
    .topbar__greeting { font-size: 1.1rem; }
    .topbar__search { display: none; }
    .topbar__user-info { display: none; }
    .topbar__cta { padding: 0 10px; font-size: 0.8rem; }
  }
</style>
