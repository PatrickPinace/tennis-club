---
// dashboard.astro — placeholder page
// Docelowo: pobiera dane z GET /api/dashboard/summary/ + /api/me/
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Dashboard" pageTitle="Dashboard">

  <!-- Page header -->
  <div class="page-header" style="align-items:flex-start; text-align:left;">
    <div class="page-header__eyebrow">Panel główny</div>
    <h1 class="page-header__title">Witaj z powrotem 👋</h1>
    <p class="page-header__subtitle">Przegląd aktywności klubu i Twoich statystyk.</p>
  </div>

  <!-- Stats grid — placeholder karty -->
  <div class="stats-grid" style="margin-bottom: 24px;">
    <div class="stat-placeholder">
      <div class="stat-label">Najbliższa rezerwacja</div>
      <div class="stat-value">—</div>
      <div class="stat-detail">Połącz Astro z API Django</div>
    </div>
    <div class="stat-placeholder">
      <div class="stat-label">Ostatni mecz</div>
      <div class="stat-value">—</div>
      <div class="stat-detail">GET /api/matches/history/</div>
    </div>
    <div class="stat-placeholder">
      <div class="stat-label">Ranking klubowy</div>
      <div class="stat-value">—</div>
      <div class="stat-detail">GET /api/rankings/ (do dodania)</div>
    </div>
    <div class="stat-placeholder">
      <div class="stat-label">Nadchodzący turniej</div>
      <div class="stat-value">—</div>
      <div class="stat-detail">GET /api/tournaments/</div>
    </div>
  </div>

  <!-- MVP notice -->
  <div class="mvp-notice">
    <div class="mvp-notice__icon">🚧</div>
    <div>
      <strong>MVP Scaffold — Astro + Tailwind</strong>
      <p>To jest szkielet frontendu. Design system, layout i routing działają.
        Widoki biznesowe będą implementowane w kolejnych etapach.</p>
    </div>
  </div>

</AppLayout>

<style>
  .page-header {
    margin-bottom: 28px;
  }
  .page-header__eyebrow {
    font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--primary); margin-bottom: 4px;
  }
  .page-header__title {
    font-size: 1.6rem; font-weight: 800; color: var(--text);
    line-height: 1.15; letter-spacing: -0.02em;
  }
  .page-header__subtitle {
    margin-top: 4px; font-size: 0.9rem; color: var(--text-muted);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .stat-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 20px;
    display: flex; flex-direction: column; gap: 6px;
  }

  .stat-label {
    font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .stat-value {
    font-size: 1.6rem; font-weight: 800; color: var(--text-dim);
    letter-spacing: -0.03em;
  }

  .stat-detail {
    font-size: 0.75rem; color: var(--text-dim);
    font-family: var(--font-mono);
  }

  .mvp-notice {
    display: flex; gap: 16px; align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--primary);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    font-size: 0.875rem;
  }

  .mvp-notice__icon { font-size: 1.4rem; flex-shrink: 0; }

  .mvp-notice strong { display: block; color: var(--text); margin-bottom: 4px; }
  .mvp-notice p { color: var(--text-muted); line-height: 1.6; }

  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
