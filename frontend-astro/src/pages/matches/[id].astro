---
// matches/[id].astro — detal meczu towarzyskiego
// GET /api/matches/<id>/  (IsAuthenticated — wymaga cookie sesji)
export const prerender = false;

import AppLayout from '@/layouts/AppLayout.astro';
import { getMatch, getCurrentUser, type MatchHistoryEntry } from '@/lib/api';
import { url } from '@/lib/url';

const { id } = Astro.params;
const matchId = id ? parseInt(id, 10) : NaN;

if (isNaN(matchId)) {
  return Astro.redirect(url('/matches'));
}

const sessionCookie = Astro.request.headers.get('cookie') ?? undefined;
const [match, currentUser] = await Promise.all([
  getMatch(matchId, sessionCookie),
  getCurrentUser(sessionCookie),
]);

// Nie znaleziono meczu lub brak dostępu
if (!match) {
  return Astro.redirect(url('/matches'));
}

// ── Helpery ────────────────────────────────────────────────────────────────

function userName(u: MatchHistoryEntry['p1']): string {
  if (!u) return '—';
  const full = `${u.first_name} ${u.last_name}`.trim();
  return full || u.username;
}

function userInitials(u: MatchHistoryEntry['p1']): string {
  if (!u) return '?';
  const parts = [u.first_name, u.last_name].filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
  return (u.username?.[0] ?? '?').toUpperCase();
}

function fmtDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString('pl-PL', {
      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
    });
  } catch { return iso; }
}

// Sety: lista par [p1_gems, p2_gems] dla rozegranych setów
const sets: Array<[number, number]> = [];
if (match.p1_set1 != null && match.p2_set1 != null) sets.push([match.p1_set1, match.p2_set1]);
if (match.p1_set2 != null && match.p2_set2 != null) sets.push([match.p1_set2, match.p2_set2]);
if (match.p1_set3 != null && match.p2_set3 != null) sets.push([match.p1_set3, match.p2_set3]);

const scoreStr = sets.map(([a, b]) => `${a}:${b}`).join(', ') || '—';

// Kto wygrał
const p1Won = match.win === 'p1';
const p2Won = match.win === 'p2';

// Czy zalogowany user jest uczestnikiem — do podświetlenia "Twój" wynik
const myId = currentUser?.id ?? null;
const iAmP1 = myId === match.p1?.id || myId === match.p3?.id;
const iAmP2 = myId === match.p2?.id || myId === match.p4?.id;

const myResult = iAmP1 ? (p1Won ? 'win' : 'loss') : iAmP2 ? (p2Won ? 'win' : 'loss') : null;
const resultLabel = myResult === 'win' ? 'Wygrana' : myResult === 'loss' ? 'Porażka' : null;
const resultClass = myResult === 'win' ? 'result--win' : myResult === 'loss' ? 'result--loss' : '';

const typeLabel = match.description
  ? match.description.charAt(0) + match.description.slice(1).toLowerCase()
  : 'Mecz';
const formatLabel = match.match_double ? 'Debel' : 'Singiel';

// Drużyny (dla debla: p1+p3 vs p2+p4)
const team1 = [match.p1, match.p3].filter(Boolean) as NonNullable<MatchHistoryEntry['p1']>[];
const team2 = [match.p2, match.p4].filter(Boolean) as NonNullable<MatchHistoryEntry['p1']>[];

const canEdit = match.can_edit ?? false;

// ── Confirm flow ───────────────────────────────────────────────────────────
const isPending    = match.score_status === 'PENDING';
const iAmReporter  = myId !== null && myId === match.reported_by?.id;
const iAmParticipant = iAmP1 || iAmP2;
// Może potwierdzić: uczestnik meczu, nie ten kto zgłosił, mecz PENDING
const canConfirm   = isPending && iAmParticipant && !iAmReporter;
// Czekamy na potwierdzenie (my zgłosiliśmy)
const awaitingConfirm = isPending && iAmReporter;
---

<AppLayout
  title={`Mecz #${matchId}`}
  showSearch={false}
  showCta={false}
  currentUser={currentUser}
>

  <!-- Breadcrumb + akcje -->
  <div class="match-topbar">
    <nav class="breadcrumb" aria-label="Nawigacja okruszkowa">
      <a href={url('/matches')} class="breadcrumb__link">Mecze</a>
      <span class="breadcrumb__sep" aria-hidden="true">›</span>
      <span class="breadcrumb__current">Mecz #{matchId}</span>
    </nav>
    {canEdit && (
      <button id="edit-toggle-btn" class="tc-btn tc-btn-secondary tc-btn-sm" type="button">
        ✏ Edytuj wynik
      </button>
    )}
  </div>

  <!-- Header karty meczu -->
  <div class={`match-header tc-card ${resultClass}`}>
    <div class="match-header__top">
      <div class="match-header__badges">
        <span class="tc-badge tc-badge-neutral">{typeLabel}</span>
        <span class="tc-badge tc-badge-neutral">{formatLabel}</span>
      </div>
      {resultLabel && (
        <span class={`match-result-badge match-result-badge--${myResult}`}>
          {resultLabel}
        </span>
      )}
    </div>

    <!-- Sędziowanie: gracze vs wynik -->
    <div class="match-scoreboard">
      <!-- Drużyna 1 -->
      <div class={`match-team ${p1Won ? 'match-team--winner' : ''}`}>
        {team1.map(u => (
          <div class="match-team__player">
            <div class={`tc-avatar tc-avatar-md${u.id === myId ? ' tc-avatar--me' : ''}`} aria-hidden="true">
              {userInitials(u)}
            </div>
            <div class="match-team__name">
              {userName(u)}
              {u.id === myId && <span class="me-badge">Ty</span>}
            </div>
          </div>
        ))}
        {p1Won && <div class="match-team__crown" aria-label="Zwycięzca">🏆</div>}
      </div>

      <!-- Wynik setów -->
      <div class="match-score">
        <div class="match-score__sets">
          {sets.length > 0 ? sets.map(([a, b]) => (
            <div class="match-score__set">
              <span class={a > b ? 'set-gem--win' : 'set-gem--loss'}>{a}</span>
              <span class="set-sep">:</span>
              <span class={b > a ? 'set-gem--win' : 'set-gem--loss'}>{b}</span>
            </div>
          )) : (
            <span class="match-score__empty">—</span>
          )}
        </div>
        <div class="match-score__label">{scoreStr}</div>
      </div>

      <!-- Drużyna 2 -->
      <div class={`match-team match-team--right ${p2Won ? 'match-team--winner' : ''}`}>
        {team2.map(u => (
          <div class="match-team__player">
            <div class={`tc-avatar tc-avatar-md${u.id === myId ? ' tc-avatar--me' : ''}`} aria-hidden="true">
              {userInitials(u)}
            </div>
            <div class="match-team__name">
              {u.id === myId && <span class="me-badge">Ty</span>}
              {userName(u)}
            </div>
          </div>
        ))}
        {p2Won && <div class="match-team__crown" aria-label="Zwycięzca">🏆</div>}
      </div>
    </div>

    <div class="match-header__date">{fmtDate(match.match_date)}</div>
  </div>

  <!-- Confirm flow — status bar -->
  {(isPending) && (
    <div id="confirm-bar" class={`confirm-bar ${canConfirm ? 'confirm-bar--action' : 'confirm-bar--waiting'}`} style="margin-top:20px;">
      <div class="confirm-bar__content">
        {canConfirm && (
          <>
            <div class="confirm-bar__text">
              <span class="confirm-bar__icon">⚠</span>
              <span>
                Wynik zgłoszony przez{' '}
                <strong>{match.reported_by ? `${match.reported_by.first_name} ${match.reported_by.last_name}`.trim() || match.reported_by.username : '—'}</strong>.
                Potwierdź, jeśli się zgadzasz.
              </span>
            </div>
            <button id="confirm-btn" class="tc-btn tc-btn-primary tc-btn-sm" type="button">
              Potwierdź wynik
            </button>
          </>
        )}
        {awaitingConfirm && (
          <div class="confirm-bar__text">
            <span class="confirm-bar__icon">⏳</span>
            <span>Zgłoszono — czeka na potwierdzenie przez drugiego uczestnika.</span>
          </div>
        )}
      </div>
      <div id="confirm-msg" class="confirm-bar__msg" style="display:none;"></div>
    </div>
  )}

  <!-- Szczegółowa tabela setów -->
  {sets.length > 0 && (
    <div class="tc-card" style="margin-top:20px;">
      <div class="tc-card-header">
        <span class="tc-card-title">Wynik setów</span>
      </div>
      <div class="sets-table-wrap">
      <table class="tc-table sets-table">
        <thead>
          <tr>
            <th>Gracz</th>
            {sets.map((_, i) => <th class="col-num">Set {i + 1}</th>)}
            <th class="col-num">Sety</th>
            <th class="col-num">Gemy</th>
          </tr>
        </thead>
        <tbody>
          <tr class={p1Won ? 'row--winner' : ''}>
            <td>
              <div class="sets-player">
                <div class="tc-avatar tc-avatar-sm" aria-hidden="true">{userInitials(match.p1)}</div>
                <span>{userName(match.p1)}{match.match_double && match.p3 ? ` / ${userName(match.p3)}` : ''}</span>
                {p1Won && <span class="tc-badge tc-badge-success" style="margin-left:6px;">Wygrana</span>}
              </div>
            </td>
            {sets.map(([a]) => <td class="col-num">{a}</td>)}
            <td class="col-num font-bold">{match.p1_win_set}</td>
            <td class="col-num">{match.p1_win_gem}</td>
          </tr>
          <tr class={p2Won ? 'row--winner' : ''}>
            <td>
              <div class="sets-player">
                <div class="tc-avatar tc-avatar-sm" aria-hidden="true">{userInitials(match.p2)}</div>
                <span>{userName(match.p2)}{match.match_double && match.p4 ? ` / ${userName(match.p4)}` : ''}</span>
                {p2Won && <span class="tc-badge tc-badge-success" style="margin-left:6px;">Wygrana</span>}
              </div>
            </td>
            {sets.map(([, b]) => <td class="col-num">{b}</td>)}
            <td class="col-num font-bold">{match.p2_win_set}</td>
            <td class="col-num">{match.p2_win_gem}</td>
          </tr>
        </tbody>
      </table>
      </div><!-- /sets-table-wrap -->
    </div>
  )}

  <!-- Formularz edycji wyniku (widoczny tylko gdy can_edit, toggle) -->
  {canEdit && (
    <div id="edit-form-card" class="tc-card" style="margin-top:20px; display:none;">
      <div class="tc-card-header">
        <span class="tc-card-title">Edytuj wynik</span>
      </div>
      <form id="edit-score-form" style="padding:16px 20px 20px;" novalidate>
        <div class="edit-sets-row">
          {[1, 2, 3].map(s => (
            <div class="edit-set-group">
              <div class="edit-set-label">Set {s}{s === 1 ? ' *' : ''}</div>
              <div class="edit-set-inputs">
                <input class="edit-set-input" type="number" min="0" max="99"
                  name={`p1_set${s}`}
                  value={s === 1 ? String(match.p1_set1 ?? '') : s === 2 ? String(match.p1_set2 ?? '') : String(match.p1_set3 ?? '')}
                  placeholder="—">
                <span class="edit-set-sep">:</span>
                <input class="edit-set-input" type="number" min="0" max="99"
                  name={`p2_set${s}`}
                  value={s === 1 ? String(match.p2_set1 ?? '') : s === 2 ? String(match.p2_set2 ?? '') : String(match.p2_set3 ?? '')}
                  placeholder="—">
              </div>
            </div>
          ))}
        </div>
        <div style="margin-top:14px; display:flex; align-items:center; gap:10px;">
          <button type="submit" class="tc-btn tc-btn-primary tc-btn-sm">Zapisz</button>
          <button type="button" id="edit-cancel-btn" class="tc-btn tc-btn-ghost tc-btn-sm">Anuluj</button>
          <span id="edit-form-msg" style="font-size:0.82rem;"></span>
        </div>
      </form>
    </div>
  )}

  <!-- Powrót -->
  <div style="margin-top:28px;">
    <a href={url('/matches')} class="tc-btn tc-btn-ghost tc-btn-sm">← Wróć do listy meczów</a>
  </div>

</AppLayout>

<style>
  .match-topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; gap: 12px;
  }
  .match-topbar .breadcrumb { margin-bottom: 0; }

  .breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.8rem; color: var(--text-muted);
    margin-bottom: 20px;
  }
  .breadcrumb__link { color: var(--primary); text-decoration: none; }
  .breadcrumb__link:hover { text-decoration: underline; }
  .breadcrumb__sep { color: var(--text-dim); }
  .breadcrumb__current { color: var(--text); font-weight: 500; }

  /* ── Match header card ───────────────────────────────────────────────── */
  .match-header { padding: 24px 28px; }

  .result--win  { border-left: 3px solid #22c55e; }
  .result--loss { border-left: 3px solid var(--danger); }

  .match-header__top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; flex-wrap: wrap; gap: 10px;
  }
  .match-header__badges { display: flex; gap: 6px; }

  .match-result-badge {
    font-size: 0.78rem; font-weight: 700;
    padding: 4px 12px; border-radius: 99px;
  }
  .match-result-badge--win  { background: rgba(34,197,94,0.12); color: #22c55e; }
  .match-result-badge--loss { background: rgba(239,68,68,0.1);  color: var(--danger); }

  /* ── Scoreboard ──────────────────────────────────────────────────────── */
  .match-scoreboard {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 8px 0 20px;
  }

  .match-team {
    display: flex; flex-direction: column; gap: 10px;
  }
  .match-team--right {
    align-items: flex-end;
    text-align: right;
  }
  .match-team--winner .match-team__name {
    font-weight: 700; color: var(--text);
  }

  .match-team__player {
    display: flex; align-items: center; gap: 10px;
  }
  .match-team--right .match-team__player {
    flex-direction: row-reverse;
  }

  .match-team__name {
    font-size: 0.95rem; color: var(--text-muted);
    display: flex; align-items: center; gap: 6px;
  }

  .match-team__crown {
    font-size: 1.1rem; margin-top: 2px;
  }

  .me-badge {
    font-size: 0.65rem; font-weight: 700;
    background: rgba(34,197,94,0.15); color: #22c55e;
    padding: 1px 6px; border-radius: 99px;
  }

  .tc-avatar--me {
    border: 1.5px solid #22c55e;
    background: rgba(34,197,94,0.15);
    color: #22c55e;
  }

  /* ── Score display ───────────────────────────────────────────────────── */
  .match-score {
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
  }

  .match-score__sets {
    display: flex; gap: 8px; align-items: center;
  }

  .match-score__set {
    display: flex; align-items: baseline; gap: 2px;
    font-size: 1.6rem; font-weight: 800; letter-spacing: -0.02em;
  }

  .set-gem--win  { color: var(--text); }
  .set-gem--loss { color: var(--text-dim); }
  .set-sep       { color: var(--text-dim); font-size: 1.2rem; }

  .match-score__empty { font-size: 1.6rem; color: var(--text-dim); }

  .match-score__label {
    font-size: 0.75rem; color: var(--text-muted); font-weight: 500;
  }

  .match-header__date {
    font-size: 0.82rem; color: var(--text-muted);
    text-align: center; margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
  }

  /* ── Sets table ──────────────────────────────────────────────────────── */
  .sets-table-wrap { overflow-x: auto; }
  .sets-table { min-width: 400px; }
  .col-num { text-align: right; }
  .font-bold { font-weight: 700; color: var(--text); }

  .row--winner td { background: rgba(34,197,94,0.03); }

  .sets-player {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.875rem;
  }

  /* Avatar sizes */
  .tc-avatar-md {
    width: 40px; height: 40px;
    font-size: 0.85rem;
  }

  /* ── Edit form ───────────────────────────────────────────────────────── */
  .edit-sets-row {
    display: flex; gap: 20px; flex-wrap: wrap;
  }
  .edit-set-group {
    display: flex; flex-direction: column; gap: 6px;
  }
  .edit-set-label {
    font-size: 0.75rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em;
  }
  .edit-set-inputs {
    display: flex; align-items: center; gap: 6px;
  }
  .edit-set-input {
    width: 56px; padding: 6px 8px; border: 1px solid var(--border);
    border-radius: 6px; background: var(--surface-2); color: var(--text);
    font-size: 0.95rem; text-align: center;
  }
  .edit-set-input:focus { outline: none; border-color: var(--primary); }
  .edit-set-sep { color: var(--text-dim); font-weight: 700; }

  /* ── Confirm bar ─────────────────────────────────────────────────────── */
  .confirm-bar {
    border-radius: 10px; padding: 14px 18px;
    border: 1px solid transparent;
  }
  .confirm-bar--action {
    background: rgba(234,179,8,0.08); border-color: rgba(234,179,8,0.3);
  }
  .confirm-bar--waiting {
    background: rgba(99,102,241,0.06); border-color: rgba(99,102,241,0.2);
  }
  .confirm-bar__content {
    display: flex; align-items: center; justify-content: space-between;
    gap: 14px; flex-wrap: wrap;
  }
  .confirm-bar__text {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.875rem; color: var(--text-muted);
  }
  .confirm-bar__icon { font-size: 1rem; flex-shrink: 0; }
  .confirm-bar__msg {
    margin-top: 8px; font-size: 0.82rem; font-weight: 600;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    /* Topbar: breadcrumb i przycisk "Edytuj" jeden pod drugim */
    .match-topbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 14px;
    }

    /* Karta meczu — mniejszy padding */
    .match-header { padding: 16px; }

    /* Scoreboard: zamiast 1fr auto 1fr → pionowo: gracz1 / wynik / gracz2 */
    .match-scoreboard {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 4px 0 14px;
    }

    /* Prawa drużyna: na mobilu wyrównana do lewej jak lewa */
    .match-team--right {
      align-items: flex-start;
      text-align: left;
    }
    .match-team--right .match-team__player {
      flex-direction: row;
    }

    /* Wynik setów — wyśrodkowany separator między drużynami */
    .match-score {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 10px 0;
    }
    .match-score__set { font-size: 1.3rem; }
    .match-score__empty { font-size: 1.3rem; }

    /* Avatar nieco mniejszy */
    .tc-avatar-md { width: 34px; height: 34px; font-size: 0.78rem; }

    /* Tabela setów — scroll poziomy */
    .sets-table { min-width: 360px; }

    /* Formularz edycji — sety obok siebie ale mniejszy gap */
    .edit-sets-row { gap: 12px; }

    /* Confirm bar — stack pionowo */
    .confirm-bar { padding: 12px 14px; }
    .confirm-bar__content { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>

<script define:vars={{ matchId, canEdit, canConfirm }}>
// ── Confirm flow ──────────────────────────────────────────────────────────
if (canConfirm) {
  const confirmBtn = document.getElementById('confirm-btn');
  const confirmMsg = document.getElementById('confirm-msg');

  function getCsrf() {
    const m = document.cookie.match(/csrftoken=([^;]+)/);
    return m ? m[1] : '';
  }

  confirmBtn?.addEventListener('click', async () => {
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Potwierdzanie…';
    confirmMsg.style.display = 'none';
    confirmMsg.textContent = '';

    try {
      const res = await fetch(`/api/matches/${matchId}/confirm/`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'X-CSRFToken': getCsrf(), 'Content-Type': 'application/json' },
      });

      if (res.ok) {
        confirmMsg.textContent = 'Wynik potwierdzony!';
        confirmMsg.style.color = '#22c55e';
        confirmMsg.style.display = '';
        setTimeout(() => window.location.reload(), 800);
      } else {
        const err = await res.json().catch(() => ({}));
        confirmMsg.textContent = err.detail || `Błąd ${res.status}`;
        confirmMsg.style.color = 'var(--danger)';
        confirmMsg.style.display = '';
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Potwierdź wynik';
      }
    } catch {
      confirmMsg.textContent = 'Błąd sieci.';
      confirmMsg.style.color = 'var(--danger)';
      confirmMsg.style.display = '';
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Potwierdź wynik';
    }
  });
}

// ── Edit form ──────────────────────────────────────────────────────────────
if (canEdit) {
  const toggleBtn  = document.getElementById('edit-toggle-btn');
  const cancelBtn  = document.getElementById('edit-cancel-btn');
  const formCard   = document.getElementById('edit-form-card');
  const form       = document.getElementById('edit-score-form');
  const msgEl      = document.getElementById('edit-form-msg');

  toggleBtn?.addEventListener('click', () => {
    formCard.style.display = formCard.style.display === 'none' ? '' : 'none';
  });
  cancelBtn?.addEventListener('click', () => {
    formCard.style.display = 'none';
  });

  function getCsrfToken() {
    const m = document.cookie.match(/csrftoken=([^;]+)/);
    return m ? m[1] : '';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (btn) btn.disabled = true;
    msgEl.textContent = '';
    msgEl.style.color = '';

    const getVal = (name) => {
      const v = form.elements[name]?.value;
      return v !== '' && v != null ? parseInt(v, 10) : null;
    };

    const body = {};
    for (const f of ['p1_set1','p2_set1','p1_set2','p2_set2','p1_set3','p2_set3']) {
      const el = form.elements[f];
      if (el) body[f] = getVal(f);
    }

    try {
      const res = await fetch(`/api/matches/${matchId}/`, {
        method: 'PATCH',
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRFToken': getCsrfToken(),
        },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        msgEl.textContent = 'Zapisano!';
        msgEl.style.color = '#22c55e';
        // Odśwież stronę po chwili, żeby score-display się zaktualizował
        setTimeout(() => window.location.reload(), 800);
      } else {
        const err = await res.json().catch(() => ({}));
        msgEl.textContent = err.detail || Object.values(err)[0] || `Błąd ${res.status}`;
        msgEl.style.color = 'var(--danger)';
        if (btn) btn.disabled = false;
      }
    } catch {
      msgEl.textContent = 'Błąd sieci.';
      msgEl.style.color = 'var(--danger)';
      if (btn) btn.disabled = false;
    }
  });
}
</script>
