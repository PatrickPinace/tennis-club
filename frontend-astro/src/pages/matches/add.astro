---
// matches/add.astro — formularz dodawania rozegranego meczu towarzyskiego (singiel i debel)
// Prywatna strona: wymaga zalogowania.
export const prerender = false;

import AppLayout from '@/layouts/AppLayout.astro';
import { getCurrentUser } from '@/lib/api';
import { url } from '@/lib/url';

const sessionCookie = Astro.request.headers.get('cookie') ?? undefined;
const currentUser = await getCurrentUser(sessionCookie);

if (!currentUser) {
  return Astro.redirect(url('/login') + '?next=' + encodeURIComponent(url('/matches/add')));
}

const today = new Date().toISOString().slice(0, 10);
const myId  = currentUser.id;
---

<AppLayout title="Dodaj mecz" showSearch={false} showCta={false} currentUser={currentUser}>
  <nav class="tc-breadcrumb" aria-label="Nawigacja">
    <a href={url('/matches')}>← Moje mecze</a>
  </nav>

  <div class="add-wrap">
    <div class="add-header">
      <h1 class="add-title">Dodaj mecz towarzyski</h1>
      <p class="add-subtitle">Zapisz wynik rozegranego meczu.</p>
    </div>

    <div id="add-error" class="add-alert add-alert--err" style="display:none;" role="alert"></div>

    <div class="tc-card add-card">
      <form id="add-form" novalidate data-my-id={String(myId)}>

        <!-- Toggle singiel / debel -->
        <div class="af-field">
          <label class="af-label">Format</label>
          <div class="af-format-toggle" role="group" aria-label="Format meczu">
            <button type="button" id="btn-sng" class="af-format-btn af-format-btn--active" data-format="SNG">
              Singiel
            </button>
            <button type="button" id="btn-dbl" class="af-format-btn" data-format="DBL">
              Debel
            </button>
          </div>
        </div>

        <!-- ── DRUŻYNA 1 (Twoja) ── -->
        <div class="af-team-header" id="team1-header" style="display:none;">
          <span class="af-team-label af-team-label--you">Twoja drużyna</span>
        </div>

        <!-- Twój partner (debel) -->
        <div class="af-field af-field--dbl" id="field-partner" style="display:none;">
          <label class="af-label" for="af-partner-input">
            Twój partner <span class="af-required">*</span>
          </label>
          <div class="af-autocomplete" id="af-ac-partner">
            <input id="af-partner-input" class="af-input" type="text"
              placeholder="Wpisz imię lub nazwisko..."
              autocomplete="off" aria-autocomplete="list"
              aria-controls="af-sug-partner" aria-expanded="false" />
            <input type="hidden" id="af-partner-id" />
            <ul id="af-sug-partner" class="af-suggestions" role="listbox" style="display:none;" aria-label="Sugestie partnerów"></ul>
            <div class="af-search-status" id="af-status-partner" aria-live="polite"></div>
          </div>
          <p id="af-partner-err" class="af-field-err" style="display:none;">Wybierz partnera z listy.</p>
        </div>

        <!-- ── DRUŻYNA 2 (Rywal) ── -->
        <div class="af-team-header" id="team2-header" style="display:none;">
          <span class="af-team-label af-team-label--opp">Drużyna przeciwna</span>
        </div>

        <!-- Główny przeciwnik -->
        <div class="af-field">
          <label class="af-label" for="af-opponent-input">
            <span id="lbl-opponent">Przeciwnik</span> <span class="af-required">*</span>
          </label>
          <div class="af-autocomplete" id="af-ac-opponent">
            <input id="af-opponent-input" class="af-input" type="text"
              placeholder="Wpisz imię lub nazwisko..."
              autocomplete="off" aria-autocomplete="list"
              aria-controls="af-sug-opponent" aria-expanded="false" />
            <input type="hidden" id="af-opponent-id" />
            <ul id="af-sug-opponent" class="af-suggestions" role="listbox" style="display:none;" aria-label="Sugestie przeciwników"></ul>
            <div class="af-search-status" id="af-status-opponent" aria-live="polite"></div>
          </div>
          <p id="af-opponent-err" class="af-field-err" style="display:none;">Wybierz przeciwnika z listy.</p>
        </div>

        <!-- Partner przeciwnika (debel) -->
        <div class="af-field af-field--dbl" id="field-rival2" style="display:none;">
          <label class="af-label" for="af-rival2-input">
            Partner przeciwnika <span class="af-required">*</span>
          </label>
          <div class="af-autocomplete" id="af-ac-rival2">
            <input id="af-rival2-input" class="af-input" type="text"
              placeholder="Wpisz imię lub nazwisko..."
              autocomplete="off" aria-autocomplete="list"
              aria-controls="af-sug-rival2" aria-expanded="false" />
            <input type="hidden" id="af-rival2-id" />
            <ul id="af-sug-rival2" class="af-suggestions" role="listbox" style="display:none;" aria-label="Sugestie partnerów przeciwnika"></ul>
            <div class="af-search-status" id="af-status-rival2" aria-live="polite"></div>
          </div>
          <p id="af-rival2-err" class="af-field-err" style="display:none;">Wybierz partnera przeciwnika z listy.</p>
        </div>

        <!-- ── Sety ── -->
        <div class="af-field">
          <label class="af-label">Wynik</label>
          <div class="af-sets">
            <!-- Set 1 -->
            <div class="af-set">
              <span class="af-set-label">Set 1 <span class="af-required">*</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s1-p1">Ty</span>
                  <input id="af-p1s1" class="af-num" type="number" min="0" max="99" placeholder="0" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s1-p2">Rywal</span>
                  <input id="af-p2s1" class="af-num" type="number" min="0" max="99" placeholder="0" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s1-err" class="af-field-err" style="display:none;">Set 1 jest wymagany — wpisz wynik dla obu stron.</p>
            </div>
            <!-- Set 2 -->
            <div class="af-set af-set--opt">
              <span class="af-set-label">Set 2 <span class="af-optional">(opcjonalnie)</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s2-p1">Ty</span>
                  <input id="af-p1s2" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s2-p2">Rywal</span>
                  <input id="af-p2s2" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s2-err" class="af-field-err" style="display:none;">Wpisz wynik dla obu stron w secie 2.</p>
            </div>
            <!-- Set 3 -->
            <div class="af-set af-set--opt">
              <span class="af-set-label">Set 3 <span class="af-optional">(opcjonalnie)</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s3-p1">Ty</span>
                  <input id="af-p1s3" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who" id="lbl-s3-p2">Rywal</span>
                  <input id="af-p2s3" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s3-err" class="af-field-err" style="display:none;">Wpisz wynik dla obu stron w secie 3.</p>
            </div>
          </div>
        </div>

        <!-- Data meczu -->
        <div class="af-field">
          <label class="af-label" for="af-date">Data meczu</label>
          <input id="af-date" class="af-input af-input--date" type="date"
            value={today} max={today} />
        </div>

        <!-- Submit -->
        <div class="af-actions">
          <a href={url('/matches')} class="tc-btn tc-btn-ghost">Anuluj</a>
          <button id="af-submit" type="submit" class="tc-btn tc-btn-primary">
            Zapisz mecz
          </button>
        </div>

      </form>
    </div>
  </div>
</AppLayout>

<script>
  (function () {
    const API  = (document.querySelector('meta[name="api-base"]') as HTMLMetaElement)?.content ?? '';
    const BASE = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
    const form = document.getElementById('add-form') as HTMLFormElement;
    const ME   = Number((form as HTMLElement)?.dataset?.myId ?? 0);

    // ── Stan formularza ────────────────────────────────────────────────────────
    let isDouble = false;

    // ── Elementy toggle ────────────────────────────────────────────────────────
    const btnSng      = document.getElementById('btn-sng');
    const btnDbl      = document.getElementById('btn-dbl');
    const fieldPartner = document.getElementById('field-partner');
    const fieldRival2  = document.getElementById('field-rival2');
    const team1Header  = document.getElementById('team1-header');
    const team2Header  = document.getElementById('team2-header');
    const lblOpponent  = document.getElementById('lbl-opponent');

    // Etykiety "Ty/Rywal" → "Ty+Partner/Rywal+Partner" w setach
    const setLabelsP1 = [
      document.getElementById('lbl-s1-p1'),
      document.getElementById('lbl-s2-p1'),
      document.getElementById('lbl-s3-p1'),
    ];
    const setLabelsP2 = [
      document.getElementById('lbl-s1-p2'),
      document.getElementById('lbl-s2-p2'),
      document.getElementById('lbl-s3-p2'),
    ];

    function setFormat(dbl) {
      isDouble = dbl;
      btnSng?.classList.toggle('af-format-btn--active', !dbl);
      btnDbl?.classList.toggle('af-format-btn--active', dbl);
      const show = el => el && (el.style.display = '');
      const hide = el => el && (el.style.display = 'none');

      if (dbl) {
        show(fieldPartner); show(fieldRival2);
        show(team1Header); show(team2Header);
        if (lblOpponent) lblOpponent.textContent = 'Główny przeciwnik';
        setLabelsP1.forEach(el => { if (el) el.textContent = 'Ty / P'; });
        setLabelsP2.forEach(el => { if (el) el.textContent = 'Rywal / P'; });
      } else {
        hide(fieldPartner); hide(fieldRival2);
        hide(team1Header); hide(team2Header);
        if (lblOpponent) lblOpponent.textContent = 'Przeciwnik';
        setLabelsP1.forEach(el => { if (el) el.textContent = 'Ty'; });
        setLabelsP2.forEach(el => { if (el) el.textContent = 'Rywal'; });
        // Reset pól debla
        resetAC('partner');
        resetAC('rival2');
      }
    }

    btnSng?.addEventListener('click', () => setFormat(false));
    btnDbl?.addEventListener('click', () => setFormat(true));

    // ── Autocomplete factory ───────────────────────────────────────────────────
    // Każde pole ma: inputEl, hiddenEl, sugListEl, statusEl, errEl
    const acState = {}; // key → { selectedId, selectedName, timer }

    function makeAC(key, inputId, hiddenId, sugId, statusId) {
      const inputEl  = document.getElementById(inputId);
      const hiddenEl = document.getElementById(hiddenId);
      const sugEl    = document.getElementById(sugId);
      const statusEl = document.getElementById(statusId);
      if (!inputEl || !hiddenEl || !sugEl) return;

      acState[key] = { selectedId: null, selectedName: '', timer: null };

      function closeSug() {
        sugEl.style.display = 'none';
        inputEl.setAttribute('aria-expanded', 'false');
      }

      function getSelectedIds() {
        // Zbierz wszystkie aktualnie wybrane ID (żeby wykluczyć z sugestii)
        const ids = new Set();
        ids.add(ME); // zalogowany user zawsze wykluczony
        for (const k of ['opponent', 'partner', 'rival2']) {
          const id = acState[k]?.selectedId;
          if (id) ids.add(id);
        }
        return ids;
      }

      function renderSug(users) {
        const excluded = getSelectedIds();
        const filtered = users.filter(u => !excluded.has(u.id) || acState[key].selectedId === u.id);
        if (filtered.length === 0) {
          sugEl.innerHTML = '<li class="af-sug-empty">Brak wyników</li>';
        } else {
          sugEl.innerHTML = filtered.map(u => {
            const full = [u.first_name, u.last_name].filter(Boolean).join(' ') || u.username;
            const sub  = (u.first_name || u.last_name) ? u.username : '';
            return `<li class="af-sug-item" role="option" data-id="${u.id}" data-name="${full}">
              <span class="af-sug-name">${full}</span>
              ${sub ? `<span class="af-sug-sub">${sub}</span>` : ''}
            </li>`;
          }).join('');
        }
        sugEl.style.display = '';
        inputEl.setAttribute('aria-expanded', 'true');
      }

      async function fetchUsers(q) {
        if (statusEl) statusEl.textContent = 'Szukam…';
        try {
          const endpoint = q.length >= 2
            ? `${API}/api/users/?search=${encodeURIComponent(q)}`
            : `${API}/api/users/?suggest=1`;
          const res = await fetch(endpoint, { credentials: 'include' });
          if (!res.ok) throw new Error();
          const data = await res.json();
          if (statusEl) statusEl.textContent = '';
          renderSug(data);
        } catch {
          if (statusEl) statusEl.textContent = '';
          sugEl.innerHTML = '<li class="af-sug-empty">Błąd ładowania</li>';
          sugEl.style.display = '';
        }
      }

      inputEl.addEventListener('focus', () => {
        if (!inputEl.value.trim()) fetchUsers('');
      });

      inputEl.addEventListener('input', () => {
        acState[key].selectedId = null;
        hiddenEl.value = '';
        clearErr(key);
        const q = inputEl.value.trim();
        if (acState[key].timer) clearTimeout(acState[key].timer);
        acState[key].timer = setTimeout(() => fetchUsers(q), 250);
      });

      sugEl.addEventListener('click', (e) => {
        const item = e.target.closest('.af-sug-item');
        if (!item) return;
        acState[key].selectedId = Number(item.dataset.id);
        acState[key].selectedName = item.dataset.name ?? '';
        inputEl.value = acState[key].selectedName;
        hiddenEl.value = String(acState[key].selectedId);
        clearErr(key);
        closeSug();
      });

      inputEl.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSug();
      });

      document.addEventListener('click', (e) => {
        const wrap = inputEl.closest('.af-autocomplete');
        if (wrap && !wrap.contains(e.target)) closeSug();
      });
    }

    function resetAC(key) {
      if (!acState[key]) return;
      acState[key].selectedId = null;
      acState[key].selectedName = '';
      const inputId = { opponent: 'af-opponent-input', partner: 'af-partner-input', rival2: 'af-rival2-input' }[key];
      const hiddenId = { opponent: 'af-opponent-id', partner: 'af-partner-id', rival2: 'af-rival2-id' }[key];
      const input = document.getElementById(inputId);
      const hidden = document.getElementById(hiddenId);
      if (input) input.value = '';
      if (hidden) hidden.value = '';
    }

    // Inicjalizuj autocomplete dla każdego pola
    makeAC('opponent', 'af-opponent-input', 'af-opponent-id', 'af-sug-opponent', 'af-status-opponent');
    makeAC('partner',  'af-partner-input',  'af-partner-id',  'af-sug-partner',  'af-status-partner');
    makeAC('rival2',   'af-rival2-input',   'af-rival2-id',   'af-sug-rival2',   'af-status-rival2');

    // ── Walidacja ──────────────────────────────────────────────────────────────
    const errorBanner = document.getElementById('add-error');

    function clearErr(key) {
      const map = { opponent: 'af-opponent-err', partner: 'af-partner-err', rival2: 'af-rival2-err' };
      const el = document.getElementById(map[key]);
      if (el) el.style.display = 'none';
    }

    function showFieldErr(id, show) {
      const el = document.getElementById(id);
      if (el) el.style.display = show ? '' : 'none';
    }

    function intVal(id) {
      const v = document.getElementById(id)?.value?.trim() ?? '';
      if (v === '') return null;
      const n = parseInt(v, 10);
      return isNaN(n) ? null : n;
    }

    function validate() {
      let ok = true;

      // Przeciwnik wymagany zawsze
      if (!acState['opponent']?.selectedId) {
        showFieldErr('af-opponent-err', true); ok = false;
      }

      // Pola debla wymagane gdy debel
      if (isDouble) {
        if (!acState['partner']?.selectedId) {
          showFieldErr('af-partner-err', true); ok = false;
        }
        if (!acState['rival2']?.selectedId) {
          showFieldErr('af-rival2-err', true); ok = false;
        }

        // Unikalność — zbierz wszystkie 4 ID
        if (ok) {
          const ids = [
            ME,
            acState['opponent'].selectedId,
            acState['partner'].selectedId,
            acState['rival2'].selectedId,
          ];
          if (new Set(ids).size < ids.length) {
            if (errorBanner) {
              errorBanner.textContent = 'Każdy gracz musi być inną osobą — ten sam gracz pojawia się dwukrotnie.';
              errorBanner.style.display = '';
            }
            ok = false;
          }
        }
      }

      // Set 1 wymagany
      const s1p1 = intVal('af-p1s1'), s1p2 = intVal('af-p2s1');
      const s1bad = s1p1 === null || s1p2 === null || s1p1 < 0 || s1p2 < 0;
      showFieldErr('af-s1-err', s1bad); if (s1bad) ok = false;

      // Set 2 — oba albo żaden
      const s2p1 = intVal('af-p1s2'), s2p2 = intVal('af-p2s2');
      const s2bad = (s2p1 === null) !== (s2p2 === null) || (s2p1 !== null && s2p1 < 0) || (s2p2 !== null && s2p2 < 0);
      showFieldErr('af-s2-err', s2bad); if (s2bad) ok = false;

      // Set 3 — oba albo żaden
      const s3p1 = intVal('af-p1s3'), s3p2 = intVal('af-p2s3');
      const s3bad = (s3p1 === null) !== (s3p2 === null) || (s3p1 !== null && s3p1 < 0) || (s3p2 !== null && s3p2 < 0);
      showFieldErr('af-s3-err', s3bad); if (s3bad) ok = false;

      return ok;
    }

    // ── CSRF ───────────────────────────────────────────────────────────────────
    function getCsrf() {
      return document.cookie.split(';').map(c => c.trim())
        .find(c => c.startsWith('csrftoken='))?.split('=')[1] ?? '';
    }

    // ── Submit ─────────────────────────────────────────────────────────────────
    const submitBtn = document.getElementById('af-submit');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorBanner) errorBanner.style.display = 'none';
      if (!validate()) return;

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Zapisuję…'; }

      const payload = {
        p2: acState['opponent'].selectedId,
        match_double: isDouble,
        match_date: document.getElementById('af-date')?.value ?? '',
        p1_set1: intVal('af-p1s1'),
        p2_set1: intVal('af-p2s1'),
      };

      if (isDouble) {
        payload.p3 = acState['partner'].selectedId;   // partner zalogowanego (Team A)
        payload.p4 = acState['rival2'].selectedId;    // partner przeciwnika (Team B)
      }

      const s2p1 = intVal('af-p1s2'), s2p2 = intVal('af-p2s2');
      if (s2p1 !== null && s2p2 !== null) { payload.p1_set2 = s2p1; payload.p2_set2 = s2p2; }

      const s3p1 = intVal('af-p1s3'), s3p2 = intVal('af-p2s3');
      if (s3p1 !== null && s3p2 !== null) { payload.p1_set3 = s3p1; payload.p2_set3 = s3p2; }

      try {
        const res = await fetch(`${API}/api/matches/add/`, {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json', 'X-CSRFToken': getCsrf() },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          window.location.href = `${BASE}/matches?added=1`;
          return;
        }

        let errMsg = 'Nie udało się zapisać meczu. Spróbuj ponownie.';
        try {
          const d = await res.json();
          if (typeof d === 'object') {
            const msgs = Object.entries(d)
              .map(([k, v]) => `${k}: ${Array.isArray(v) ? v.join(', ') : v}`)
              .join(' | ');
            if (msgs) errMsg = msgs;
          }
        } catch {}

        if (errorBanner) { errorBanner.textContent = errMsg; errorBanner.style.display = ''; }

      } catch {
        if (errorBanner) { errorBanner.textContent = 'Błąd połączenia. Sprawdź sieć i spróbuj ponownie.'; errorBanner.style.display = ''; }
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Zapisz mecz'; }
      }
    });

  })();
</script>

<style>
  .add-wrap {
    padding: 0 var(--page-px, 28px) 40px;
    max-width: 600px;
    margin: 0 auto;
  }

  .add-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .add-title {
    font-size: 1.5rem; font-weight: 800; color: var(--text);
    margin: 0 0 6px;
  }
  .add-subtitle {
    font-size: 0.88rem; color: var(--text-muted); margin: 0;
  }

  .add-alert {
    padding: 10px 14px; border-radius: 8px;
    font-size: 0.84rem; font-weight: 600;
    margin-bottom: 16px;
  }
  .add-alert--err {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    color: var(--danger, #ef4444);
  }

  .add-card { padding: 28px 32px; text-align: center; }

  :global(.tc-breadcrumb) { max-width: 600px; margin: 0 auto; }

  /* ── Format toggle ──────────────────────────────────────────────────── */
  .af-format-toggle {
    display: inline-flex; border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
  }
  .af-format-btn {
    padding: 7px 20px;
    font-size: 0.84rem; font-weight: 600;
    background: var(--surface); color: var(--text-muted);
    border: none; cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .af-format-btn + .af-format-btn {
    border-left: 1px solid var(--border);
  }
  .af-format-btn--active {
    background: var(--primary); color: #fff;
  }

  /* ── Team headers (debel) ───────────────────────────────────────────── */
  .af-team-header {
    margin-bottom: 8px; margin-top: 4px;
    text-align: center;
  }
  .af-team-label {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.07em;
    padding: 3px 10px; border-radius: 99px;
  }
