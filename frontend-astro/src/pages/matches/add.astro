---
// matches/add.astro — formularz dodawania rozegranego meczu towarzyskiego (singiel)
// Prywatna strona: wymaga zalogowania. Bez debla, bez confirm flow.
export const prerender = false;

import AppLayout from '@/layouts/AppLayout.astro';
import { getCurrentUser } from '@/lib/api';
import { url } from '@/lib/url';

const sessionCookie = Astro.request.headers.get('cookie') ?? undefined;
const currentUser = await getCurrentUser(sessionCookie);

if (!currentUser) {
  return Astro.redirect(url('/login') + '?next=' + encodeURIComponent(url('/matches/add')));
}

// Dzisiejsza data jako default dla pola daty
const today = new Date().toISOString().slice(0, 10);
---

<AppLayout title="Dodaj mecz" showSearch={false} showCta={false} currentUser={currentUser}>
  <nav class="tc-breadcrumb" aria-label="Nawigacja">
    <a href={url('/matches')}>← Moje mecze</a>
  </nav>

  <div class="add-wrap">
    <div class="add-header">
      <h1 class="add-title">Dodaj mecz towarzyski</h1>
      <p class="add-subtitle">Zapisz wynik rozegranego meczu singla.</p>
    </div>

    <!-- Alert błędu -->
    <div id="add-error" class="add-alert add-alert--err" style="display:none;" role="alert"></div>

    <div class="tc-card add-card">
      <form id="add-form" novalidate>

        <!-- Przeciwnik -->
        <div class="af-field">
          <label class="af-label" for="af-opponent-input">
            Przeciwnik <span class="af-required">*</span>
          </label>
          <div class="af-autocomplete" id="af-autocomplete">
            <input
              id="af-opponent-input"
              class="af-input"
              type="text"
              placeholder="Wpisz imię lub nazwisko..."
              autocomplete="off"
              aria-autocomplete="list"
              aria-controls="af-suggestions"
              aria-expanded="false"
            />
            <input type="hidden" id="af-opponent-id" name="p2" />
            <ul
              id="af-suggestions"
              class="af-suggestions"
              role="listbox"
              style="display:none;"
              aria-label="Sugestie graczy"
            ></ul>
            <div id="af-search-status" class="af-search-status" aria-live="polite"></div>
          </div>
          <p id="af-opponent-err" class="af-field-err" style="display:none;">Wybierz przeciwnika z listy.</p>
        </div>

        <!-- Sety -->
        <div class="af-field">
          <label class="af-label">Wynik</label>
          <div class="af-sets">

            <!-- Set 1 (wymagany) -->
            <div class="af-set">
              <span class="af-set-label">Set 1 <span class="af-required">*</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who">Ty</span>
                  <input id="af-p1s1" class="af-num" type="number" min="0" max="99" placeholder="0" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who">Rywal</span>
                  <input id="af-p2s1" class="af-num" type="number" min="0" max="99" placeholder="0" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s1-err" class="af-field-err" style="display:none;">Set 1 jest wymagany — wpisz wynik dla obu graczy.</p>
            </div>

            <!-- Set 2 (opcjonalny) -->
            <div class="af-set af-set--opt">
              <span class="af-set-label">Set 2 <span class="af-optional">(opcjonalnie)</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who">Ty</span>
                  <input id="af-p1s2" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who">Rywal</span>
                  <input id="af-p2s2" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s2-err" class="af-field-err" style="display:none;">Wpisz wynik dla obu graczy w secie 2.</p>
            </div>

            <!-- Set 3 (opcjonalny) -->
            <div class="af-set af-set--opt">
              <span class="af-set-label">Set 3 <span class="af-optional">(opcjonalnie)</span></span>
              <div class="af-set-row">
                <div class="af-set-col">
                  <span class="af-set-who">Ty</span>
                  <input id="af-p1s3" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
                <span class="af-set-sep">:</span>
                <div class="af-set-col">
                  <span class="af-set-who">Rywal</span>
                  <input id="af-p2s3" class="af-num" type="number" min="0" max="99" placeholder="—" inputmode="numeric" />
                </div>
              </div>
              <p id="af-s3-err" class="af-field-err" style="display:none;">Wpisz wynik dla obu graczy w secie 3.</p>
            </div>

          </div>
        </div>

        <!-- Data meczu -->
        <div class="af-field">
          <label class="af-label" for="af-date">Data meczu</label>
          <input
            id="af-date"
            class="af-input af-input--date"
            type="date"
            value={today}
            max={today}
          />
        </div>

        <!-- Submit -->
        <div class="af-actions">
          <a href={url('/matches')} class="tc-btn tc-btn-ghost">Anuluj</a>
          <button id="af-submit" type="submit" class="tc-btn tc-btn-primary">
            Zapisz mecz
          </button>
        </div>

      </form>
    </div>
  </div>
</AppLayout>

<script>
  (function () {
    // ── Bazowy URL — ta sama konwencja co inne strony ──────────────────────────
    const API  = (document.querySelector('meta[name="api-base"]') as HTMLMetaElement)?.content ?? '';
    const BASE = import.meta.env.BASE_URL?.replace(/\/$/, '') ?? '';

    // ── Elementy ───────────────────────────────────────────────────────────────
    const form        = document.getElementById('add-form') as HTMLFormElement;
    const errorBanner = document.getElementById('add-error') as HTMLElement;

    const opponentInput = document.getElementById('af-opponent-input') as HTMLInputElement;
    const opponentId    = document.getElementById('af-opponent-id')    as HTMLInputElement;
    const suggestions   = document.getElementById('af-suggestions')    as HTMLUListElement;
    const searchStatus  = document.getElementById('af-search-status')  as HTMLElement;
    const opponentErr   = document.getElementById('af-opponent-err')   as HTMLElement;

    const p1s1 = document.getElementById('af-p1s1') as HTMLInputElement;
    const p2s1 = document.getElementById('af-p2s1') as HTMLInputElement;
    const p1s2 = document.getElementById('af-p1s2') as HTMLInputElement;
    const p2s2 = document.getElementById('af-p2s2') as HTMLInputElement;
    const p1s3 = document.getElementById('af-p1s3') as HTMLInputElement;
    const p2s3 = document.getElementById('af-p2s3') as HTMLInputElement;
    const s1Err = document.getElementById('af-s1-err') as HTMLElement;
    const s2Err = document.getElementById('af-s2-err') as HTMLElement;
    const s3Err = document.getElementById('af-s3-err') as HTMLElement;

    const dateInput = document.getElementById('af-date') as HTMLInputElement;
    const submitBtn = document.getElementById('af-submit') as HTMLButtonElement;

    // ── CSRF ───────────────────────────────────────────────────────────────────
    function getCsrf(): string {
      return document.cookie.split(';')
        .map(c => c.trim())
        .find(c => c.startsWith('csrftoken='))
        ?.split('=')[1] ?? '';
    }

    // ── Autocomplete ───────────────────────────────────────────────────────────
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    let selectedUserId: number | null = null;
    let selectedUserName = '';

    function closeSuggestions() {
      suggestions.style.display = 'none';
      opponentInput.setAttribute('aria-expanded', 'false');
    }

    function renderSuggestions(users: {id:number; username:string; first_name:string; last_name:string}[]) {
      if (users.length === 0) {
        suggestions.innerHTML = '<li class="af-sug-empty">Brak wyników</li>';
      } else {
        suggestions.innerHTML = users.map(u => {
          const full = [u.first_name, u.last_name].filter(Boolean).join(' ') || u.username;
          const sub  = u.first_name || u.last_name ? u.username : '';
          return `<li class="af-sug-item" role="option" data-id="${u.id}" data-name="${full}">
            <span class="af-sug-name">${full}</span>
            ${sub ? `<span class="af-sug-sub">${sub}</span>` : ''}
          </li>`;
        }).join('');
      }
      suggestions.style.display = '';
      opponentInput.setAttribute('aria-expanded', 'true');
    }

    async function fetchUsers(q: string) {
      searchStatus.textContent = 'Szukam…';
      try {
        const endpoint = q.length >= 2
          ? `${API}/api/users/?search=${encodeURIComponent(q)}`
          : `${API}/api/users/?suggest=1`;
        const res = await fetch(endpoint, { credentials: 'include' });
        if (!res.ok) throw new Error('API error');
        const data = await res.json();
        searchStatus.textContent = '';
        renderSuggestions(data);
      } catch {
        searchStatus.textContent = '';
        suggestions.innerHTML = '<li class="af-sug-empty">Błąd ładowania</li>';
        suggestions.style.display = '';
      }
    }

    // Otwórz sugestie przy focus (suggest mode)
    opponentInput.addEventListener('focus', () => {
      if (!opponentInput.value.trim()) {
        fetchUsers('');
      }
    });

    // Wpisywanie — debounce 250ms
    opponentInput.addEventListener('input', () => {
      // Reset wyboru gdy zmieniony tekst
      selectedUserId = null;
      opponentId.value = '';
      opponentErr.style.display = 'none';

      const q = opponentInput.value.trim();
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => fetchUsers(q), 250);
    });

    // Kliknięcie sugestii
    suggestions.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest<HTMLElement>('.af-sug-item');
      if (!item) return;
      selectedUserId = Number(item.dataset.id);
      selectedUserName = item.dataset.name ?? '';
      opponentInput.value = selectedUserName;
      opponentId.value = String(selectedUserId);
      opponentErr.style.display = 'none';
      closeSuggestions();
    });

    // Zamknij przy kliknięciu poza
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('#af-autocomplete')) {
        closeSuggestions();
      }
    });

    // Klawiatura — Escape zamyka
    opponentInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSuggestions();
    });

    // ── Helpers walidacji ──────────────────────────────────────────────────────
    function intVal(el: HTMLInputElement): number | null {
      const v = el.value.trim();
      if (v === '') return null;
      const n = parseInt(v, 10);
      return isNaN(n) ? null : n;
    }

    function showErr(el: HTMLElement, show: boolean) {
      el.style.display = show ? '' : 'none';
    }

    function validate(): boolean {
      let ok = true;

      // Przeciwnik
      if (!opponentId.value) {
        showErr(opponentErr, true);
        ok = false;
      }

      // Set 1 wymagany
      const s1p1 = intVal(p1s1);
      const s1p2 = intVal(p2s1);
      const s1missing = s1p1 === null || s1p2 === null;
      const s1neg = (s1p1 !== null && s1p1 < 0) || (s1p2 !== null && s1p2 < 0);
      showErr(s1Err, s1missing || s1neg);
      if (s1missing || s1neg) ok = false;

      // Set 2 — oba albo żaden
      const s2p1 = intVal(p1s2);
      const s2p2 = intVal(p2s2);
      const s2partial = (s2p1 === null) !== (s2p2 === null);
      const s2neg = (s2p1 !== null && s2p1 < 0) || (s2p2 !== null && s2p2 < 0);
      showErr(s2Err, s2partial || s2neg);
      if (s2partial || s2neg) ok = false;

      // Set 3 — oba albo żaden
      const s3p1 = intVal(p1s3);
      const s3p2 = intVal(p2s3);
      const s3partial = (s3p1 === null) !== (s3p2 === null);
      const s3neg = (s3p1 !== null && s3p1 < 0) || (s3p2 !== null && s3p2 < 0);
      showErr(s3Err, s3partial || s3neg);
      if (s3partial || s3neg) ok = false;

      return ok;
    }

    // ── Submit ─────────────────────────────────────────────────────────────────
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBanner.style.display = 'none';

      if (!validate()) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Zapisuję…';

      const payload: Record<string, string | number | boolean> = {
        p2: Number(opponentId.value),
        match_double: false,
        match_date: dateInput.value,
        p1_set1: intVal(p1s1)!,
        p2_set1: intVal(p2s1)!,
      };

      const s2p1 = intVal(p1s2);
      const s2p2 = intVal(p2s2);
      if (s2p1 !== null && s2p2 !== null) {
        payload['p1_set2'] = s2p1;
        payload['p2_set2'] = s2p2;
      }

      const s3p1 = intVal(p1s3);
      const s3p2 = intVal(p2s3);
      if (s3p1 !== null && s3p2 !== null) {
        payload['p1_set3'] = s3p1;
        payload['p2_set3'] = s3p2;
      }

      try {
        const res = await fetch(`${API}/api/matches/add/`, {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': getCsrf(),
          },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          // Redirect na /matches z query ?added=1 — pokaż banner
          window.location.href = `${BASE}/matches?added=1`;
          return;
        }

        // Błąd backendu
        let errMsg = 'Nie udało się zapisać meczu. Spróbuj ponownie.';
        try {
          const errData = await res.json();
          if (typeof errData === 'object') {
            const msgs = Object.entries(errData)
              .map(([k, v]) => `${k}: ${Array.isArray(v) ? v.join(', ') : v}`)
              .join(' | ');
            if (msgs) errMsg = msgs;
          }
        } catch { /* zostaje domyślny komunikat */ }

        errorBanner.textContent = errMsg;
        errorBanner.style.display = '';

      } catch {
        errorBanner.textContent = 'Błąd połączenia. Sprawdź sieć i spróbuj ponownie.';
        errorBanner.style.display = '';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Zapisz mecz';
      }
    });

  })();
</script>

<style>
  .add-wrap {
    padding: 0 var(--page-px, 28px) 40px;
    max-width: 560px;
  }

  .add-header {
    margin-bottom: 24px;
  }
  .add-title {
    font-size: 1.5rem; font-weight: 800; color: var(--text);
    margin: 0 0 6px;
  }
  .add-subtitle {
    font-size: 0.88rem; color: var(--text-muted); margin: 0;
  }

  .add-alert {
    padding: 10px 14px; border-radius: 8px;
    font-size: 0.84rem; font-weight: 600;
    margin-bottom: 16px;
  }
  .add-alert--err {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    color: var(--danger, #ef4444);
  }

  .add-card { padding: 24px 28px; }

  /* ── Pola formularza ────────────────────────────────────────────────── */
  .af-field { margin-bottom: 22px; }
  .af-label {
    display: block;
    font-size: 0.84rem; font-weight: 700; color: var(--text);
    margin-bottom: 7px;
  }
  .af-required { color: var(--primary); }
  .af-optional { font-weight: 400; font-size: 0.78rem; color: var(--text-muted); }

  .af-input {
    width: 100%; box-sizing: border-box;
    padding: 9px 12px; border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface); color: var(--text);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.12s;
  }
  .af-input:focus { border-color: var(--primary); }
  .af-input--date { max-width: 200px; }

  .af-field-err {
    font-size: 0.78rem; color: var(--danger, #ef4444);
    margin: 5px 0 0; font-weight: 600;
  }

  /* ── Autocomplete ───────────────────────────────────────────────────── */
  .af-autocomplete { position: relative; }

  .af-suggestions {
    position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    z-index: 100;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; box-shadow: var(--shadow-card, 0 4px 16px rgba(0,0,0,0.12));
    list-style: none; padding: 4px 0; margin: 0;
    max-height: 220px; overflow-y: auto;
  }

  .af-sug-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; cursor: pointer;
    transition: background 0.1s;
  }
  .af-sug-item:hover, .af-sug-item[aria-selected="true"] {
    background: var(--surface-hover);
  }

  .af-sug-name {
    font-size: 0.875rem; font-weight: 600; color: var(--text);
  }
  .af-sug-sub {
    font-size: 0.75rem; color: var(--text-muted);
  }

  .af-sug-empty {
    padding: 10px 12px;
    font-size: 0.84rem; color: var(--text-muted); text-align: center;
  }

  .af-search-status {
    font-size: 0.78rem; color: var(--text-muted);
    margin-top: 5px; min-height: 18px;
  }

  /* ── Sety ───────────────────────────────────────────────────────────── */
  .af-sets {
    display: flex; flex-direction: column; gap: 14px;
  }

  .af-set {
    background: var(--surface-2, var(--surface-hover));
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .af-set--opt { opacity: 0.9; }

  .af-set-label {
    display: block;
    font-size: 0.78rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 10px;
  }

  .af-set-row {
    display: flex; align-items: center; gap: 10px;
  }

  .af-set-col {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }

  .af-set-who {
    font-size: 0.72rem; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .af-num {
    width: 64px; text-align: center;
    padding: 8px 6px; border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface); color: var(--text);
    font-size: 1.1rem; font-weight: 700;
    outline: none;
    -moz-appearance: textfield;
    transition: border-color 0.12s;
  }
  .af-num:focus { border-color: var(--primary); }
  .af-num::-webkit-outer-spin-button,
  .af-num::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .af-set-sep {
    font-size: 1.2rem; font-weight: 700; color: var(--text-muted);
    margin-top: 20px; /* wyrównanie z polem — nad etykietą "Ty/Rywal" */
    flex-shrink: 0;
  }

  /* ── Akcje ──────────────────────────────────────────────────────────── */
  .af-actions {
    display: flex; justify-content: flex-end; gap: 10px;
    margin-top: 28px; padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 480px) {
    .add-card { padding: 16px 16px; }
    .af-actions { flex-direction: column-reverse; }
    .af-actions .tc-btn { width: 100%; justify-content: center; }
    .af-num { width: 56px; }
  }
</style>
