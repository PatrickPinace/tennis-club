---
// matches.astro — historia meczów z danymi demo
// Docelowo: GET /api/matches/history/ (istnieje w Django)
import AppLayout from '@/layouts/AppLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

// Dane demo — docelowo z /api/matches/history/
const matches = [
  {
    id: 1,
    date: '21 Paź 2026',
    opponent: 'Tomasz Bąk',
    opponentInitials: 'TB',
    format: 'SNG',
    score: '6:3, 7:5',
    result: 'win',
    location: 'Korty Otwock',
    type: 'friendly',
    typeLabel: 'Towarzyski',
  },
  {
    id: 2,
    date: '15 Paź 2026',
    opponent: 'Adam Kowalczyk',
    opponentInitials: 'AK',
    format: 'SNG',
    score: '4:6, 5:7',
    result: 'loss',
    location: 'Hala Praga',
    type: 'tournament',
    typeLabel: 'Liga Letnia',
  },
  {
    id: 3,
    date: '8 Paź 2026',
    opponent: 'Rafał Nowak',
    opponentInitials: 'RN',
    format: 'SNG',
    score: '6:1, 6:4',
    result: 'win',
    location: 'Korty Otwock',
    type: 'tournament',
    typeLabel: 'Liga Letnia',
  },
  {
    id: 4,
    date: '1 Paź 2026',
    opponent: 'Piotr Wiśniewski',
    opponentInitials: 'PW',
    format: 'SNG',
    score: '7:5, 4:6, 10:8',
    result: 'win',
    location: 'Korty Otwock',
    type: 'friendly',
    typeLabel: 'Towarzyski',
  },
  {
    id: 5,
    date: '24 Wrz 2026',
    opponent: 'Łukasz Dąbrowski',
    opponentInitials: 'ŁD',
    format: 'DBL',
    score: '6:4, 6:3',
    result: 'win',
    location: 'Hala Praga',
    type: 'tournament',
    typeLabel: 'Americano #7',
  },
  {
    id: 6,
    date: '18 Wrz 2026',
    opponent: 'Marek Wróbel',
    opponentInitials: 'MW',
    format: 'SNG',
    score: '3:6, 6:7',
    result: 'loss',
    location: 'Korty Otwock',
    type: 'friendly',
    typeLabel: 'Towarzyski',
  },
];

const wins   = matches.filter(m => m.result === 'win').length;
const losses = matches.filter(m => m.result === 'loss').length;
const winRate = Math.round(wins / matches.length * 100);
---

<AppLayout
  title="Mecze"
  greeting="Historia meczów"
  showSearch={false}
  showCta={true}
  ctaLabel="+ Dodaj mecz"
  ctaHref="/matches/add"
>

  <PageHeader
    eyebrow="Rozgrywki"
    title="Historia meczów"
    subtitle="Wszystkie rozegrane mecze — towarzyskie i turniejowe."
  />

  <!-- Stats -->
  <div class="m-stats">
    <div class="m-stat">
      <span class="m-stat__val">{matches.length}</span>
      <span class="m-stat__lbl">Wszystkie</span>
    </div>
    <div class="m-stat m-stat--win">
      <span class="m-stat__val">{wins}</span>
      <span class="m-stat__lbl">Wygrane</span>
    </div>
    <div class="m-stat m-stat--loss">
      <span class="m-stat__val">{losses}</span>
      <span class="m-stat__lbl">Porażki</span>
    </div>
    <div class="m-stat">
      <span class="m-stat__val">{winRate}%</span>
      <span class="m-stat__lbl">Win Rate</span>
    </div>
  </div>

  <!-- Filters -->
  <div class="m-filters">
    <button class="m-filter m-filter--active">Wszystkie</button>
    <button class="m-filter">Wygrane</button>
    <button class="m-filter">Porażki</button>
    <button class="m-filter">Turniejowe</button>
    <button class="m-filter">Towarzyskie</button>
  </div>

  <!-- Lista meczów -->
  <div class="tc-card">
    <div class="tc-card-header">
      <span class="tc-card-title">Ostatnie mecze</span>
      <span style="font-size:0.78rem; color:var(--text-dim);">Dane demo · GET /api/matches/history/</span>
    </div>

    <ul class="match-list" role="list">
      {matches.map(m => (
        <li class="match-row">
          <!-- Result dot -->
          <div class={`match-result match-result--${m.result}`} aria-label={m.result === 'win' ? 'Wygrana' : 'Porażka'}>
            {m.result === 'win' ? 'W' : 'P'}
          </div>

          <!-- Opponent -->
          <div class="match-opponent">
            <div class={`tc-avatar tc-avatar-sm`} aria-hidden="true">{m.opponentInitials}</div>
            <div>
              <div class="match-opponent__name">{m.opponent}</div>
              <div class="match-opponent__meta">{m.date} · {m.location}</div>
            </div>
          </div>

          <!-- Score -->
          <div class="match-score" aria-label={`Wynik: ${m.score}`}>
            <span class={`match-score__num match-score__num--${m.result}`}>{m.score}</span>
          </div>

          <!-- Type badge -->
          <div class="match-badges">
            <span class="tc-badge tc-badge-neutral">{m.typeLabel}</span>
            {m.format === 'DBL' && <span class="tc-badge tc-badge-info">Debel</span>}
          </div>

          <!-- Actions -->
          <div class="match-actions">
            <a href={`/matches/${m.id}`} class="tc-btn tc-btn-ghost tc-btn-sm">Szczegóły</a>
          </div>
        </li>
      ))}
    </ul>

    <div class="tc-card-footer" style="text-align:center;">
      <a href="#" class="tc-btn tc-btn-ghost tc-btn-sm">Załaduj więcej →</a>
    </div>
  </div>

</AppLayout>

<style>
  /* ── Stats ─────────────────────────────────────────────────────────────── */
  .m-stats {
    display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;
  }

  .m-stat {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: 14px 20px;
    display: flex; flex-direction: column; gap: 2px;
    min-width: 100px; box-shadow: var(--shadow-card);
  }

  .m-stat__val {
    font-size: 1.5rem; font-weight: 900; color: var(--text);
    letter-spacing: -0.04em; line-height: 1;
  }
  .m-stat__lbl {
    font-size: 0.72rem; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  .m-stat--win  .m-stat__val { color: #22c55e; }
  .m-stat--loss .m-stat__val { color: var(--danger); }

  /* ── Filters ───────────────────────────────────────────────────────────── */
  .m-filters {
    display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px;
  }

  .m-filter {
    padding: 6px 14px; border-radius: 99px;
    font-size: 0.8rem; font-weight: 600;
    border: 1px solid var(--border);
    background: var(--surface); color: var(--text-muted);
    cursor: pointer; transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .m-filter:hover { background: var(--surface-hover); color: var(--text); }
  .m-filter--active {
    background: var(--primary-subtle); color: var(--primary);
    border-color: rgba(34,197,94,0.3);
  }

  /* ── Match list ────────────────────────────────────────────────────────── */
  .match-list { list-style: none; padding: 0; margin: 0; }

  .match-row {
    display: grid;
    grid-template-columns: 36px 1fr auto auto auto;
    align-items: center; gap: 16px;
    padding: 13px 20px;
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }
  .match-row:last-child { border-bottom: none; }
  .match-row:hover { background: var(--surface-hover); }

  .match-result {
    width: 28px; height: 28px; border-radius: 6px;
    display: grid; place-items: center;
    font-size: 0.72rem; font-weight: 800;
    flex-shrink: 0;
  }
  .match-result--win  { background: rgba(34,197,94,0.12); color: #22c55e; }
  .match-result--loss { background: rgba(239,68,68,0.12); color: var(--danger); }

  .match-opponent {
    display: flex; align-items: center; gap: 10px; min-width: 0;
  }
  .match-opponent__name {
    font-weight: 600; font-size: 0.875rem; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .match-opponent__meta {
    font-size: 0.75rem; color: var(--text-muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .match-score {}
  .match-score__num {
    font-weight: 700; font-size: 0.9rem; white-space: nowrap;
  }
  .match-score__num--win  { color: #22c55e; }
  .match-score__num--loss { color: var(--text-muted); }

  .match-badges { display: flex; gap: 5px; flex-wrap: wrap; }
  .match-actions { flex-shrink: 0; }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .match-row {
      grid-template-columns: 28px 1fr auto;
      gap: 10px;
    }
    .match-badges { display: none; }
    .match-actions { display: none; }
  }
</style>
