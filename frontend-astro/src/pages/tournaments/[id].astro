---
// tournaments/[id].astro — szczegół turnieju
// Obsługuje tylko Round Robin (tournament_type === 'RND').
// Inne typy → komunikat "nie obsługiwany jeszcze w Astro".
// Endpoint: GET /api/tournaments/{id}/detail/
// SSR: prerender=false — dane zawsze świeże, nowe turnieje dostępne od razu.
export const prerender = false;

import AppLayout from '@/layouts/AppLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getTournamentDetail, type TournamentDetail, type RRStandingRow, type TournamentMatch } from '@/lib/api';
import { url } from '@/lib/url';

const { id } = Astro.params;
const tournamentId = id ? parseInt(id, 10) : NaN;
const justCreated = Astro.url.searchParams.get('created') === '1';

// ── Pobierz dane ──────────────────────────────────────────────────────────────
let tournament: TournamentDetail | null = null;
let fetchError: string | null = null;

if (!isNaN(tournamentId)) {
  try {
    tournament = await getTournamentDetail(tournamentId);
    if (!tournament) fetchError = 'not_found';
  } catch (e) {
    fetchError = 'api_error';
    console.error('[tournament/[id]] fetch failed:', e);
  }
} else {
  fetchError = 'bad_id';
}

// ── Stałe ─────────────────────────────────────────────────────────────────────
const STATUS_LABEL: Record<string, string> = {
  DRF: 'Szkic', REG: 'Rejestracja', SCH: 'Zaplanowany',
  ACT: 'Trwa', FIN: 'Zakończony', CNC: 'Odwołany',
};
const STATUS_BADGE: Record<string, string> = {
  DRF: 'tc-badge-neutral', REG: 'tc-badge-success', SCH: 'tc-badge-info',
  ACT: 'tc-badge-warning',  FIN: 'tc-badge-neutral', CNC: 'tc-badge-neutral',
};
const FORMAT_LABEL: Record<string, string> = { SNG: 'Singiel', DBL: 'Debel' };
const MATCH_STATUS_LABEL: Record<string, string> = {
  WAI: 'Oczekuje', SCH: 'Zaplanowany', INP: 'W trakcie',
  CMP: 'Zakończony', WDR: 'Walkower', CNC: 'Odwołany',
};
const TIE_LABEL: Record<string, string> = {
  HEAD: 'Bezpośrednie spotkanie', SETS: 'Bilans setów', GAMES: 'Bilans gemów',
};

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleDateString('pl-PL', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return iso; }
}

// Grupuj mecze wg rundy
function groupByRound(matches: TournamentMatch[]): Map<number, TournamentMatch[]> {
  const map = new Map<number, TournamentMatch[]>();
  for (const m of matches) {
    if (!map.has(m.round_number)) map.set(m.round_number, []);
    map.get(m.round_number)!.push(m);
  }
  return map;
}

const isRoundRobin = tournament?.tournament_type === 'RND';
const isSingleElimination = tournament?.tournament_type === 'SGL';
const isAmericano = tournament?.tournament_type === 'AMR';
const amrSchedulingType = isAmericano ? (tournament?.config?.scheduling_type ?? 'STATIC') : null;
const isMexicano = amrSchedulingType === 'DYNAMIC';
const matchesByRound = tournament && (isRoundRobin || isAmericano) ? groupByRound(tournament.matches) : new Map();
const rounds = Array.from(matchesByRound.keys()).sort((a, b) => a - b);
const amrTotalRounds = isAmericano ? (tournament?.config?.number_of_rounds ?? null) : null;
const amrCurrentRound = isMexicano && rounds.length > 0 ? Math.max(...rounds) : null;

// done  = CMP + WDR (spójne z backendem matches_progress)
// pending = WAI + SCH + INP (nie wliczamy CNC — anulowane nie czekają na rozegranie)
const completedMatches = tournament?.matches.filter(m => m.status === 'CMP' || m.status === 'WDR') ?? [];
const pendingMatches   = tournament?.matches.filter(m => m.status === 'WAI' || m.status === 'SCH' || m.status === 'INP') ?? [];
---

<AppLayout
  title={tournament?.name ?? 'Turniej'}
  greeting="Turnieje"
  showSearch={false}
  showCta={false}
>

  <!-- Breadcrumb -->
  <nav class="td-breadcrumb" aria-label="Nawigacja">
    <a href={url('/tournaments')}>← Turnieje</a>
    {tournament && <span aria-hidden="true"> / </span>}
    {tournament && <span>{tournament.name}</span>}
  </nav>

  <!-- ── Banner: turniej właśnie utworzony ──────────────────────────────────── -->
  {justCreated && tournament && (
    <div class="td-created-banner" id="td-created-banner" role="status">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <div class="td-created-banner__body">
        <strong>Turniej utworzony!</strong>
        <span>Dodaj uczestników i otwórz zapisy poniżej.</span>
      </div>
      <button type="button" class="td-created-banner__close" aria-label="Zamknij"
        onclick="this.closest('.td-created-banner').remove()">✕</button>
    </div>
  )}

  <!-- ── Błędy ─────────────────────────────────────────────────────────────── -->
  {fetchError === 'not_found' && (
    <div class="td-error-card">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
      <p>Turniej o ID <strong>{id}</strong> nie istnieje.</p>
      <a href={url('/tournaments')} class="tc-btn tc-btn-secondary tc-btn-sm">← Powrót do listy</a>
    </div>
  )}

  {fetchError === 'api_error' && (
    <div class="td-error-card">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      <p>Błąd połączenia z API.</p>
      <a href={url('/tournaments')} class="tc-btn tc-btn-secondary tc-btn-sm">← Powrót do listy</a>
    </div>
  )}

  <!-- ── Turniej znaleziony ─────────────────────────────────────────────────── -->
  {tournament && (
    <>
      <PageHeader
        eyebrow="Rozgrywki"
        title={tournament.name}
        subtitle={tournament.description || `${FORMAT_LABEL[tournament.match_format] ?? tournament.match_format} · ${isRoundRobin ? 'Liga (każdy z każdym)' : isSingleElimination ? 'Eliminacja pojedyncza' : isMexicano ? 'Mexicano' : isAmericano ? 'Americano' : tournament.tournament_type}`}
        centered={true}
      />

      <!-- Header info row -->
      <div class="td-info-row">
        <div class="td-info-badges">
          <span class={`tc-badge ${STATUS_BADGE[tournament.status] ?? 'tc-badge-neutral'}`}>
            {STATUS_LABEL[tournament.status] ?? tournament.status}
          </span>
          <span class="tc-badge tc-badge-primary">{isRoundRobin ? 'Liga (Round Robin)' : isSingleElimination ? 'Eliminacja pojedyncza' : isMexicano ? 'Mexicano' : isAmericano ? 'Americano' : (tournament.tournament_type ?? '—')}</span>
          <span class="tc-badge tc-badge-neutral">{FORMAT_LABEL[tournament.match_format] ?? tournament.match_format}</span>
          {tournament.rank === 1 && <span class="tc-badge" style="background:rgba(245,158,11,0.12);color:#f59e0b;">★ Ranga 1</span>}
        </div>
        <div class="td-info-meta">
          {(tournament.start_date || tournament.end_date) && (
            <span class="td-meta-item">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
              {fmtDate(tournament.start_date)}{tournament.end_date ? ` – ${fmtDate(tournament.end_date)}` : ''}
            </span>
          )}
          {tournament.facility_name && (
            <span class="td-meta-item">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {tournament.facility_name}
            </span>
          )}
          <span class="td-meta-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
              {tournament.participant_count} uczestników
          </span>
          {tournament.matches_progress && tournament.matches_progress.total > 0 && (
            <span class="td-meta-item td-meta-progress">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              {tournament.matches_progress.done}/{tournament.matches_progress.total} meczów
              <span class="td-progress-bar-wrap">
                <span
                  class="td-progress-bar-fill"
                  style={`width:${Math.round(tournament.matches_progress.done / tournament.matches_progress.total * 100)}%`}
                ></span>
              </span>
            </span>
          )}
        </div>
      </div>

      <!-- ── Nie Round Robin, nie SGL, nie AMR → komunikat ───────────────── -->
      {!isRoundRobin && !isSingleElimination && !isAmericano && (
        <div class="td-unsupported">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <p>Ten typ szczegółu nie jest jeszcze obsługiwany.</p>
          <span>Ten turniej ma typ: <strong>{tournament.tournament_type}</strong>.</span>
        </div>
      )}

      <!-- ── Single Elimination — widok drabinki ───────────────────────────── -->
      {isSingleElimination && (
        <div class="td-layout">

          <!-- Stat pills -->
          <div class="td-stats">
            <div class="td-stat">
              <span class="td-stat__val">{tournament.participant_count}</span>
              <span class="td-stat__lbl">Uczestników</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{tournament.matches.length}</span>
              <span class="td-stat__lbl">Meczów</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{completedMatches.length}</span>
              <span class="td-stat__lbl">Rozegranych</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{pendingMatches.length}</span>
              <span class="td-stat__lbl">Pozostałych</span>
            </div>
          </div>

          <!-- Lista uczestników (bez drabinki zanim mecze zostaną wygenerowane) -->
          {tournament.participants.length > 0 && (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Uczestnicy ({tournament.participant_count})</span>
              </div>
              <div class="td-participants">
                {tournament.participants.map(p => (
                  <div class="td-participant">
                    <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                      {p.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                    </div>
                    <span class="td-participant__name">{p.display_name}</span>
                    {p.seed_number && (
                      <span class="td-seed">#{p.seed_number}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── Drabinka ──────────────────────────────────────────────────── -->
          {(tournament.status === 'DRF' || tournament.status === 'REG') ? (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Drabinka zostanie wygenerowana po zamknięciu rejestracji.</span>
            </div>
          ) : (
            <div class="tc-card" style="margin-bottom:24px;" id="bracket-card">
              <div class="tc-card-header">
                <span class="tc-card-title">Drabinka</span>
              </div>
              <div id="bracket-container" class="bracket-container">
                <div class="org-loading">Ładowanie drabinki…</div>
              </div>
            </div>
          )}

          <!-- ── Zarządzanie (organizer) — SGL ────────────────────────────── -->
          <div
            id="org-panel"
            style="display:none;"
            data-tournament-id={tournament.id}
            data-created-by={tournament.created_by_username}
            data-tournament-status={tournament.status}
            data-tournament-type={tournament.tournament_type}
            data-match-format={tournament.match_format}
            data-sets-to-win={tournament.config?.sets_to_win ?? 2}
            data-end-date={tournament.end_date ?? ''}
          >
            <div class="tc-card org-card">
              <div class="tc-card-header">
                <span class="tc-card-title">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:-2px;margin-right:6px;color:var(--primary);">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                  </svg>
                  Zarządzanie turniejem
                </span>
                <div style="display:flex;align-items:center;gap:8px;">
                  <a href={url('/tournaments/manage')} class="org-manage-link">
                    <svg width="11" height="11" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                    </svg>
                    Moje turnieje
                  </a>
                  <span class="tc-badge tc-badge-warning" style="font-size:0.72rem;">Organizator</span>
                </div>
              </div>

              <div id="org-locked-msg" style="display:none;" class="org-locked-notice">
                Turniej jest zakończony lub odwołany — edycja wyników jest zablokowana.
              </div>

              <!-- Status -->
              <div id="org-status-section" style="padding:0 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:10px;">Status turnieju</div>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                  <span id="org-status-badge" class="tc-badge tc-badge-neutral" style="font-size:0.8rem;">
                    {STATUS_LABEL[tournament.status] ?? tournament.status}
                  </span>
                  <div id="org-status-actions" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
                  <span id="org-status-msg" class="org-form-msg" style="margin-left:4px;"></span>
                </div>
              </div>

              <!-- Uczestnicy -->
              <div id="org-participants-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:8px;">Uczestnicy</div>
                <div id="org-participants-list" class="org-participants-list">
                  <div class="org-loading">Ładowanie uczestników…</div>
                </div>
                <div class="org-add-row">
                  <div id="org-add-sng-wrap">
                    <div class="org-add-search-wrap">
                      <div class="org-add-input-wrap">
                        <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <input id="org-add-user-search" class="org-add-input" type="text"
                          placeholder="Szukaj uczestnika…" autocomplete="off">
                      </div>
                      <button id="org-add-user-btn" class="org-add-btn" type="button">+ Dodaj</button>
                    </div>
                    <div id="org-user-suggestions" class="org-sug-dropdown" style="display:none;"></div>
                  </div>
                </div>
                <span id="org-participant-msg" class="org-form-msg" style="margin-top:4px;display:block;"></span>
                <div id="org-close-reg-wrap" style="display:none; margin-top:12px; padding-top:12px; border-top:1px dashed var(--border);">
                  <button id="org-close-reg-btn" class="org-close-reg-btn" type="button">
                    <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zamknij zapisy i generuj drabinkę →
                  </button>
                  <span id="org-close-reg-msg" class="org-form-msg" style="margin-left:8px;"></span>
                </div>
              </div>

              <!-- Wyniki meczów drabinki -->
              <div class="org-matches-header">
                <div class="org-section-label">Wyniki meczów</div>
                <div class="org-matches-toolbar">
                  <div class="org-filter-group" id="org-filter-group">
                    <button class="org-filter-btn org-filter-btn--active" data-filter="pending">Do wpisania</button>
                    <button class="org-filter-btn" data-filter="done">Zakończone</button>
                    <button class="org-filter-btn" data-filter="all">Wszystkie</button>
                  </div>
                </div>
              </div>
              <div id="org-matches-list" class="org-matches-list-wrap">
                <div class="org-loading">Ładowanie meczów…</div>
              </div>

              <!-- Zakończ turniej -->
              <div id="org-finish-section" style="display:none; padding:0 20px 20px; border-top:1px solid var(--border); margin-top:8px; padding-top:16px;">
                <div class="org-section-label" style="margin-bottom:12px;">Zakończenie turnieju</div>
                <div id="org-finish-confirm" style="display:none;" class="org-finish-confirm-box">
                  <div id="org-finish-unplayed-warn" style="display:none;" class="org-finish-unplayed-warn"></div>
                  <p class="org-finish-confirm__msg">
                    Czy na pewno chcesz zakończyć turniej? Ranking zostanie automatycznie przeliczony. Tej akcji nie można cofnąć.
                  </p>
                  <div class="org-finish-confirm__actions">
                    <button id="org-finish-yes-btn" class="org-finish-btn org-finish-btn--danger">Tak, zakończ turniej</button>
                    <button id="org-finish-cancel-btn" class="org-finish-btn org-finish-btn--ghost">Anuluj</button>
                  </div>
                </div>
                <div id="org-finish-trigger-wrap">
                  <button id="org-finish-btn" class="org-finish-btn org-finish-btn--outline">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zakończ turniej
                  </button>
                  <span id="org-finish-msg" class="org-form-msg" style="margin-left:12px;"></span>
                </div>
              </div>

            </div>
          </div>

          <!-- SSR data dla JS -->
          {tournament && (
            <script id="ssr-matches-data" type="application/json" set:html={JSON.stringify(tournament.matches)} />
          )}
          {tournament && (
            <script id="ssr-participants-data" type="application/json" set:html={JSON.stringify(tournament.participants)} />
          )}

        </div>
      )}

      <!-- ── Americano — widok rund i tabeli punktów ───────────────────── -->
      {isAmericano && (
        <div class="td-layout">

          <!-- Stat pills -->
          <div class="td-stats">
            <div class="td-stat">
              <span class="td-stat__val">{tournament.participant_count}</span>
              <span class="td-stat__lbl">Uczestników</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{tournament.matches.length}</span>
              <span class="td-stat__lbl">Meczów</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{completedMatches.length}</span>
              <span class="td-stat__lbl">Rozegranych</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{pendingMatches.length}</span>
              <span class="td-stat__lbl">Pozostałych</span>
            </div>
          </div>

          <!-- ── Baner Mexicano (DYNAMIC only) ───────────────────────────── -->
          {isMexicano && (
            <div class="mexicano-banner">
              <span class="mexicano-banner__icon">⚡</span>
              <div class="mexicano-banner__body">
                <strong>Mexicano</strong> — parowanie dynamiczne
                {amrCurrentRound !== null && amrTotalRounds !== null && (
                  <span class="mexicano-banner__rounds">
                    &nbsp;· Runda <strong>{amrCurrentRound}</strong> / {amrTotalRounds}
                  </span>
                )}
                {amrCurrentRound === null && amrTotalRounds !== null && (
                  <span class="mexicano-banner__rounds">&nbsp;· {amrTotalRounds} rund łącznie</span>
                )}
              </div>
            </div>
          )}

          <!-- ── Dołącz do turnieju (self-registration) — AMR ───────────── -->
          {tournament.status === 'REG' && (
            <div id="join-panel" style="display:none;margin-bottom:24px;"
              data-tournament-id={tournament.id}
              data-tournament-status={tournament.status}>
              <div class="join-bar">
                <span class="join-bar__text">Rejestracja otwarta — dołącz do turnieju!</span>
                <button id="join-btn" class="tc-btn tc-btn-primary tc-btn-sm">Dołącz</button>
                <span id="join-msg" class="org-form-msg" style="margin-left:8px;"></span>
              </div>
            </div>
          )}

          <!-- Tabela punktów AMR — SSR, odświeżana przez JS po CMP -->
          <div class="tc-card" style="margin-bottom:24px;" id="amr-standings-card">
            <div class="tc-card-header">
              <span class="tc-card-title">Tabela punktów</span>
            </div>
            {tournament.standings && (tournament.standings as any[]).length > 0 ? (
              <div style="overflow-x:auto;">
                <table class="tc-table td-standings-table" id="amr-standings-table">
                  <thead>
                    <tr>
                      <th style="width:40px;">#</th>
                      <th>Gracz</th>
                      <th class="col-num">Punkty</th>
                      <th class="col-num">Mecze</th>
                    </tr>
                  </thead>
                  <tbody id="amr-standings-body">
                    {(tournament.standings as any[]).map((row, idx) => (
                      <tr class={idx === 0 && tournament.status === 'FIN' ? 'td-row--winner' : ''}>
                        <td>
                          <span class={`rank-pos${idx < 3 ? ` rank-pos--${idx + 1}` : ''}`}>{idx + 1}</span>
                        </td>
                        <td>
                          <div class="td-player">
                            <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                              {row.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                            </div>
                            <span class="td-player__name">{row.display_name}</span>
                            {idx === 0 && tournament.status === 'FIN' && <span class="td-winner-badge">🏆</span>}
                          </div>
                        </td>
                        <td class="col-num td-pts">{row.points}</td>
                        <td class="col-num col-muted">{row.matches_played}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="td-empty-section">
                <span>Tabela będzie widoczna po rozegraniu pierwszych meczów.</span>
              </div>
            )}
          </div>

          <!-- Lista uczestników -->
          {tournament.participants.length > 0 && (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Uczestnicy ({tournament.participant_count})</span>
              </div>
              <div class="td-participants">
                {tournament.participants.map(p => (
                  <div class="td-participant">
                    <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                      {p.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                    </div>
                    <span class="td-participant__name">{p.display_name}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Rundy z meczami — widok tabelkowy -->
          {tournament.matches.length > 0 ? (
            <div class="tc-card" style="margin-bottom:24px;" id="amr-matches-card">
              <div class="tc-card-header">
                <span class="tc-card-title">Mecze ({tournament.matches.length})</span>
                <span style="font-size:0.78rem; color:var(--text-dim);">
                  {completedMatches.length} rozegranych · {pendingMatches.length} pozostałych
                </span>
              </div>
              {rounds.map(roundNum => (
                <div class="td-round">
                  <div class="td-round__label">Runda {roundNum}</div>
                  <div class="td-round__matches">
                    {(matchesByRound.get(roundNum) ?? []).map(m => (
                      <div class={`td-match ${m.status === 'CMP' ? 'td-match--done' : ''}`}>
                        <div class="td-match__players">
                          <span class={`td-match__name ${m.winner_name === m.participant1_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant1_name ?? '—'}
                          </span>
                          <span class="td-match__vs">vs</span>
                          <span class={`td-match__name ${m.winner_name === m.participant2_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant2_name ?? '—'}
                          </span>
                        </div>
                        <div class="td-match__right">
                          {m.score ? (
                            <span class="td-match__score">{m.score}</span>
                          ) : m.status === 'WAI' ? (
                            <span class="td-match__status-lbl">Oczekuje</span>
                          ) : (
                            <span class="td-match__status-lbl">{MATCH_STATUS_LABEL[m.status] ?? m.status}</span>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Mecze pojawią się po zamknięciu rejestracji.</span>
            </div>
          )}

          <!-- ── Wpisz wynik — uczestnik meczu AMR ─────────────────────── -->
          <!-- Widoczny client-side przez IIFE tylko gdy user jest uczestnikiem meczu. -->
          {(tournament.status === 'ACT' || tournament.status === 'FIN') && (
            <div
              id="amr-player-score-panel"
              style="display:none;margin-bottom:24px;"
              data-tournament-id={tournament.id}
              data-tournament-status={tournament.status}
              data-tournament-type={tournament.tournament_type}
              data-points-per-match={tournament.config ? (tournament.config as any).points_per_match ?? 32 : 32}
            >
              <div class="tc-card">
                <div class="tc-card-header">
                  <span class="tc-card-title">Twoje mecze</span>
                  <span style="font-size:0.78rem;color:var(--text-dim);">Wpisz wyniki swoich meczów</span>
                </div>
                <div id="amr-player-matches-list"></div>
              </div>
            </div>
          )}

          <!-- SSR data dla IIFE gracza AMR -->
          {tournament && (
            <script id="amr-ssr-matches-data" type="application/json" set:html={JSON.stringify(tournament.matches)} />
          )}
          {tournament && (
            <script id="amr-ssr-participants-data" type="application/json" set:html={JSON.stringify(tournament.participants)} />
          )}

          <!-- Org-panel AMR -->
          <div
            id="org-panel"
            style="display:none;"
            data-tournament-id={tournament.id}
            data-created-by={tournament.created_by_username}
            data-tournament-status={tournament.status}
            data-tournament-type={tournament.tournament_type}
            data-match-format={tournament.match_format}
            data-sets-to-win="1"
            data-end-date={tournament.end_date ?? ''}
          >
            <div class="tc-card org-card">
              <div class="tc-card-header">
                <span class="tc-card-title">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:-2px;margin-right:6px;color:var(--primary);">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                  </svg>
                  Zarządzanie turniejem
                </span>
                <div style="display:flex;align-items:center;gap:8px;">
                  <a href={url('/tournaments/manage')} class="org-manage-link">
                    <svg width="11" height="11" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                    </svg>
                    Moje turnieje
                  </a>
                  <span class="tc-badge tc-badge-warning" style="font-size:0.72rem;">Organizator</span>
                </div>
              </div>

              <div id="org-locked-msg" style="display:none;" class="org-locked-notice">
                Turniej jest zakończony lub odwołany — edycja wyników jest zablokowana.
              </div>

              <!-- Status -->
              <div id="org-status-section" style="padding:0 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:10px;">Status turnieju</div>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                  <span id="org-status-badge" class="tc-badge tc-badge-neutral" style="font-size:0.8rem;">
                    {STATUS_LABEL[tournament.status] ?? tournament.status}
                  </span>
                  <div id="org-status-actions" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
                  <span id="org-status-msg" class="org-form-msg" style="margin-left:4px;"></span>
                </div>
              </div>

              <!-- Uczestnicy -->
              <div id="org-participants-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:8px;">Uczestnicy</div>
                <div id="org-participants-list" class="org-participants-list">
                  <div class="org-loading">Ładowanie uczestników…</div>
                </div>
                <div class="org-add-row">
                  <div id="org-add-sng-wrap">
                    <div class="org-add-search-wrap">
                      <div class="org-add-input-wrap">
                        <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <input id="org-add-user-search" class="org-add-input" type="text"
                          placeholder="Szukaj uczestnika…" autocomplete="off">
                      </div>
                      <button id="org-add-user-btn" class="org-add-btn" type="button">+ Dodaj</button>
                    </div>
                    <div id="org-user-suggestions" class="org-sug-dropdown" style="display:none;"></div>
                  </div>
                </div>
                <span id="org-participant-msg" class="org-form-msg" style="margin-top:4px;display:block;"></span>
                <div id="org-close-reg-wrap" style="display:none; margin-top:12px; padding-top:12px; border-top:1px dashed var(--border);">
                  <button id="org-close-reg-btn" class="org-close-reg-btn" type="button">
                    <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zamknij zapisy i generuj mecze →
                  </button>
                  <span id="org-close-reg-msg" class="org-form-msg" style="margin-left:8px;"></span>
                </div>
              </div>

              <!-- Konfiguracja AMR — widoczna tylko gdy DRF lub REG -->
              {(tournament.status === 'DRF' || tournament.status === 'REG') && (
                <div id="org-amr-config-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);">
                  <div class="org-section-label" style="margin-bottom:10px;">Konfiguracja Americano</div>
                  <form id="org-amr-config-form" style="display:flex; gap:16px; align-items:flex-end; flex-wrap:wrap;" novalidate>
                    <label class="org-field-label" style="flex:1; min-width:120px;">Liczba rund
                      <input class="org-field-input" type="number" id="amr-cfg-rounds"
                        name="number_of_rounds" min="1" max="99"
                        value={String(tournament.config?.number_of_rounds ?? 7)}>
                    </label>
                    <label class="org-field-label" style="flex:1; min-width:120px;">Punkty na mecz
                      <input class="org-field-input" type="number" id="amr-cfg-ppm"
                        name="points_per_match" min="1" max="999"
                        value={String(tournament.config?.points_per_match ?? 32)}>
                    </label>
                    <div style="display:flex; align-items:center; gap:8px; padding-bottom:2px;">
                      <button type="submit" class="org-save-btn" id="org-amr-cfg-save-btn">Zapisz</button>
                      <span class="org-form-msg" id="org-amr-cfg-msg"></span>
                    </div>
                  </form>
                  <p class="cr-hint" style="margin-top:8px;">Maks. liczba rund = liczba uczestników − 1. Dostępne tylko przed zamknięciem rejestracji.</p>
                </div>
              )}

              <!-- Mexicano — status rundy i fallback (tylko DYNAMIC + ACT) -->
              {isMexicano && tournament.status === 'ACT' && (
                <div id="mexicano-round-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);"
                  data-total-rounds={String(amrTotalRounds ?? '')}
                  data-current-round={String(amrCurrentRound ?? 0)}>
                  <div class="org-section-label" style="margin-bottom:10px;">Postęp Mexicano</div>
                  <div id="mexicano-round-status" class="mexicano-round-status">
                    <span id="mexicano-round-label" class="mexicano-round-label">Wczytywanie…</span>
                  </div>
                  <div id="mexicano-next-wrap" style="display:none; margin-top:12px;">
                    <button id="mexicano-next-btn" class="org-close-reg-btn" type="button" style="background:rgba(99,102,241,0.1);color:rgb(99,102,241);border-color:rgba(99,102,241,0.3);">
                      ⚡ Generuj następną rundę →
                    </button>
                    <span id="mexicano-next-msg" class="org-form-msg" style="margin-left:8px;"></span>
                  </div>
                  <div id="mexicano-last-round-note" style="display:none; margin-top:10px;" class="mexicano-last-note">
                    Ostatnia runda zakończona — możesz teraz zakończyć turniej.
                  </div>
                </div>
              )}

              <!-- Wyniki meczów -->
              <div class="org-matches-header">
                <div class="org-section-label">Wyniki meczów</div>
                <div class="org-matches-toolbar">
                  <div class="org-filter-group" id="org-filter-group">
                    <button class="org-filter-btn org-filter-btn--active" data-filter="pending">Do wpisania</button>
                    <button class="org-filter-btn" data-filter="done">Zakończone</button>
                    <button class="org-filter-btn" data-filter="all">Wszystkie</button>
                  </div>
                </div>
              </div>
              <div id="org-matches-list" class="org-matches-list-wrap">
                <div class="org-loading">Ładowanie meczów…</div>
              </div>

              <!-- Zakończ turniej -->
              <div id="org-finish-section" style="display:none; padding:0 20px 20px; border-top:1px solid var(--border); margin-top:8px; padding-top:16px;">
                <div class="org-section-label" style="margin-bottom:12px;">Zakończenie turnieju</div>
                <div id="org-finish-confirm" style="display:none;" class="org-finish-confirm-box">
                  <div id="org-finish-unplayed-warn" style="display:none;" class="org-finish-unplayed-warn"></div>
                  <p class="org-finish-confirm__msg">
                    Czy na pewno chcesz zakończyć turniej? Ranking zostanie automatycznie przeliczony. Tej akcji nie można cofnąć.
                  </p>
                  <div class="org-finish-confirm__actions">
                    <button id="org-finish-yes-btn" class="org-finish-btn org-finish-btn--danger">Tak, zakończ turniej</button>
                    <button id="org-finish-cancel-btn" class="org-finish-btn org-finish-btn--ghost">Anuluj</button>
                  </div>
                </div>
                <div id="org-finish-trigger-wrap">
                  <button id="org-finish-btn" class="org-finish-btn org-finish-btn--outline">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zakończ turniej
                  </button>
                  <span id="org-finish-msg" class="org-form-msg" style="margin-left:12px;"></span>
                </div>
              </div>

            </div>
          </div>

          <!-- SSR data dla JS -->
          {tournament && (
            <script id="ssr-matches-data" type="application/json" set:html={JSON.stringify(tournament.matches)} />
          )}
          {tournament && (
            <script id="ssr-participants-data" type="application/json" set:html={JSON.stringify(tournament.participants)} />
          )}

        </div>
      )}

      <!-- ── Round Robin — właściwy widok ───────────────────────────────── -->
      {isRoundRobin && (
        <div class="td-layout">

          <!-- Stat pills -->
          <div class="td-stats">
            <div class="td-stat">
              <span class="td-stat__val">{tournament.participant_count}</span>
              <span class="td-stat__lbl">Uczestników</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{tournament.matches.length}</span>
              <span class="td-stat__lbl">Meczów</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{completedMatches.length}</span>
              <span class="td-stat__lbl">Rozegranych</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{pendingMatches.length}</span>
              <span class="td-stat__lbl">Pozostałych</span>
            </div>
          </div>

          <!-- ── Dołącz do turnieju (self-registration) — RR ────────────── -->
          {tournament.status === 'REG' && (
            <div id="join-panel" style="display:none;margin-bottom:24px;"
              data-tournament-id={tournament.id}
              data-tournament-status={tournament.status}>
              <div class="join-bar">
                <span class="join-bar__text">Rejestracja otwarta — dołącz do turnieju!</span>
                <button id="join-btn" class="tc-btn tc-btn-primary tc-btn-sm">Dołącz</button>
                <span id="join-msg" class="org-form-msg" style="margin-left:8px;"></span>
              </div>
            </div>
          )}

          <!-- ── Tabela standings ────────────────────────────────────────── -->
          {tournament.standings && tournament.standings.length > 0 ? (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Tabela wyników</span>
                <span style="font-size:0.78rem; color:var(--text-dim);">Sortowanie: punkty → sety → gemy</span>
              </div>
              <div style="overflow-x:auto;">
                <table class="tc-table td-standings-table">
                  <thead>
                    <tr>
                      <th style="width:40px;">#</th>
                      <th>Gracz</th>
                      <th class="col-num">Pkt</th>
                      <th class="col-num">M</th>
                      <th class="col-num">W</th>
                      <th class="col-num">P</th>
                      <th class="col-num">Sety +/-</th>
                      <th class="col-num">Gemy +/-</th>
                    </tr>
                  </thead>
                  <tbody>
                    {(tournament.standings as RRStandingRow[]).map((row, idx) => (
                      <tr class={idx === 0 && tournament.status === 'FIN' ? 'td-row--winner' : ''}>
                        <td>
                          <span class={`rank-pos${idx < 3 ? ` rank-pos--${idx + 1}` : ''}`}>
                            {idx + 1}
                          </span>
                        </td>
                        <td>
                          <div class="td-player">
                            <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                              {row.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                            </div>
                            <span class="td-player__name">{row.display_name}</span>
                            {idx === 0 && tournament.status === 'FIN' && (
                              <span class="td-winner-badge">🏆</span>
                            )}
                          </div>
                        </td>
                        <td class="col-num td-pts">{Number(row.points).toFixed(1)}</td>
                        <td class="col-num col-muted">{row.matches_played}</td>
                        <td class="col-num" style="color:var(--primary);">{row.wins}</td>
                        <td class="col-num" style="color:var(--danger);">{row.losses}</td>
                        <td class="col-num col-muted">
                          {row.sets_won}:{row.sets_lost}
                          <span class={`td-diff ${row.sets_diff > 0 ? 'td-diff--pos' : row.sets_diff < 0 ? 'td-diff--neg' : ''}`}>
                            ({row.sets_diff > 0 ? '+' : ''}{row.sets_diff})
                          </span>
                        </td>
                        <td class="col-num col-muted">
                          {row.games_won}:{row.games_lost}
                          <span class={`td-diff ${row.games_diff > 0 ? 'td-diff--pos' : row.games_diff < 0 ? 'td-diff--neg' : ''}`}>
                            ({row.games_diff > 0 ? '+' : ''}{row.games_diff})
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ) : (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Brak wyników — tabela zostanie wypełniona po rozegraniu pierwszych meczów.</span>
            </div>
          )}

          <!-- ── Lista uczestników ──────────────────────────────────────── -->
          {tournament.participants.length > 0 && (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Uczestnicy ({tournament.participant_count})</span>
              </div>
              <div class="td-participants">
                {tournament.participants.map(p => (
                  <div class="td-participant">
                    <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                      {p.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                    </div>
                    <span class="td-participant__name">{p.display_name}</span>
                    {p.seed_number && (
                      <span class="td-seed">#{p.seed_number}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── Mecze wg rund ──────────────────────────────────────────── -->
          {tournament.matches.length > 0 ? (
            <div class="tc-card" style="margin-bottom:24px;" id="matches-card">
              <div class="tc-card-header">
                <span class="tc-card-title">Mecze ({tournament.matches.length})</span>
                <div style="display:flex;align-items:center;gap:12px;">
                  <span style="font-size:0.78rem; color:var(--text-dim);">
                    {completedMatches.length} rozegranych · {pendingMatches.length} pozostałych
                  </span>
                  <div class="view-toggle" id="matches-view-toggle">
                    <button class="view-toggle__btn view-toggle__btn--active" data-view="list" title="Lista">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="1" width="16" height="2.5" rx="1"/><rect x="0" y="6.75" width="16" height="2.5" rx="1"/><rect x="0" y="12.5" width="16" height="2.5" rx="1"/></svg>
                    </button>
                    <button class="view-toggle__btn" data-view="matrix" title="Macierz">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/><rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/></svg>
                    </button>
                  </div>
                </div>
              </div>

              {rounds.map(roundNum => (
                <div class="td-round">
                  <div class="td-round__label">Runda {roundNum}</div>
                  <div class="td-round__matches">
                    {(matchesByRound.get(roundNum) ?? []).map(m => (
                      <div class={`td-match ${m.status === 'CMP' ? 'td-match--done' : ''} ${m.status === 'INP' ? 'td-match--live' : ''}`}>
                        <div class="td-match__players">
                          <span class={`td-match__name ${m.winner_name === m.participant1_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant1_name ?? '—'}
                          </span>
                          <span class="td-match__vs">vs</span>
                          <span class={`td-match__name ${m.winner_name === m.participant2_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant2_name ?? '—'}
                          </span>
                        </div>
                        <div class="td-match__right">
                          {m.score ? (
                            <span class="td-match__score">{m.score}</span>
                          ) : m.status === 'WAI' ? (
                            <span class="td-match__status-lbl">Oczekuje</span>
                          ) : m.status === 'INP' ? (
                            <span class="td-match__status-lbl td-match__status-lbl--live">● Live</span>
                          ) : (
                            <span class="td-match__status-lbl">{MATCH_STATUS_LABEL[m.status] ?? m.status}</span>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <!-- Widok macierzy (ukryty domyślnie, wypełniany przez JS) -->
            <div id="rr-matrix-wrap" class="tc-card rr-matrix-card" style="display:none; margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Tabela ligowa</span>
                <div class="rr-matrix-legend">
                  <span class="rr-matrix-legend__item rr-matrix-legend__item--win">W wygrana</span>
                  <span class="rr-matrix-legend__item rr-matrix-legend__item--loss">P przegrana</span>
                  <span class="rr-matrix-legend__item rr-matrix-legend__item--draw">R remis</span>
                  <span class="rr-matrix-legend__item rr-matrix-legend__item--pending">— brak</span>
                  <span class="rr-matrix-legend__sep">·</span>
                  <span class="rr-matrix-legend__note">wynik z perspektywy gracza w wierszu →</span>
                </div>
              </div>
              <div class="rr-matrix-scroll-hint">← przewiń →</div>
              <div class="rr-matrix-scroll-wrap">
                <div id="rr-matrix-inner"></div>
              </div>
            </div>

            </div>
          ) : (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Brak zaplanowanych meczów. Mecze pojawią się po zamknięciu rejestracji.</span>
            </div>
          )}

          <!-- ── Wpisz wynik — uczestnik meczu RR ─────────────────────── -->
          <!-- Widoczny client-side przez IIFE tylko gdy user jest uczestnikiem meczu. -->
          {(tournament.status === 'ACT' || tournament.status === 'FIN') && (
            <div
              id="player-score-panel"
              style="display:none;margin-bottom:24px;"
              data-tournament-id={tournament.id}
              data-tournament-status={tournament.status}
              data-tournament-type={tournament.tournament_type}
            >
              <div class="tc-card">
                <div class="tc-card-header">
                  <span class="tc-card-title">Twoje mecze</span>
                  <span style="font-size:0.78rem;color:var(--text-dim);">Wpisz wyniki swoich meczów</span>
                </div>
                <div id="player-matches-list"></div>
              </div>
            </div>
          )}

          <!-- ── Zarządzanie (organizer) ───────────────────────────────── -->
          <!-- Sekcja widoczna tylko dla is_staff i organizatora turnieju.
               Sprawdzamy uprawnienia client-side przez /api/auth/me/.
               Turniej nie może być Zakończony (FIN) ani Odwołany (CNC). -->
          <div
            id="org-panel"
            style="display:none;"
            data-tournament-id={tournament.id}
            data-created-by={tournament.created_by_username}
            data-tournament-status={tournament.status}
            data-tournament-type={tournament.tournament_type}
            data-match-format={tournament.match_format}
            data-sets-to-win={tournament.config?.sets_to_win ?? 2}
            data-end-date={tournament.end_date ?? ''}
          >
            <div class="tc-card org-card">
              <div class="tc-card-header">
                <span class="tc-card-title">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:-2px;margin-right:6px;color:var(--primary);">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                  </svg>
                  Zarządzanie turniejem
                </span>
                <div style="display:flex;align-items:center;gap:8px;">
                  <a href={url('/tournaments/manage')} class="org-manage-link">
                    <svg width="11" height="11" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
                    </svg>
                    Moje turnieje
                  </a>
                  <span class="tc-badge tc-badge-warning" style="font-size:0.72rem;">Organizator</span>
                </div>
              </div>

              <!-- Komunikat gdy turniej FIN/CNC -->
              <div id="org-locked-msg" style="display:none;" class="org-locked-notice">
                Turniej jest zakończony lub odwołany — edycja wyników jest zablokowana.
              </div>

              <!-- ── Status turnieju ──────────────────────────────────────── -->
              <div id="org-status-section" style="padding:0 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:10px;">Status turnieju</div>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                  <span id="org-status-badge" class="tc-badge tc-badge-neutral" style="font-size:0.8rem;">
                    {STATUS_LABEL[tournament.status] ?? tournament.status}
                  </span>
                  <div id="org-status-actions" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
                  <span id="org-status-msg" class="org-form-msg" style="margin-left:4px;"></span>
                </div>
              </div>

              <!-- ── Uczestnicy ───────────────────────────────────────────── -->
              <div id="org-participants-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:8px;">Uczestnicy</div>
                <div id="org-participants-list" class="org-participants-list">
                  <div class="org-loading">Ładowanie uczestników…</div>
                </div>
                <!-- Add participant row — zawsze widoczny pod listą -->
                <div class="org-add-row">
                  <!-- Singiel: jedno pole wyszukiwania -->
                  <div id="org-add-sng-wrap">
                    <div class="org-add-search-wrap">
                      <div class="org-add-input-wrap">
                        <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        <input id="org-add-user-search" class="org-add-input" type="text"
                          placeholder="Szukaj uczestnika…" autocomplete="off">
                      </div>
                      <button id="org-add-user-btn" class="org-add-btn" type="button">
                        + Dodaj
                      </button>
                    </div>
                    <div id="org-user-suggestions" class="org-sug-dropdown" style="display:none;"></div>
                  </div>

                  <!-- Debel: dwa pola + nazwa pary (widoczne gdy match_format=DBL) -->
                  <div id="org-add-dbl-row" style="display:none;">
                    <div class="org-dbl-players-row">
                      <div class="org-dbl-player-col">
                        <div class="org-dbl-player-label">Gracz 1 (kapitan)</div>
                        <div class="org-add-input-wrap">
                          <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                          </svg>
                          <input id="org-add-p1-search" class="org-add-input" type="text"
                            placeholder="Szukaj gracza 1…" autocomplete="off">
                        </div>
                        <div id="org-p1-suggestions" class="org-sug-dropdown" style="display:none;"></div>
                      </div>
                      <div class="org-dbl-sep" aria-hidden="true">/</div>
                      <div class="org-dbl-player-col">
                        <div class="org-dbl-player-label">Gracz 2 (partner)</div>
                        <div class="org-add-input-wrap">
                          <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                          </svg>
                          <input id="org-add-p2-search" class="org-add-input" type="text"
                            placeholder="Szukaj gracza 2…" autocomplete="off">
                        </div>
                        <div id="org-p2-suggestions" class="org-sug-dropdown" style="display:none;"></div>
                      </div>
                    </div>
                    <div class="org-dbl-name-row">
                      <label class="org-dbl-name-label" for="org-add-dbl-name">Nazwa pary</label>
                      <input id="org-add-dbl-name" class="org-add-input" type="text"
                        placeholder="np. Kowalski / Nowak (uzupełniane automatycznie)"
                        style="width:100%;" autocomplete="off">
                      <span class="org-dbl-name-hint">Możesz zmienić nazwę ręcznie</span>
                    </div>
                    <div style="margin-top:8px;">
                      <button id="org-add-dbl-btn" class="org-add-btn" type="button">
                        + Dodaj parę
                      </button>
                    </div>
                  </div>
                </div>
                <span id="org-participant-msg" class="org-form-msg" style="margin-top:4px;display:block;"></span>
                <!-- Skrót: Zamknij zapisy (widoczny tylko gdy status REG i są min. 2 uczestników) -->
                <div id="org-close-reg-wrap" style="display:none; margin-top:12px; padding-top:12px; border-top:1px dashed var(--border);">
                  <button id="org-close-reg-btn" class="org-close-reg-btn" type="button">
                    <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zamknij zapisy i generuj mecze →
                  </button>
                  <span id="org-close-reg-msg" class="org-form-msg" style="margin-left:8px;"></span>
                </div>
              </div>

              <!-- Tabela standings (odświeżana) -->
              <div style="padding:0 20px 4px;">
                <div class="org-section-label">Tabela ligowa</div>
              </div>
              <div style="overflow-x:auto;">
                <table class="tc-table td-standings-table" id="org-standings-table">
                  <thead>
                    <tr>
                      <th style="width:36px;">#</th>
                      <th>Gracz</th>
                      <th class="col-num">Pkt</th>
                      <th class="col-num">M</th>
                      <th class="col-num">W</th>
                      <th class="col-num">P</th>
                      <th class="col-num">Wr%</th>
                      <th class="col-num">Sety</th>
                    </tr>
                  </thead>
                  <tbody id="org-standings-body">
                    <tr><td colspan="8" class="org-loading">Ładowanie tabeli…</td></tr>
                  </tbody>
                </table>
              </div>

              <!-- Lista meczów do wpisania wyników -->
              <div class="org-matches-header">
                <div class="org-section-label">Wyniki meczów</div>
                <div class="org-matches-toolbar">
                  <div class="org-filter-group" id="org-filter-group">
                    <button class="org-filter-btn org-filter-btn--active" data-filter="pending">Do wpisania</button>
                    <button class="org-filter-btn" data-filter="done">Zakończone</button>
                    <button class="org-filter-btn" data-filter="all">Wszystkie</button>
                  </div>
                  <div class="org-search-wrap">
                    <input id="org-match-search" class="org-search-input" type="text" placeholder="Szukaj zawodnika…" autocomplete="off">
                  </div>
                </div>
              </div>
              <div id="org-matches-list" class="org-matches-list-wrap">
                <div class="org-loading">Ładowanie meczów…</div>
              </div>

              <!-- Konfiguracja RR (edycja) -->
              <div style="padding:16px 20px 4px;">
                <div class="org-section-label">Konfiguracja punktacji</div>
              </div>
              <form id="org-config-form" style="padding:0 20px 20px;" novalidate>
                <div class="org-config-grid">

                  <div class="org-config-group">
                    <div class="org-config-group-label">Ogólne</div>
                    <label class="org-field-label">Maks. uczestników
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="max_participants" min="2" max="128" step="1">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label" id="lbl-sets-to-win">Sety do wygrania meczu
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="sets_to_win" min="1" max="5" step="1">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label" id="lbl-games-per-set">Gemy do wygrania seta
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="games_per_set" min="1" max="21" step="1">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label">Tie-breaker (remis punktowy)
                      <select class="org-field-input org-field-select" name="tie_breaker_priority">
                        <option value="SETS">Bilans setów</option>
                        <option value="GAMES">Bilans gemów</option>
                        <option value="HEAD">Bezpośrednie spotkanie</option>
                      </select>
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za mecz</div>
                    <label class="org-field-label">Za wygraną
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_win" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label">Za przegraną
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_loss" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za sety</div>
                    <label class="org-field-label">Za wygrany set
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_set_win" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label">Za przegrany set
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_set_loss" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za gemy</div>
                    <label class="org-field-label">Za wygrany gem
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_gem_win" min="-100" max="100" step="0.1">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label">Za przegrany gem
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_gem_loss" min="-100" max="100" step="0.1">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Super tie-break</div>
                    <label class="org-field-label">Za wygrany punkt (STB)
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_supertiebreak_win" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                    <label class="org-field-label">Za przegrany punkt (STB)
                      <div class="org-score-spinner">
                        <button type="button" class="org-spin-btn org-spin-up org-cfg-spin" tabindex="-1">▲</button>
                        <input class="org-set-input org-cfg-input" type="number" name="points_for_supertiebreak_loss" min="-100" max="100" step="0.5">
                        <button type="button" class="org-spin-btn org-spin-down org-cfg-spin" tabindex="-1">▼</button>
                      </div>
                    </label>
                  </div>

                </div>

                <div class="org-form-actions" style="margin-top:12px;">
                  <button type="submit" class="org-save-btn" id="org-config-save-btn">Zapisz konfigurację</button>
                  <span class="org-form-msg" id="org-config-msg"></span>
                </div>
              </form>

              <!-- Zakończ turniej — widoczny tylko gdy status ACT -->
              <div id="org-finish-section" style="display:none; padding:0 20px 20px; border-top:1px solid var(--border); margin-top:8px; padding-top:16px;">
                <div class="org-section-label" style="margin-bottom:12px;">Zakończenie turnieju</div>
                <div id="org-finish-confirm" style="display:none;" class="org-finish-confirm-box">
                  <div id="org-finish-unplayed-warn" style="display:none;" class="org-finish-unplayed-warn"></div>
                  <p class="org-finish-confirm__msg">
                    Czy na pewno chcesz zakończyć turniej? Ranking zostanie automatycznie przeliczony. Tej akcji nie można cofnąć.
                  </p>
                  <div class="org-finish-confirm__actions">
                    <button id="org-finish-yes-btn" class="org-finish-btn org-finish-btn--danger">
                      Tak, zakończ turniej
                    </button>
                    <button id="org-finish-cancel-btn" class="org-finish-btn org-finish-btn--ghost">
                      Anuluj
                    </button>
                  </div>
                </div>
                <div id="org-finish-trigger-wrap">
                  <button id="org-finish-btn" class="org-finish-btn org-finish-btn--outline">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zakończ turniej
                  </button>
                  <span id="org-finish-msg" class="org-form-msg" style="margin-left:12px;"></span>
                </div>
              </div>

            </div>
          </div>

          <!-- Dane meczów, uczestników i config dla org-panel JS (SSR JSON) -->
          {tournament && (
            <script id="ssr-matches-data" type="application/json" set:html={JSON.stringify(tournament.matches)} />
          )}
          {tournament && (
            <script id="ssr-participants-data" type="application/json" set:html={JSON.stringify(tournament.participants)} />
          )}
          {tournament?.config && (
            <script id="ssr-config-data" type="application/json" set:html={JSON.stringify(tournament.config)} />
          )}

          <!-- ── Konfiguracja (zwijana) ─────────────────────────────────── -->
          {tournament.config && (
            <details class="tc-card td-config-card">
              <summary class="tc-card-header" style="cursor:pointer; list-style:none;">
                <span class="tc-card-title">Zasady i punktacja</span>
                <span style="font-size:0.78rem; color:var(--text-dim);">▾ rozwiń</span>
              </summary>
              <div class="td-config-body">
                <div class="td-config-grid">
                  <div>
                    <div class="td-config-row"><span>Format meczu</span><strong>Do {tournament.config.sets_to_win} wygranych setów</strong></div>
                    <div class="td-config-row"><span>Format seta</span><strong>Do {tournament.config.games_per_set} gemów</strong></div>
