---
// tournaments/[id].astro — szczegół turnieju
// Obsługuje tylko Round Robin (tournament_type === 'RND').
// Inne typy → komunikat "nie obsługiwany jeszcze w Astro".
// Endpoint: GET /api/tournaments/{id}/detail/

import AppLayout from '@/layouts/AppLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getTournamentsList, getTournamentDetail, type TournamentDetail, type RRStandingRow, type TournamentMatch } from '@/lib/api';

export async function getStaticPaths() {
  try {
    const list = await getTournamentsList();
    return list.map(t => ({ params: { id: String(t.id) } }));
  } catch {
    // Baza pusta lub API niedostepne — brak stron do wygenerowania
    return [];
  }
}

const { id } = Astro.params;
const tournamentId = id ? parseInt(id, 10) : NaN;

// ── Pobierz dane ──────────────────────────────────────────────────────────────
let tournament: TournamentDetail | null = null;
let fetchError: string | null = null;

if (!isNaN(tournamentId)) {
  try {
    tournament = await getTournamentDetail(tournamentId);
    if (!tournament) fetchError = 'not_found';
  } catch (e) {
    fetchError = 'api_error';
    console.error('[tournament/[id]] fetch failed:', e);
  }
} else {
  fetchError = 'bad_id';
}

// ── Stałe ─────────────────────────────────────────────────────────────────────
const STATUS_LABEL: Record<string, string> = {
  DRF: 'Szkic', REG: 'Rejestracja', SCH: 'Zaplanowany',
  ACT: 'Trwa', FIN: 'Zakończony', CNC: 'Odwołany',
};
const STATUS_BADGE: Record<string, string> = {
  DRF: 'tc-badge-neutral', REG: 'tc-badge-success', SCH: 'tc-badge-info',
  ACT: 'tc-badge-warning',  FIN: 'tc-badge-neutral', CNC: 'tc-badge-neutral',
};
const FORMAT_LABEL: Record<string, string> = { SNG: 'Singiel', DBL: 'Debel' };
const MATCH_STATUS_LABEL: Record<string, string> = {
  WAI: 'Oczekuje', SCH: 'Zaplanowany', INP: 'W trakcie',
  CMP: 'Zakończony', WDR: 'Walkower', CNC: 'Odwołany',
};
const TIE_LABEL: Record<string, string> = {
  HEAD: 'Bezpośrednie spotkanie', SETS: 'Bilans setów', GAMES: 'Bilans gemów',
};

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleDateString('pl-PL', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch { return iso; }
}

// Grupuj mecze wg rundy
function groupByRound(matches: TournamentMatch[]): Map<number, TournamentMatch[]> {
  const map = new Map<number, TournamentMatch[]>();
  for (const m of matches) {
    if (!map.has(m.round_number)) map.set(m.round_number, []);
    map.get(m.round_number)!.push(m);
  }
  return map;
}

const isRoundRobin = tournament?.tournament_type === 'RND';
const matchesByRound = tournament && isRoundRobin ? groupByRound(tournament.matches) : new Map();
const rounds = Array.from(matchesByRound.keys()).sort((a, b) => a - b);

const completedMatches = tournament?.matches.filter(m => m.status === 'CMP') ?? [];
const pendingMatches   = tournament?.matches.filter(m => m.status !== 'CMP' && m.status !== 'WDR' && m.status !== 'CNC') ?? [];
---

<AppLayout
  title={tournament?.name ?? 'Turniej'}
  greeting="Turnieje"
  showSearch={false}
  showCta={false}
>

  <!-- Breadcrumb -->
  <nav class="td-breadcrumb" aria-label="Nawigacja">
    <a href="/tournaments">← Turnieje</a>
    {tournament && <span aria-hidden="true"> / </span>}
    {tournament && <span>{tournament.name}</span>}
  </nav>

  <!-- ── Błędy ─────────────────────────────────────────────────────────────── -->
  {fetchError === 'not_found' && (
    <div class="td-error-card">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
      <p>Turniej o ID <strong>{id}</strong> nie istnieje.</p>
      <a href="/tournaments" class="tc-btn tc-btn-secondary tc-btn-sm">← Powrót do listy</a>
    </div>
  )}

  {fetchError === 'api_error' && (
    <div class="td-error-card">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      <p>Błąd połączenia z API.</p>
      <a href="/tournaments" class="tc-btn tc-btn-secondary tc-btn-sm">← Powrót do listy</a>
    </div>
  )}

  <!-- ── Turniej znaleziony ─────────────────────────────────────────────────── -->
  {tournament && (
    <>
      <PageHeader
        eyebrow="Rozgrywki"
        title={tournament.name}
        subtitle={tournament.description || `${FORMAT_LABEL[tournament.match_format] ?? tournament.match_format} · Liga (każdy z każdym)`}
      />

      <!-- Header info row -->
      <div class="td-info-row">
        <div class="td-info-badges">
          <span class={`tc-badge ${STATUS_BADGE[tournament.status] ?? 'tc-badge-neutral'}`}>
            {STATUS_LABEL[tournament.status] ?? tournament.status}
          </span>
          <span class="tc-badge tc-badge-primary">Liga (Round Robin)</span>
          <span class="tc-badge tc-badge-neutral">{FORMAT_LABEL[tournament.match_format] ?? tournament.match_format}</span>
          {tournament.rank === 1 && <span class="tc-badge" style="background:rgba(245,158,11,0.12);color:#f59e0b;">★ Ranga 1</span>}
        </div>
        <div class="td-info-meta">
          {(tournament.start_date || tournament.end_date) && (
            <span class="td-meta-item">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
              {fmtDate(tournament.start_date)}{tournament.end_date ? ` – ${fmtDate(tournament.end_date)}` : ''}
            </span>
          )}
          {tournament.facility_name && (
            <span class="td-meta-item">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {tournament.facility_name}
            </span>
          )}
          <span class="td-meta-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
              {tournament.participant_count} uczestników
            </span>
          </span>
        </div>
      </div>

      <!-- ── Nie Round Robin → komunikat ──────────────────────────────────── -->
      {!isRoundRobin && (
        <div class="td-unsupported">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <p>Ten typ szczegółu nie jest jeszcze obsługiwany w Astro.</p>
          <span>Obsługiwany typ: <strong>Round Robin</strong>. Ten turniej ma typ: <strong>{tournament.tournament_type}</strong>.</span>
          <a href={`http://localhost:8000/tournaments/`} class="tc-btn tc-btn-ghost tc-btn-sm" target="_blank" rel="noopener">Otwórz w Django →</a>
        </div>
      )}

      <!-- ── Round Robin — właściwy widok ───────────────────────────────── -->
      {isRoundRobin && (
        <div class="td-layout">

          <!-- Stat pills -->
          <div class="td-stats">
            <div class="td-stat">
              <span class="td-stat__val">{tournament.participant_count}</span>
              <span class="td-stat__lbl">Uczestników</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{tournament.matches.length}</span>
              <span class="td-stat__lbl">Meczów</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{completedMatches.length}</span>
              <span class="td-stat__lbl">Rozegranych</span>
            </div>
            <div class="td-stat">
              <span class="td-stat__val">{pendingMatches.length}</span>
              <span class="td-stat__lbl">Pozostałych</span>
            </div>
          </div>

          <!-- ── Tabela standings ────────────────────────────────────────── -->
          {tournament.standings && tournament.standings.length > 0 ? (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Tabela wyników</span>
                <span style="font-size:0.78rem; color:var(--text-dim);">Sortowanie: punkty → sety → gemy</span>
              </div>
              <div style="overflow-x:auto;">
                <table class="tc-table td-standings-table">
                  <thead>
                    <tr>
                      <th style="width:40px;">#</th>
                      <th>Gracz</th>
                      <th class="col-num">Pkt</th>
                      <th class="col-num">M</th>
                      <th class="col-num">W</th>
                      <th class="col-num">P</th>
                      <th class="col-num">Sety +/-</th>
                      <th class="col-num">Gemy +/-</th>
                    </tr>
                  </thead>
                  <tbody>
                    {(tournament.standings as RRStandingRow[]).map((row, idx) => (
                      <tr class={idx === 0 && tournament.status === 'FIN' ? 'td-row--winner' : ''}>
                        <td>
                          <span class={`rank-pos${idx < 3 ? ` rank-pos--${idx + 1}` : ''}`}>
                            {idx + 1}
                          </span>
                        </td>
                        <td>
                          <div class="td-player">
                            <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                              {row.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                            </div>
                            <span class="td-player__name">{row.display_name}</span>
                            {idx === 0 && tournament.status === 'FIN' && (
                              <span class="td-winner-badge">🏆</span>
                            )}
                          </div>
                        </td>
                        <td class="col-num td-pts">{row.points.toFixed(1)}</td>
                        <td class="col-num col-muted">{row.matches_played}</td>
                        <td class="col-num" style="color:var(--primary);">{row.wins}</td>
                        <td class="col-num" style="color:var(--danger);">{row.losses}</td>
                        <td class="col-num col-muted">
                          {row.sets_won}:{row.sets_lost}
                          <span class={`td-diff ${row.sets_diff > 0 ? 'td-diff--pos' : row.sets_diff < 0 ? 'td-diff--neg' : ''}`}>
                            ({row.sets_diff > 0 ? '+' : ''}{row.sets_diff})
                          </span>
                        </td>
                        <td class="col-num col-muted">
                          {row.games_won}:{row.games_lost}
                          <span class={`td-diff ${row.games_diff > 0 ? 'td-diff--pos' : row.games_diff < 0 ? 'td-diff--neg' : ''}`}>
                            ({row.games_diff > 0 ? '+' : ''}{row.games_diff})
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ) : (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Brak wyników — tabela zostanie wypełniona po rozegraniu pierwszych meczów.</span>
            </div>
          )}

          <!-- ── Lista uczestników ──────────────────────────────────────── -->
          {tournament.participants.length > 0 && (
            <div class="tc-card" style="margin-bottom:24px;">
              <div class="tc-card-header">
                <span class="tc-card-title">Uczestnicy ({tournament.participant_count})</span>
              </div>
              <div class="td-participants">
                {tournament.participants.map(p => (
                  <div class="td-participant">
                    <div class="tc-avatar tc-avatar-sm" aria-hidden="true">
                      {p.display_name.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('')}
                    </div>
                    <span class="td-participant__name">{p.display_name}</span>
                    {p.seed_number && (
                      <span class="td-seed">#{p.seed_number}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── Mecze wg rund ──────────────────────────────────────────── -->
          {tournament.matches.length > 0 ? (
            <div class="tc-card" style="margin-bottom:24px;" id="matches-card">
              <div class="tc-card-header">
                <span class="tc-card-title">Mecze ({tournament.matches.length})</span>
                <div style="display:flex;align-items:center;gap:12px;">
                  <span style="font-size:0.78rem; color:var(--text-dim);">
                    {completedMatches.length} rozegranych · {pendingMatches.length} pozostałych
                  </span>
                  <div class="view-toggle" id="matches-view-toggle">
                    <button class="view-toggle__btn view-toggle__btn--active" data-view="list" title="Lista">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="1" width="16" height="2.5" rx="1"/><rect x="0" y="6.75" width="16" height="2.5" rx="1"/><rect x="0" y="12.5" width="16" height="2.5" rx="1"/></svg>
                    </button>
                    <button class="view-toggle__btn" data-view="matrix" title="Macierz">
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/><rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/></svg>
                    </button>
                  </div>
                </div>
              </div>

              {rounds.map(roundNum => (
                <div class="td-round">
                  <div class="td-round__label">Runda {roundNum}</div>
                  <div class="td-round__matches">
                    {(matchesByRound.get(roundNum) ?? []).map(m => (
                      <div class={`td-match ${m.status === 'CMP' ? 'td-match--done' : ''} ${m.status === 'INP' ? 'td-match--live' : ''}`}>
                        <div class="td-match__players">
                          <span class={`td-match__name ${m.winner_name === m.participant1_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant1_name ?? '—'}
                          </span>
                          <span class="td-match__vs">vs</span>
                          <span class={`td-match__name ${m.winner_name === m.participant2_name && m.status === 'CMP' ? 'td-match__name--winner' : ''}`}>
                            {m.participant2_name ?? '—'}
                          </span>
                        </div>
                        <div class="td-match__right">
                          {m.score ? (
                            <span class="td-match__score">{m.score}</span>
                          ) : m.status === 'WAI' ? (
                            <span class="td-match__status-lbl">Oczekuje</span>
                          ) : m.status === 'INP' ? (
                            <span class="td-match__status-lbl td-match__status-lbl--live">● Live</span>
                          ) : (
                            <span class="td-match__status-lbl">{MATCH_STATUS_LABEL[m.status] ?? m.status}</span>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <!-- Widok macierzy (ukryty domyślnie, wypełniany przez JS) -->
            <div id="rr-matrix-wrap" style="display:none; overflow-x:auto; padding:0 0 16px;">
              <div id="rr-matrix-inner" style="padding:0 16px;"></div>
            </div>

            </div>
          ) : (
            <div class="tc-card td-empty-section" style="margin-bottom:24px;">
              <span>Brak zaplanowanych meczów. Mecze pojawią się po zamknięciu rejestracji.</span>
            </div>
          )}

          <!-- ── Zarządzanie (organizer) ───────────────────────────────── -->
          <!-- Sekcja widoczna tylko dla is_staff i organizatora turnieju.
               Sprawdzamy uprawnienia client-side przez /api/auth/me/.
               Turniej nie może być Zakończony (FIN) ani Odwołany (CNC). -->
          <div
            id="org-panel"
            style="display:none;"
            data-tournament-id={tournament.id}
            data-created-by={tournament.created_by_username}
            data-tournament-status={tournament.status}
            data-sets-to-win={tournament.config?.sets_to_win ?? 2}
            data-end-date={tournament.end_date ?? ''}
          >
            <div class="tc-card org-card">
              <div class="tc-card-header">
                <span class="tc-card-title">
                  <svg width="15" height="15" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="display:inline-block;vertical-align:-2px;margin-right:6px;color:var(--primary);">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                  </svg>
                  Zarządzanie turniejem
                </span>
                <span class="tc-badge tc-badge-warning" style="font-size:0.72rem;">Organizator</span>
              </div>

              <!-- Komunikat gdy turniej FIN/CNC -->
              <div id="org-locked-msg" style="display:none;" class="org-locked-notice">
                Turniej jest zakończony lub odwołany — edycja wyników jest zablokowana.
              </div>

              <!-- ── Status turnieju ──────────────────────────────────────── -->
              <div id="org-status-section" style="padding:0 20px 16px; border-bottom:1px solid var(--border);">
                <div class="org-section-label" style="margin-bottom:10px;">Status turnieju</div>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                  <span id="org-status-badge" class="tc-badge tc-badge-neutral" style="font-size:0.8rem;">
                    {STATUS_LABEL[tournament.status] ?? tournament.status}
                  </span>
                  <div id="org-status-actions" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
                  <span id="org-status-msg" class="org-form-msg" style="margin-left:4px;"></span>
                </div>
              </div>

              <!-- ── Uczestnicy ───────────────────────────────────────────── -->
              <div id="org-participants-section" style="padding:12px 20px 16px; border-bottom:1px solid var(--border);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;">
                  <div class="org-section-label" style="margin-bottom:0;">Uczestnicy</div>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <input id="org-add-user-search" class="org-search-input" type="text"
                      placeholder="Szukaj użytkownika…" autocomplete="off"
                      style="width:180px;">
                    <button id="org-add-user-btn" class="org-save-btn" style="white-space:nowrap;" type="button">
                      + Dodaj
                    </button>
                  </div>
                </div>
                <div id="org-user-suggestions" style="display:none; position:relative;"></div>
                <div id="org-participants-list" class="org-participants-list">
                  <div class="org-loading">Ładowanie uczestników…</div>
                </div>
                <span id="org-participant-msg" class="org-form-msg" style="margin-top:6px;display:block;"></span>
              </div>

              <!-- Tabela standings (odświeżana) -->
              <div style="padding:0 20px 4px;">
                <div class="org-section-label">Tabela ligowa</div>
              </div>
              <div style="overflow-x:auto;">
                <table class="tc-table td-standings-table" id="org-standings-table">
                  <thead>
                    <tr>
                      <th style="width:36px;">#</th>
                      <th>Gracz</th>
                      <th class="col-num">Pkt</th>
                      <th class="col-num">M</th>
                      <th class="col-num">W</th>
                      <th class="col-num">P</th>
                      <th class="col-num">Wr%</th>
                      <th class="col-num">Sety</th>
                    </tr>
                  </thead>
                  <tbody id="org-standings-body">
                    <tr><td colspan="8" class="org-loading">Ładowanie tabeli…</td></tr>
                  </tbody>
                </table>
              </div>

              <!-- Lista meczów do wpisania wyników -->
              <div class="org-matches-header">
                <div class="org-section-label">Wyniki meczów</div>
                <div class="org-matches-toolbar">
                  <div class="org-filter-group" id="org-filter-group">
                    <button class="org-filter-btn org-filter-btn--active" data-filter="pending">Do wpisania</button>
                    <button class="org-filter-btn" data-filter="done">Zakończone</button>
                    <button class="org-filter-btn" data-filter="all">Wszystkie</button>
                  </div>
                  <div class="org-search-wrap">
                    <input id="org-match-search" class="org-search-input" type="text" placeholder="Szukaj zawodnika…" autocomplete="off">
                  </div>
                </div>
              </div>
              <div id="org-matches-list" class="org-matches-list-wrap">
                <div class="org-loading">Ładowanie meczów…</div>
              </div>

              <!-- Konfiguracja RR (edycja) -->
              <div style="padding:16px 20px 4px;">
                <div class="org-section-label">Konfiguracja punktacji</div>
              </div>
              <form id="org-config-form" style="padding:0 20px 20px;" novalidate>
                <div class="org-config-grid">

                  <div class="org-config-group">
                    <div class="org-config-group-label">Ogólne</div>
                    <label class="org-field-label">Maks. uczestników
                      <input class="org-field-input" type="number" name="max_participants" min="2" max="128" step="1">
                    </label>
                    <label class="org-field-label" id="lbl-sets-to-win">Sety do wygrania meczu
                      <input class="org-field-input" type="number" name="sets_to_win" min="1" max="5" step="1">
                    </label>
                    <label class="org-field-label" id="lbl-games-per-set">Gemy do wygrania seta
                      <input class="org-field-input" type="number" name="games_per_set" min="1" max="21" step="1">
                    </label>
                    <label class="org-field-label">Tie-breaker (remis punktowy)
                      <select class="org-field-input org-field-select" name="tie_breaker_priority">
                        <option value="SETS">Bilans setów</option>
                        <option value="GAMES">Bilans gemów</option>
                        <option value="HEAD">Bezpośrednie spotkanie</option>
                      </select>
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za mecz</div>
                    <label class="org-field-label">Za wygraną
                      <input class="org-field-input" type="number" name="points_for_win" min="-100" max="100" step="0.01">
                    </label>
                    <label class="org-field-label">Za przegraną
                      <input class="org-field-input" type="number" name="points_for_loss" min="-100" max="100" step="0.01">
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za sety</div>
                    <label class="org-field-label">Za wygrany set
                      <input class="org-field-input" type="number" name="points_for_set_win" min="-100" max="100" step="0.01">
                    </label>
                    <label class="org-field-label">Za przegrany set
                      <input class="org-field-input" type="number" name="points_for_set_loss" min="-100" max="100" step="0.01">
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Punkty za gemy</div>
                    <label class="org-field-label">Za wygrany gem
                      <input class="org-field-input" type="number" name="points_for_gem_win" min="-100" max="100" step="0.01">
                    </label>
                    <label class="org-field-label">Za przegrany gem
                      <input class="org-field-input" type="number" name="points_for_gem_loss" min="-100" max="100" step="0.01">
                    </label>
                  </div>

                  <div class="org-config-group">
                    <div class="org-config-group-label">Super tie-break</div>
                    <label class="org-field-label">Za wygrany punkt (STB)
                      <input class="org-field-input" type="number" name="points_for_supertiebreak_win" min="-100" max="100" step="0.01">
                    </label>
                    <label class="org-field-label">Za przegrany punkt (STB)
                      <input class="org-field-input" type="number" name="points_for_supertiebreak_loss" min="-100" max="100" step="0.01">
                    </label>
                  </div>

                </div>

                <div class="org-form-actions" style="margin-top:12px;">
                  <button type="submit" class="org-save-btn" id="org-config-save-btn">Zapisz konfigurację</button>
                  <span class="org-form-msg" id="org-config-msg"></span>
                </div>
              </form>

              <!-- Zakończ turniej — widoczny tylko gdy status ACT -->
              <div id="org-finish-section" style="display:none; padding:0 20px 20px; border-top:1px solid var(--border); margin-top:8px; padding-top:16px;">
                <div class="org-section-label" style="margin-bottom:12px;">Zakończenie turnieju</div>
                <div id="org-finish-confirm" style="display:none;" class="org-finish-confirm-box">
                  <p class="org-finish-confirm__msg">
                    Czy na pewno chcesz zakończyć turniej? Ranking zostanie automatycznie przeliczony. Tej akcji nie można cofnąć.
                  </p>
                  <div class="org-finish-confirm__actions">
                    <button id="org-finish-yes-btn" class="org-finish-btn org-finish-btn--danger">
                      Tak, zakończ turniej
                    </button>
                    <button id="org-finish-cancel-btn" class="org-finish-btn org-finish-btn--ghost">
                      Anuluj
                    </button>
                  </div>
                </div>
                <div id="org-finish-trigger-wrap">
                  <button id="org-finish-btn" class="org-finish-btn org-finish-btn--outline">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    Zakończ turniej
                  </button>
                  <span id="org-finish-msg" class="org-form-msg" style="margin-left:12px;"></span>
                </div>
              </div>

            </div>
          </div>

          <!-- Dane meczów, uczestników i config dla org-panel JS (SSR JSON) -->
          {tournament && (
            <script id="ssr-matches-data" type="application/json" set:html={JSON.stringify(tournament.matches)} />
          )}
          {tournament && (
            <script id="ssr-participants-data" type="application/json" set:html={JSON.stringify(tournament.participants)} />
          )}
          {tournament?.config && (
            <script id="ssr-config-data" type="application/json" set:html={JSON.stringify(tournament.config)} />
          )}

          <!-- ── Konfiguracja (zwijana) ─────────────────────────────────── -->
          {tournament.config && (
            <details class="tc-card td-config-card">
              <summary class="tc-card-header" style="cursor:pointer; list-style:none;">
                <span class="tc-card-title">Zasady i punktacja</span>
                <span style="font-size:0.78rem; color:var(--text-dim);">▾ rozwiń</span>
              </summary>
              <div class="td-config-body">
                <div class="td-config-grid">
                  <div>
                    <div class="td-config-row"><span>Format meczu</span><strong>Do {tournament.config.sets_to_win} wygranych setów</strong></div>
                    <div class="td-config-row"><span>Format seta</span><strong>Do {tournament.config.games_per_set} gemów</strong></div>
                    <div class="td-config-row"><span>Kryterium remisu</span><strong>{TIE_LABEL[tournament.config.tie_breaker_priority] ?? tournament.config.tie_breaker_priority}</strong></div>
                    <div class="td-config-row"><span>Maks. uczestników</span><strong>{tournament.config.max_participants}</strong></div>
                  </div>
                  <div>
                    <div class="td-config-row"><span>Wygrana mecz</span><strong>+{tournament.config.points_for_win} pkt</strong></div>
                    <div class="td-config-row"><span>Przegrana mecz</span><strong>+{tournament.config.points_for_loss} pkt</strong></div>
                    <div class="td-config-row"><span>Bonus wygr. set</span><strong>+{tournament.config.points_for_set_win} pkt</strong></div>
                    <div class="td-config-row"><span>Kara przegr. set</span><strong>{tournament.config.points_for_set_loss} pkt</strong></div>
                    <div class="td-config-row"><span>Bonus wygr. gem</span><strong>+{tournament.config.points_for_gem_win} pkt</strong></div>
                  </div>
                </div>
              </div>
            </details>
          )}

        </div>
      )}
    </>
  )}

</AppLayout>

<style>
