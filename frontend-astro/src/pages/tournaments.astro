---
// tournaments.astro — lista turniejów z danymi demo
// Docelowo: GET /api/tournaments/ (istnieje w Django, wymaga odkomentowania path('api/',...))
import AppLayout from '@/layouts/AppLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

// Dane demo — docelowo z /api/tournaments/
const tournaments = [
  {
    id: 1,
    name: 'Puchar Jesieni 2026',
    type: 'SGL',
    typeName: 'Single Elimination',
    format: 'SNG',
    formatName: 'Singiel',
    startDate: '28 Paź 2026',
    endDate:   '29 Paź 2026',
    status: 'REG',   // DRAFT | REG | ACT | FIN
    statusLabel: 'Rejestracja',
    participants: 16,
    maxParticipants: 16,
    registered: true,
    facility: 'Korty Otwock',
  },
  {
    id: 2,
    name: 'Liga Zimowa — Runda 3',
    type: 'RND',
    typeName: 'Round Robin',
    format: 'SNG',
    formatName: 'Singiel',
    startDate: '15 Lis 2026',
    endDate:   '15 Lis 2026',
    status: 'REG',
    statusLabel: 'Rejestracja',
    participants: 9,
    maxParticipants: 12,
    registered: false,
    facility: 'Hala Praga',
  },
  {
    id: 3,
    name: 'Americano Sobotni #8',
    type: 'AMR',
    typeName: 'Americano',
    format: 'DBL',
    formatName: 'Debel',
    startDate: '5 Lis 2026',
    endDate:   '5 Lis 2026',
    status: 'REG',
    statusLabel: 'Rejestracja',
    participants: 6,
    maxParticipants: 8,
    registered: false,
    facility: 'Korty Otwock',
  },
  {
    id: 4,
    name: 'Turniej Świąteczny 2026',
    type: 'SWS',
    typeName: 'System Szwajcarski',
    format: 'SNG',
    formatName: 'Singiel',
    startDate: '20 Gru 2026',
    endDate:   '21 Gru 2026',
    status: 'DRAFT',
    statusLabel: 'Wkrótce',
    participants: 0,
    maxParticipants: 24,
    registered: false,
    facility: 'Hala Praga',
  },
  {
    id: 5,
    name: 'Liga Letnia — Finał',
    type: 'RND',
    typeName: 'Round Robin',
    format: 'SNG',
    formatName: 'Singiel',
    startDate: '10 Wrz 2026',
    endDate:   '11 Wrz 2026',
    status: 'FIN',
    statusLabel: 'Zakończony',
    participants: 12,
    maxParticipants: 12,
    registered: true,
    facility: 'Korty Otwock',
    winner: 'Tomasz Bąk',
  },
];

const statusBadge: Record<string, string> = {
  DRAFT: 'tc-badge-neutral',
  REG:   'tc-badge-success',
  ACT:   'tc-badge-warning',
  FIN:   'tc-badge-neutral',
};

const typeBadge: Record<string, string> = {
  SGL: 'tc-badge-info',
  RND: 'tc-badge-primary',
  AMR: 'tc-badge-warning',
  SWS: 'tc-badge-neutral',
  DBE: 'tc-badge-neutral',
  LDR: 'tc-badge-neutral',
};

const typeColor: Record<string, string> = {
  SGL: '#3b82f6',
  RND: '#22c55e',
  AMR: '#f59e0b',
  SWS: '#8b5cf6',
  DBE: '#6b7280',
  LDR: '#6b7280',
};

const active   = tournaments.filter(t => t.status === 'REG' || t.status === 'ACT');
const finished = tournaments.filter(t => t.status === 'FIN');
const upcoming = tournaments.filter(t => t.status === 'DRAFT');
---

<AppLayout
  title="Turnieje"
  greeting="Turnieje"
  showSearch={false}
  showCta={true}
  ctaLabel="+ Nowy turniej"
  ctaHref="/tournaments/create"
>

  <PageHeader
    eyebrow="Rozgrywki"
    title="Turnieje"
    subtitle="Lista aktywnych i nadchodzących turniejów. Zarejestruj się lub śledź wyniki."
  />

  <!-- Stats row -->
  <div class="t-stats-row">
    <div class="t-stat">
      <span class="t-stat__val">{active.length}</span>
      <span class="t-stat__lbl">Otwarta rejestracja</span>
    </div>
    <div class="t-stat">
      <span class="t-stat__val">{tournaments.filter(t => t.registered).length}</span>
      <span class="t-stat__lbl">Zapisany</span>
    </div>
    <div class="t-stat">
      <span class="t-stat__val">{finished.length}</span>
      <span class="t-stat__lbl">Zakończone</span>
    </div>
    <div class="t-stat">
      <span class="t-stat__val">{upcoming.length}</span>
      <span class="t-stat__lbl">Wkrótce</span>
    </div>
  </div>

  <!-- Aktywne turnieje -->
  {active.length > 0 && (
    <section aria-labelledby="active-heading">
      <h2 class="section-label" id="active-heading">Otwarta rejestracja</h2>
      <div class="t-grid">
        {active.map(t => (
          <article class="t-card" aria-label={t.name}>
            <!-- Pasek koloru na górze karty wg typu -->
            <div class="t-card__stripe" style={`background:${typeColor[t.type]}`} aria-hidden="true"></div>

            <div class="t-card__body">
              <div class="t-card__top">
                <div class="t-card__badges">
                  <span class={`tc-badge ${typeBadge[t.type]}`}>{t.typeName}</span>
                  <span class="tc-badge tc-badge-neutral">{t.formatName}</span>
                </div>
                {t.registered && (
                  <span class="t-card__registered" title="Jesteś zarejestrowany">
                    <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    Zarejestrowany
                  </span>
                )}
              </div>

              <h3 class="t-card__name">{t.name}</h3>

              <div class="t-card__meta">
                <div class="t-card__meta-item">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                  </svg>
                  {t.startDate}{t.endDate !== t.startDate ? ` – ${t.endDate}` : ''}
                </div>
                <div class="t-card__meta-item">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                  </svg>
                  {t.facility}
                </div>
              </div>

              <!-- Participants bar -->
              <div class="t-card__participants">
                <div class="t-part-bar">
                  <div
                    class="t-part-bar__fill"
                    style={`width:${Math.round(t.participants/t.maxParticipants*100)}%; background:${typeColor[t.type]}`}
                    aria-hidden="true"
                  ></div>
                </div>
                <span class="t-part-bar__label">
                  {t.participants}/{t.maxParticipants} uczestników
                  {t.participants >= t.maxParticipants && <strong> · Pełny</strong>}
                </span>
              </div>
            </div>

            <div class="t-card__footer">
              <span class={`tc-badge ${statusBadge[t.status]}`}>{t.statusLabel}</span>
              <div style="display:flex; gap:8px;">
                {!t.registered && t.participants < t.maxParticipants
                  ? <a href={`/tournaments/${t.id}`} class="tc-btn tc-btn-primary tc-btn-sm">Zapisz się</a>
                  : <a href={`/tournaments/${t.id}`} class="tc-btn tc-btn-secondary tc-btn-sm">Szczegóły</a>
                }
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Wkrótce -->
  {upcoming.length > 0 && (
    <section aria-labelledby="upcoming-heading" style="margin-top:28px;">
      <h2 class="section-label" id="upcoming-heading">Wkrótce</h2>
      <div class="t-grid">
        {upcoming.map(t => (
          <article class="t-card t-card--dim" aria-label={t.name}>
            <div class="t-card__stripe" style={`background:${typeColor[t.type]}; opacity:0.4`} aria-hidden="true"></div>
            <div class="t-card__body">
              <div class="t-card__top">
                <span class={`tc-badge ${typeBadge[t.type]}`}>{t.typeName}</span>
              </div>
              <h3 class="t-card__name">{t.name}</h3>
              <div class="t-card__meta">
                <div class="t-card__meta-item">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                  </svg>
                  {t.startDate}
                </div>
              </div>
            </div>
            <div class="t-card__footer">
              <span class="tc-badge tc-badge-neutral">{t.statusLabel}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Zakończone -->
  {finished.length > 0 && (
    <section aria-labelledby="finished-heading" style="margin-top:28px;">
      <h2 class="section-label" id="finished-heading">Zakończone</h2>
      <div class="t-grid">
        {finished.map(t => (
          <article class="t-card t-card--dim" aria-label={t.name}>
            <div class="t-card__stripe" style="background:var(--border);" aria-hidden="true"></div>
            <div class="t-card__body">
              <div class="t-card__top">
                <span class={`tc-badge ${typeBadge[t.type]}`}>{t.typeName}</span>
              </div>
              <h3 class="t-card__name">{t.name}</h3>
              <div class="t-card__meta">
                <div class="t-card__meta-item">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                  </svg>
                  {t.startDate}
                </div>
              </div>
              {t.winner && (
                <div class="t-card__winner">
                  🏆 Zwycięzca: <strong>{t.winner}</strong>
                </div>
              )}
            </div>
            <div class="t-card__footer">
              <span class="tc-badge tc-badge-neutral">{t.statusLabel}</span>
              <a href={`/tournaments/${t.id}`} class="tc-btn tc-btn-ghost tc-btn-sm">Wyniki →</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

</AppLayout>

<style>
  /* ── Stats row ─────────────────────────────────────────────────────────── */
  .t-stats-row {
    display: flex; gap: 16px; flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .t-stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px 20px;
    display: flex; flex-direction: column; gap: 2px;
    min-width: 120px;
    box-shadow: var(--shadow-card);
  }

  .t-stat__val {
    font-size: 1.6rem; font-weight: 900; color: var(--text);
    letter-spacing: -0.04em; line-height: 1;
  }
  .t-stat__lbl {
    font-size: 0.72rem; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.05em;
  }

  /* ── Section labels ────────────────────────────────────────────────────── */
  .section-label {
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 12px;
    padding-left: 2px;
  }

  /* ── Tournament grid ───────────────────────────────────────────────────── */
  .t-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  /* ── Tournament card ───────────────────────────────────────────────────── */
  .t-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex; flex-direction: column;
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .t-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .t-card--dim { opacity: 0.8; }
  .t-card--dim:hover { opacity: 1; }

  .t-card__stripe { height: 3px; flex-shrink: 0; }

  .t-card__body { padding: 18px 20px; flex: 1; }

  .t-card__top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px; gap: 8px; flex-wrap: wrap;
  }

  .t-card__badges { display: flex; gap: 5px; flex-wrap: wrap; }

  .t-card__registered {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.72rem; font-weight: 600;
    color: #22c55e;
    background: rgba(34,197,94,0.1);
    padding: 2px 8px; border-radius: 99px;
    white-space: nowrap;
  }

  .t-card__name {
    font-size: 1rem; font-weight: 700; color: var(--text);
    margin-bottom: 10px; line-height: 1.3;
  }

  .t-card__meta {
    display: flex; flex-direction: column; gap: 5px;
    margin-bottom: 14px;
  }

  .t-card__meta-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.8rem; color: var(--text-muted);
  }
  .t-card__meta-item svg { flex-shrink: 0; color: var(--text-dim); }

  /* Participants progress bar */
  .t-card__participants { display: flex; flex-direction: column; gap: 5px; }

  .t-part-bar {
    height: 5px; border-radius: 99px;
    background: var(--surface-2);
    overflow: hidden;
  }
  .t-part-bar__fill {
    height: 100%; border-radius: 99px;
    transition: width 0.3s;
  }
  .t-part-bar__label {
    font-size: 0.75rem; color: var(--text-muted);
  }

  .t-card__footer {
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface-2);
    display: flex; align-items: center; justify-content: space-between;
  }

  .t-card__winner {
    margin-top: 8px;
    font-size: 0.82rem; color: var(--text-muted);
  }
  .t-card__winner strong { color: var(--text); }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .t-grid { grid-template-columns: 1fr; }
    .t-stats-row { gap: 10px; }
    .t-stat { padding: 12px 16px; min-width: 90px; }
  }
</style>
