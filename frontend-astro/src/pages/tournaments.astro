---
// tournaments.astro — placeholder page
// Docelowo: pobiera dane z GET /api/tournaments/ (już istnieje w Django)
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Turnieje" pageTitle="Turnieje">

  <div class="page-header">
    <div class="page-header__eyebrow">Rozgrywki</div>
    <h1 class="page-header__title">Turnieje</h1>
    <p class="page-header__subtitle">
      Lista turniejów i rejestracja. Dane z <code>GET /api/tournaments/</code> (istnieje w Django — wymaga odkomentowania ścieżki API).
    </p>
  </div>

  <!-- Karty placeholder -->
  <div class="cards-grid">
    {['Turniej A', 'Turniej B', 'Turniej C'].map(name => (
      <div class="card">
        <div class="card-body">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
            <span class="badge badge-neutral">Placeholder</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--text-dim)">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <div style="font-weight:700; font-size:1rem; color:var(--text); margin-bottom:6px;">{name}</div>
          <div style="font-size:0.82rem; color:var(--text-muted);">Data: —</div>
          <div style="font-size:0.82rem; color:var(--text-muted);">Status: —</div>
        </div>
        <div class="card-footer" style="text-align:right;">
          <button class="btn-outline" disabled>Szczegóły →</button>
        </div>
      </div>
    ))}
  </div>

  <div class="empty-notice">
    Dane pojawią się po podłączeniu <code>GET /api/tournaments/</code>
  </div>

</AppLayout>

<style>
  .page-header { margin-bottom: 28px; }
  .page-header__eyebrow {
    font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--primary); margin-bottom: 4px;
  }
  .page-header__title {
    font-size: 1.6rem; font-weight: 800; color: var(--text);
    line-height: 1.15; letter-spacing: -0.02em;
  }
  .page-header__subtitle {
    margin-top: 4px; font-size: 0.9rem; color: var(--text-muted);
  }
  .page-header__subtitle code {
    font-family: var(--font-mono); font-size: 0.82rem;
    background: var(--surface-2); padding: 1px 5px; border-radius: 4px;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .card-body { padding: 20px; }
  .card-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface-2);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  .badge-neutral {
    display: inline-flex; padding: 2px 8px; border-radius: 99px;
    font-size: 0.72rem; font-weight: 600;
    background: var(--surface-2); color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .btn-outline {
    padding: 6px 14px; border-radius: var(--radius-sm);
    border: 1px solid var(--border); background: transparent;
    color: var(--text-muted); font-size: 0.82rem; cursor: pointer;
  }
  .btn-outline:disabled { opacity: 0.4; cursor: not-allowed; }

  .empty-notice {
    font-size: 0.82rem; color: var(--text-dim);
    font-family: var(--font-mono);
    text-align: center; padding: 16px;
  }
  .empty-notice code { background: var(--surface-2); padding: 1px 5px; border-radius: 4px; }
</style>
