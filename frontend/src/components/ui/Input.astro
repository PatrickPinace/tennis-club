---
/**
 * Input Component
 *
 * Props:
 * - type: string (default: 'text')
 * - name: string
 * - placeholder: string
 * - value: string
 * - disabled: boolean
 * - required: boolean
 * - class: string (additional classes)
 */

interface Props {
  type?: string;
  name: string;
  placeholder?: string;
  value?: string;
  disabled?: boolean;
  required?: boolean;
  class?: string;
}

const {
  type = 'text',
  name,
  placeholder,
  value,
  disabled = false,
  required = false,
  class: className = ''
} = Astro.props;

const baseStyles = 'w-full px-4 py-2 rounded-lg border border-[var(--color-border)] bg-white text-[var(--color-text-primary)] placeholder:text-[var(--color-text-tertiary)] transition-all duration-200';
const focusStyles = 'focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent';
const disabledStyles = 'disabled:bg-[var(--color-gray-50)] disabled:cursor-not-allowed disabled:opacity-60';

const classes = `${baseStyles} ${focusStyles} ${disabledStyles} ${className}`;
---

<input
  type={type}
  name={name}
  placeholder={placeholder}
  value={value}
  disabled={disabled}
  required={required}
  class={classes}
/>
