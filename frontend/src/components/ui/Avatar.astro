---
/**
 * Avatar Component
 *
 * Props:
 * - src: string (image URL)
 * - alt: string (user name)
 * - size: 'sm' | 'md' | 'lg' | 'xl'
 * - class: string (additional classes)
 */

interface Props {
  src?: string;
  alt: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const {
  src,
  alt,
  size = 'md',
  class: className = ''
} = Astro.props;

const sizeStyles = {
  sm: 'w-8 h-8 text-xs',
  md: 'w-10 h-10 text-sm',
  lg: 'w-12 h-12 text-base',
  xl: 'w-16 h-16 text-lg',
};

const baseStyles = 'rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary-light)] text-white font-semibold flex items-center justify-center overflow-hidden';

const classes = `${baseStyles} ${sizeStyles[size]} ${className}`;

// Get initials from name
const initials = alt
  .split(' ')
  .map(word => word[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<div class={classes}>
  {src ? (
    <img src={src} alt={alt} class="w-full h-full object-cover" />
  ) : (
    <span>{initials}</span>
  )}
</div>
