---
/**
 * Tournament Card Component
 * Displays a single tournament in a card format
 *
 * Props:
 * - tournament: TournamentListItem
 */

import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import type { TournamentListItem, TournamentStatus } from '../../types/tournament';

interface Props {
  tournament: TournamentListItem;
  class?: string;
}

const { tournament, class: className = '' } = Astro.props;

// Format dates
const startDate = new Date(tournament.start_date);
const endDate = new Date(tournament.end_date);

const formatDateRange = () => {
  const startDay = startDate.getDate();
  const endDay = endDate.getDate();
  const startMonth = startDate.toLocaleDateString('pl-PL', { month: 'short' });
  const endMonth = endDate.toLocaleDateString('pl-PL', { month: 'short' });

  if (startMonth === endMonth) {
    return `${startDay}-${endDay} ${startMonth}`;
  }
  return `${startDay} ${startMonth} - ${endDay} ${endMonth}`;
};

// Status badge config
const statusConfig: Record<TournamentStatus, { variant: 'success' | 'warning' | 'info' | 'neutral' | 'error', label: string }> = {
  draft: { variant: 'neutral', label: 'Szkic' },
  registration: { variant: 'info', label: 'Rejestracja' },
  scheduled: { variant: 'warning', label: 'Zaplanowany' },
  active: { variant: 'success', label: 'W trakcie' },
  finished: { variant: 'neutral', label: 'Zakończony' },
  cancelled: { variant: 'error', label: 'Odwołany' }
};

const statusBadge = statusConfig[tournament.status];

// Tournament type and format labels
const typeLabel = tournament.tournament_type === 'round_robin' ? 'Liga' : 'Puchar';
const formatLabel = tournament.match_format === 'singles' ? 'Singiel' : 'Debel';

// Calculate if registration is available
const isRegistrationOpen = tournament.status === 'registration';
const isFull = tournament.participant_count >= tournament.max_participants;
---

<Card class={`cursor-pointer hover:shadow-lg transition-shadow ${className}`}>
  <div class="p-6">
    <!-- Header with status -->
    <div class="flex items-start justify-between mb-4">
      <div class="flex-1 mr-4">
        <h3 class="text-[18px] font-bold leading-[24px] tracking-[-0.01em] text-[#111827] mb-1">
          {tournament.name}
        </h3>
        <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
          {formatDateRange()}
        </p>
      </div>
      <Badge variant={statusBadge.variant} size="sm">
        {statusBadge.label}
      </Badge>
    </div>

    <!-- Tournament info -->
    <div class="space-y-2 mb-4">
      <div class="flex items-center gap-2 text-[13px] text-[#6B7280]">
        <span class="font-semibold">{typeLabel}</span>
        <span>•</span>
        <span class="font-semibold">{formatLabel}</span>
        {tournament.facility && (
          <>
            <span>•</span>
            <span>{tournament.facility.name}</span>
          </>
        )}
      </div>

      <div class="flex items-center gap-2 text-[13px] text-[#6B7280]">
        <span>Ranga:</span>
        <span class="font-semibold">{'⭐'.repeat(tournament.rank)}</span>
      </div>

      <div class="text-[13px] text-[#6B7280]">
        <span>Uczestnicy: </span>
        <span class="font-semibold text-[#111827]">
          {tournament.participant_count}/{tournament.max_participants}
        </span>
        {isFull && <span class="ml-2 text-red-600 font-semibold">(Pełny)</span>}
      </div>
    </div>

    <!-- User participation status -->
    {tournament.is_participant && tournament.user_participant && (
      <div class="mt-4 rounded-[10px] bg-[#4CAF50]/10 p-3 border border-[#4CAF50]/20">
        <p class="text-[13px] font-semibold text-[#4CAF50]">
          Jesteś uczestnikiem
        </p>
        {tournament.user_participant.seed && (
          <p class="text-[12px] text-[#6B7280] mt-1">
            Rozstawienie: {tournament.user_participant.seed}
          </p>
        )}
      </div>
    )}

    <!-- Registration availability -->
    {!tournament.is_participant && isRegistrationOpen && !isFull && (
      <div class="mt-4">
        <button class="h-10 w-full rounded-[10px] bg-[#4CAF50] text-[14px] font-semibold text-white transition-colors hover:bg-[#43A047]">
          Zapisz się
        </button>
      </div>
    )}

    <!-- Winner info for finished tournaments -->
    {tournament.status === 'finished' && tournament.winner && (
      <div class="mt-4 rounded-[10px] bg-yellow-50 p-3 border border-yellow-200">
        <p class="text-[13px] font-semibold text-yellow-900">
          🏆 Zwycięzca: {tournament.winner.display_name}
        </p>
      </div>
    )}

    <!-- Description if available -->
    {tournament.description && (
      <p class="mt-3 text-[13px] font-normal leading-[18px] text-[#6B7280] line-clamp-2">
        {tournament.description}
      </p>
    )}
  </div>
</Card>
