---
/**
 * Login Page
 * Authenticates users with Django backend
 */

import AuthLayout from '@layouts/AuthLayout.astro';
import Button from '@components/ui/Button.astro';
import Input from '@components/ui/Input.astro';
import Card from '@components/ui/Card.astro';

export const prerender = false; // SSR on-demand

// Check if user is already logged in
if (Astro.locals.user) {
  return Astro.redirect('/app');
}

const error = Astro.url.searchParams.get('error');

let errorMessage = '';
if (error === 'session_expired') {
  errorMessage = 'Twoja sesja wygasła. Zaloguj się ponownie.';
} else if (error === 'verification_failed') {
  errorMessage = 'Błąd weryfikacji sesji. Spróbuj ponownie.';
}
---

<AuthLayout title="Logowanie - Tennis Club">
  <Card>
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold text-[var(--color-text-primary)]">Zaloguj się</h2>
      <p class="text-sm text-[var(--color-text-secondary)] mt-2">
        Wpisz swoje dane aby uzyskać dostęp do aplikacji
      </p>
    </div>

    {errorMessage && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-sm text-red-800">{errorMessage}</p>
      </div>
    )}

    <form action="/api/login" method="POST" class="space-y-4">
      <div>
        <label for="username" class="block text-sm font-medium text-[var(--color-text-primary)] mb-2">
          Login lub email
        </label>
        <Input
          type="text"
          name="username"
          placeholder="nazwa_użytkownika"
          required
        />
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-[var(--color-text-primary)] mb-2">
          Hasło
        </label>
        <Input
          type="password"
          name="password"
          placeholder="••••••••"
          required
        />
      </div>

      <div class="flex items-center justify-between text-sm">
        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="checkbox"
            name="remember"
            class="w-4 h-4 rounded border-[var(--color-border)] text-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-accent)]"
          />
          <span class="text-[var(--color-text-secondary)]">Zapamiętaj mnie</span>
        </label>

        <a href="/forgot-password" class="text-[var(--color-primary)] hover:text-[var(--color-primary-dark)] font-medium">
          Zapomniałeś hasła?
        </a>
      </div>

      <Button type="submit" variant="primary" class="w-full">
        Zaloguj się
      </Button>
    </form>

    <div class="mt-6 text-center">
      <p class="text-sm text-[var(--color-text-secondary)]">
        Nie masz konta?
        <a href="/register" class="text-[var(--color-primary)] hover:text-[var(--color-primary-dark)] font-medium ml-1">
          Zarejestruj się
        </a>
      </p>
    </div>
  </Card>

  <!-- Demo credentials info -->
  <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <p class="text-xs text-blue-800 font-medium mb-1">🔧 Środowisko deweloperskie</p>
    <p class="text-xs text-blue-700">
      Użyj swoich danych z Django aby się zalogować
    </p>
  </div>
</AuthLayout>
