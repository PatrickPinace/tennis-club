---
/**
 * Matches Page (Sprint 4)
 * Displays user's matches with filters
 */

import AppLayout from '@layouts/AppLayout.astro';
import MatchList from '@components/matches/MatchList';

export const prerender = false; // SSR - requires authentication

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}

const userName = user.first_name || user.username;
---

<AppLayout title="Mecze - Tennis Club" user={user}>
  <!-- Page header -->
  <div class="mb-6">
    <h1 class="text-[22px] xl:text-[24px] font-[700] leading-[1.2] tracking-[-0.02em] text-slate-900">
      Moje mecze
    </h1>
    <p class="mt-2 text-[14px] text-[#6B7280]">
      Zobacz historię swoich meczów i wyniki
    </p>
  </div>

  <!-- Match List Component (React Island) -->
  <MatchList client:load showCreateButton={true} />
</AppLayout>
