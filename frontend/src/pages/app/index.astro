---
/**
 * Dashboard Page
 * Main landing page for authenticated users
 */

import AppLayout from '@layouts/AppLayout.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import { getDashboardStats } from '@lib/api/dashboard';

export const prerender = false; // SSR - requires authentication

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login');
}

const userName = user.first_name || user.username;

// Fetch dashboard stats from API
const sessionCookie = Astro.cookies.get('sessionid');
const dashboardStats = sessionCookie ? await getDashboardStats(sessionCookie.value) : null;

// Fallback to defaults if no stats
const stats = dashboardStats || {
  user_stats: { total_matches: 0, wins: 0, losses: 0, win_rate: 0 },
  ranking: { position: 0, elo_rating: 1200, ranking_points: 0, top_percentage: 0 },
  next_reservation: null,
  last_match: null,
  upcoming_tournament: null,
  recent_activity: []
};
---

<AppLayout title="Dashboard - Tennis Club" user={user}>
  <!-- Main dashboard grid -->
  <div class="grid grid-cols-12 gap-6">
    <!-- Welcome section -->
    <div class="col-span-12 mb-0">
      <h1 class="text-[22px] xl:text-[24px] font-[700] leading-[1.2] tracking-[-0.02em] text-slate-900">
        Witaj z powrotem, {userName}!
      </h1>
    </div>

    <!-- 4 Stats cards -->
    <div class="col-span-12 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 xl:gap-6">
    <!-- Najbliższa Rezerwacja - Master Card -->
    <div class="flex h-[160px] flex-col justify-between rounded-[16px] border border-[#E5E7EB] bg-white p-6 shadow-[0_1px_2px_rgba(16,24,40,0.04),0_4px_10px_rgba(16,24,40,0.04)]">
      {stats.next_reservation ? (
        <>
          <div>
            <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
              Najbliższa Rezerwacja
            </p>

            <h3 class="mt-3 text-[18px] font-bold leading-[24px] tracking-[-0.01em] text-[#111827]">
              {stats.next_reservation.date} | {stats.next_reservation.time}
            </h3>

            <p class="mt-1.5 text-[14px] font-medium leading-[20px] text-[#374151]">
              Kort {stats.next_reservation.court.number} ({stats.next_reservation.court.surface})
            </p>
          </div>

          <button class="h-10 w-full rounded-[10px] bg-[#4CAF50] text-[14px] font-semibold text-white transition-colors hover:bg-[#43A047]">
            Zobacz szczegóły
          </button>
        </>
      ) : (
        <>
          <div>
            <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
              Najbliższa Rezerwacja
            </p>

            <p class="mt-3 text-[14px] font-medium leading-[20px] text-[#6B7280]">
              Brak zaplanowanych rezerwacji
            </p>
          </div>

          <button class="h-10 w-full rounded-[10px] bg-[#4CAF50] text-[14px] font-semibold text-white transition-colors hover:bg-[#43A047]">
            Zarezerwuj kort
          </button>
        </>
      )}
    </div>

    <!-- Ostatni Mecz - Drugi Wzorzec -->
    <div class="relative h-[160px] rounded-[16px] border border-[#E5E7EB] bg-white p-6 shadow-[0_1px_2px_rgba(16,24,40,0.04),0_4px_10px_rgba(16,24,40,0.04)]">
      {stats.last_match ? (
        <>
          <div class="pr-10">
            <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
              Ostatni Mecz
            </p>

            <p class={`mt-3 text-[16px] font-bold leading-[22px] ${stats.last_match.result === 'won' ? 'text-[#4CAF50]' : 'text-red-600'}`}>
              {stats.last_match.result === 'won' ? 'Wygrana' : 'Przegrana'}
            </p>

            <p class="mt-1 text-[18px] font-bold leading-[24px] tracking-[-0.01em] text-[#111827]">
              {stats.last_match.score}
            </p>

            <p class="mt-1.5 text-[14px] font-medium leading-[20px] text-[#374151]">
              vs {stats.last_match.opponent}
            </p>

            <p class="mt-0.5 text-[13px] font-normal leading-[18px] text-[#6B7280]">
              {stats.last_match.date}
            </p>
          </div>

          <div class="absolute right-5 top-5 flex h-7 w-7 items-center justify-center text-[#111827]">
            {stats.last_match.result === 'won' ? '🏆' : '🎾'}
          </div>
        </>
      ) : (
        <div class="pr-10">
          <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
            Ostatni Mecz
          </p>

          <p class="mt-3 text-[14px] font-medium leading-[20px] text-[#6B7280]">
            Brak rozegranych meczów
          </p>
        </div>
      )}
    </div>

    <!-- Ranking Klubowy - Wariant z dużą liczbą -->
    <div class="relative h-[160px] rounded-[16px] border border-[#E5E7EB] bg-white p-6 shadow-[0_1px_2px_rgba(16,24,40,0.04),0_4px_10px_rgba(16,24,40,0.04)]">
      <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
        Ranking Klubowy
      </p>

      <div class="mt-3 flex items-baseline gap-2">
        <h3 class="text-[34px] leading-[1] font-[800] tracking-[-0.03em] text-[#111827]">
          #{stats.ranking.position}
        </h3>
        <span class="inline-flex items-center gap-1 text-[13px] font-semibold text-[#4CAF50]">
          ↑
        </span>
      </div>

      <p class="mt-1.5 text-[14px] font-medium leading-[20px] text-[#374151]">
        Top {stats.ranking.top_percentage}% Klubu
      </p>

      <p class="mt-0.5 text-[13px] font-normal leading-[18px] text-[#6B7280]">
        ELO: {stats.ranking.elo_rating}
      </p>
    </div>

    <!-- Nadchodzący Turniej - Wariant z nazwą eventu -->
    <div class="relative h-[160px] rounded-[16px] border border-[#E5E7EB] bg-white p-6 shadow-[0_1px_2px_rgba(16,24,40,0.04),0_4px_10px_rgba(16,24,40,0.04)]">
      {stats.upcoming_tournament ? (
        <>
          <div class="pr-10">
            <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
              Nadchodzący Turniej
            </p>

            <h3 class="mt-3 text-[18px] font-bold leading-[24px] tracking-[-0.01em] text-[#111827]">
              {stats.upcoming_tournament.name}
            </h3>

            <p class="mt-1.5 text-[14px] font-medium leading-[20px] text-[#374151]">
              {stats.upcoming_tournament.date_range}
            </p>

            <p class="mt-0.5 text-[13px] font-normal leading-[18px] text-[#6B7280]">
              {stats.upcoming_tournament.participant_status}
            </p>
          </div>

          <div class="absolute right-5 top-5 flex h-7 w-7 items-center justify-center text-[#111827]">
            🏆
          </div>
        </>
      ) : (
        <div>
          <p class="text-[13px] font-semibold leading-[18px] text-[#6B7280]">
            Nadchodzący Turniej
          </p>

          <p class="mt-3 text-[14px] font-medium leading-[20px] text-[#6B7280]">
            Brak nadchodzących turniejów
          </p>
        </div>
      )}
    </div>
    </div>

    <!-- Calendar section - col-span-12 with grid-cols-12 -->
    <div class="col-span-12 grid grid-cols-1 xl:grid-cols-12 gap-6">
      <!-- Kalendarz Kortów (main) - col-span-9 -->
      <div class="xl:col-span-9">
        <div class="rounded-[18px] border border-slate-200 bg-white p-6 min-h-[520px] grid grid-rows-[auto_1fr]">
          <div class="flex items-center justify-between">
            <h3 class="text-[16px] font-[700] text-slate-900">
              Kalendarz Kortów
            </h3>
            <div class="flex items-center gap-2">
              <button class="h-9 rounded-[10px] border border-slate-200 bg-white px-3 text-[13px] font-[500] text-slate-700 hover:bg-slate-50 transition-colors">
                Today
              </button>
              <button class="h-9 w-9 rounded-[10px] border border-slate-200 bg-white text-slate-500 flex items-center justify-center hover:bg-slate-50 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                </svg>
              </button>
            </div>
          </div>

          <div class="mt-5 text-center flex flex-col items-center justify-center">
            <div class="text-6xl mb-4">📅</div>
            <h4 class="text-[18px] font-[700] text-slate-900 mb-2">
              Widok kalendarza w toku
            </h4>
            <p class="text-[13px] text-slate-500 mb-4">
              Zaawansowany kalendarz z mini kalendarzem i schedule grid
            </p>
            <button class="h-10 rounded-[10px] bg-[#4CAF50] px-4 text-[14px] font-[600] text-white hover:bg-[#43A047] transition-colors">
              Przejdź do rezerwacji
            </button>
          </div>
        </div>
      </div>

      <!-- Right Column: Statystyki + Aktywność - col-span-3 -->
      <div class="xl:col-span-3 flex flex-col gap-6">
        <!-- Moje Statystyki -->
        <div class="rounded-[16px] border border-slate-200 bg-white p-5 min-h-[232px]">
          <h3 class="text-[15px] font-[700] text-slate-900">
            Moje Statystyki
          </h3>

          <div class="mt-5 grid grid-cols-3 gap-3">
            <div class="text-center">
              <p class="text-[12px] font-[600] text-slate-500">Mecze</p>
              <p class="mt-1 text-[18px] xl:text-[20px] font-[800] text-slate-900">{stats.user_stats.total_matches}</p>
            </div>
            <div class="text-center">
              <p class="text-[12px] font-[600] text-slate-500">Wygrane</p>
              <p class="mt-1 text-[18px] xl:text-[20px] font-[800] text-slate-900">{stats.user_stats.wins}</p>
            </div>
            <div class="text-center">
              <p class="text-[12px] font-[600] text-slate-500">Win Rate</p>
              <p class="mt-1 text-[18px] xl:text-[20px] font-[800] text-slate-900">{stats.user_stats.win_rate}%</p>
            </div>
          </div>

          <div class="mt-5 h-[72px] rounded-[12px] bg-slate-50 px-3 py-2 flex items-center justify-center">
            <div class="text-3xl mb-2">📈</div>
          </div>
        </div>

        <!-- Ostatnia Aktywność -->
        <div class="rounded-[16px] border border-slate-200 bg-white p-5">
          <h3 class="text-[15px] font-[700] text-slate-900">
            Ostatnia Aktywność
          </h3>

          <div class="mt-4 divide-y divide-slate-100">
            {stats.recent_activity.length > 0 ? (
              stats.recent_activity.map((activity) => {
                const icon = activity.type === 'match' ? '🎾' : activity.type === 'tournament' ? '🏆' : activity.type === 'reservation' ? '📅' : 'ℹ️';

                return (
                  <div class="flex items-start gap-3 py-3 min-h-[60px]">
                    <div class="h-8 w-8 rounded-[10px] bg-slate-50 flex items-center justify-center text-slate-500 shrink-0">
                      <span class="text-sm">{icon}</span>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-[14px] font-[600] text-slate-900 leading-[18px]">
                        {activity.title}
                      </p>
                      <p class="mt-1 text-[12px] leading-[16px] text-slate-500">
                        {activity.message}
                      </p>
                    </div>
                  </div>
                );
              })
            ) : (
              <p class="py-4 text-[13px] text-slate-500 text-center">
                Brak aktywności
              </p>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
