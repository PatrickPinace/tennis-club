---
/**
 * AuthLayout
 * Layout for authentication pages (login, register, forgot password)
 */

import '@styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Tennis Club - Logowanie' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gradient-to-br from-[var(--color-bg-secondary)] via-white to-green-50 min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] text-white font-bold text-2xl mb-4 shadow-lg">
          TC
        </div>
        <h1 class="text-2xl font-bold text-[var(--color-primary)]">Tennis Club</h1>
        <p class="text-sm text-[var(--color-text-secondary)] mt-2">Twoja aplikacja tenisowa</p>
      </div>

      <!-- Content -->
      <slot />

      <!-- Footer -->
      <p class="text-center text-xs text-[var(--color-text-tertiary)] mt-8">
        &copy; 2026 Tennis Club. Wszystkie prawa zastrzeżone.
      </p>
    </div>
  </body>
</html>
